        </subNodes>
    </thinkRoot>
</ThinkTreeDef>

<ThinkTreeDef>
    <defName>Gestapo_Militors_ThinkTreeMain</defName>
    <thinkRoot Class="ThinkNode_Priority">
        <subNodes>
            <!-- 异常状态处理 -->
            <li Class="ThinkNode_Subtree">
                <treeDef>Despawned</treeDef>
            </li>
            <li Class="ThinkNode_Subtree">
                <treeDef>Downed</treeDef>
            </li>
            <li Class="ThinkNode_Subtree">
                <treeDef>MentalStateCritical</treeDef>
            </li>

            <!-- 常规行为 -->
            <li Class="ThinkNode_QueuedJob" />
            <li Class="ThinkNode_Subtree">
                <treeDef>MentalStateNonCritical</treeDef>
            </li>
            <li Class="ThinkNode_ConditionalForcedGoto">
                <subNodes>
                    <li Class="JobGiver_ForcedGoto" />
                </subNodes>
            </li>

            <!-- 玩家机械族技能释放（优先级高） -->
            <li Class="NCL.ThinkNode_ConditionalPlayerFaction">
                <subNodes>
                    <li Class="ThinkNode_ConditionalCanDoConstantThinkTreeJobNow">
                        <subNodes>
                            <li Class="NCL.JobGiver_AttackMinitor">
                            </li>
                        </subNodes>
                    </li>
                </subNodes>
            </li>

            <!-- 空闲行为 -->
            <li Class="ThinkNode_Tagger">
                <tagToGive>Idle</tagToGive>
                <subNodes>
					<li Class="ThinkNode_ConditionalPlayerMech">
						<subNodes>
							<li Class="JobGiver_WanderColony" />
							</subNodes>
							</li>
						<li Class="JobGiver_WanderAnywhere" />
					</subNodes>
				</li>
            <li Class="JobGiver_Idle" />
        </subNodes>
    </thinkRoot>
</ThinkTreeDef>

<ThinkTreeDef>
    <defName>Gestapo_Militors_ThinkTreeConstant</defName>
    <thinkRoot Class="ThinkNode_Priority">
        <subNodes>
            <li Class="ThinkNode_Subtree">
                <treeDef>Despawned</treeDef>
            </li>
        </subNodes>
    </thinkRoot>
</ThinkTreeDef>

  <ThinkTreeDef>
    <defName>TW_University_Minitor</defName>
    <thinkRoot Class="ThinkNode_Priority">
      <subNodes>
        
        <!-- Despawned -->
        <li Class="ThinkNode_Subtree">
          <treeDef>Despawned</treeDef>
        </li>

        <li Class="ThinkNode_ConditionalCanDoConstantThinkTreeJobNow">
          <subNodes>
		          <li Class="JobGiver_SeekAllowedArea" /><!-- 
                  <li Class="JobGiver_GetEnergy_Charger" /> -->
                  <li Class="JobGiver_Work">
                    <emergency>true</emergency>
                  </li>
				<li Class="JobGiver_Work" />
						
                  <!--<li Class="AV_Workqueen.JobGiver_Work_Urichin" /> -->
				  
				  
				  
                  <li Class="ThinkNode_ConditionalWorkMech"><!-- Combat mechs do patrolling -->
                    <invert>true</invert>
                    <subNodes>
                      <li Class="JobGiver_AIFightEnemies">
                        <targetAcquireRadius>65</targetAcquireRadius>
                        <targetKeepRadius>72</targetKeepRadius>
                      </li>
                      <li Class="ThinkNode_Tagger">
                        <tagToGive>MiscWork</tagToGive>
                        <subNodes>
                          <li Class="JobGiver_WanderColony">
                            <maxDanger>Deadly</maxDanger>
                            <reportStringOverride TKey="ReportStringPatrolling">Patrolling.</reportStringOverride>
                          </li>
                        </subNodes>
                      </li>
                    </subNodes>
                  </li>
		  <li Class="ThinkNode_ConditionalPlayerMech">
              <subNodes>
                <li Class="JobGiver_WanderColony" />
              </subNodes>
            </li>
			<li Class="JobGiver_WanderAnywhere" />
		  
		  <!-- 
		  
            <li Class="JobGiver_AIFightEnemies">
              <targetAcquireRadius>65</targetAcquireRadius>
              <targetKeepRadius>72</targetKeepRadius>
            </li>
            <li Class="JobGiver_AITrashColonyClose" />
            <li Class="JobGiver_AITrashBuildingsDistant" />
            <li Class="JobGiver_AIGotoNearestHostile" />
            <li Class="JobGiver_AITrashBuildingsDistant">
              <attackAllInert>true</attackAllInert>
            </li>
            <li Class="ThinkNode_ConditionalPlayerMech">
              <subNodes>
                <li Class="JobGiver_WanderColony" />
              </subNodes>
            </li>
            <li Class="JobGiver_WanderAnywhere" />-->
          </subNodes>
		   
        </li>
      </subNodes>
    </thinkRoot>
  </ThinkTreeDef>


</Defs>
