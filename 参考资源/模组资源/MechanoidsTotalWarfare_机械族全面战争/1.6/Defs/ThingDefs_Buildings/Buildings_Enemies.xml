  <ThingDef ParentName="BaseBullet">
    <defName>Shell_TW_BirgusMortar_Rail_Mortar</defName>
    <label>Birgus Mortar shell</label>
    <graphicData>
      <texPath>Projectiles/Shell_TW_BirgusMortar_Rail_Mortar</texPath>
      <graphicClass>Graphic_Single</graphicClass>
      <shaderType>TransparentPostLight</shaderType>
	  <drawSize>3</drawSize>
    </graphicData>
    <thingClass>NCLProjectiles.Projectile_ExplosiveStagedWithEffects</thingClass>
    <projectile>
      <damageDef>NCL_ModBomb</damageDef>
      <damageAmountBase>80</damageAmountBase>
      <explosionRadius>12.5</explosionRadius>
      <speed>28</speed>
      <shadowSize>3</shadowSize>
      <arcHeightFactor>40</arcHeightFactor>
      <flyOverhead>true</flyOverhead>
    </projectile>
    <modExtensions>
      <li Class="NCLProjectiles.ModExtension_ProjectileEffects">
        <stages>
          <li>
            <label>climbing</label>
            <type>Cruise</type>
            <speed>28</speed>
            <positionFunction>EaseInQuad</positionFunction>
			<arcFactor>30</arcFactor>
            <heightOffset>0</heightOffset>
            <heightFunction>EaseOutQuad</heightFunction>
          </li>
        </stages>
      </li>
    </modExtensions>
	<comps>
      <li Class="NCL.CompProperties_SmokeTrail">
        <intervalTicks>2</intervalTicks>
        <smokeSize>1</smokeSize>
      </li>
      <li Class="NCL.CompProperties_SpawnPawnsOnDestroy">
			<pawnKind>TW_Mech_Birgus_Kind</pawnKind>
		<spawnCountRange>
        <min>1</min>
        <max>1</max>
        </spawnCountRange>
			</li>
	  <li Class="NCL.CompProperties_SpawnFleckEffectOnDestroyed">
            <!-- 全局缩放 (可选) -->
            <globalScaleFactor>1.5</globalScaleFactor>
            
            <!-- Fleck效果配置 -->
            <flecks>
                <!-- 烟雾效果 -->
                <li>
                    <fleckDef>Smoke</fleckDef>
                    <count>20</count>          <!-- 生成20个烟雾粒子 -->
                    <scale>2.0</scale>         <!-- 粒子大小 -->
                    <maxOffset>1.8</maxOffset> <!-- 随机位置偏移范围 -->
                    <velocityAngle>90</velocityAngle> <!-- 移动方向(角度) -->
                    <velocitySpeed>0.8</velocitySpeed><!-- 移动速度 -->
                    <durationTicks>180</durationTicks><!-- 存在3秒(60ticks=1秒) -->
                </li>
                
                <!-- 火花效果 -->
                <li>
                    <fleckDef>ExplosionFlash</fleckDef>
                    <count>15</count>
                    <scale>1.2</scale>
                    <maxOffset>2.5</maxOffset>
                    <rotationRate>90</rotationRate> <!-- 旋转速度 -->
                    <solidTime>0.5</solidTime>      <!-- 实体持续时间(秒) -->
                </li>
            </flecks>
            
        </li>
    </comps>
  </ThingDef>

</Defs>