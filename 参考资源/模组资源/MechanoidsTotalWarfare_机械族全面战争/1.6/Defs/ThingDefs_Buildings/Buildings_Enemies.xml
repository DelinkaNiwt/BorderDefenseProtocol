    <ThingDef ParentName="BuildingBase">
    <defName>TW_Airstrike_Signal_Transmitter</defName>
    <label>突袭信号指示终端</label>
    <description>机械族核心支援装备，具有强力护盾及反隐能力的突袭信号指示终端在场时可持续发送加密指令，精准召唤可空降型机械体进行高频投送。
 
突袭机械体将配备伞降突袭背包，搭载 b2000 对殖民地进行骚扰及割裂阵型，为机械族袭击创造突破窗口，是掌控战场主动权的关键设备。</description>
   <uiIconPath>Buildings/TW_Airstrike_Signal_Transmitter</uiIconPath>
    <tickerType>Normal</tickerType>
    <drawerType>RealtimeOnly</drawerType>
    <fillPercent>0.4</fillPercent>  
    <altitudeLayer>Building</altitudeLayer>
    <graphicData>
      <texPath>Buildings/TW_Airstrike_Signal_Transmitter</texPath>
      <graphicClass>Graphic_Single</graphicClass>
      <drawSize>(6,6)</drawSize>
      <shadowData>
        <volume>(0, 0, 0)</volume>
        <offset>(0, 0, -0.2)</offset>
      </shadowData>
    </graphicData>
    <passability>PassThroughOnly</passability>
    <building>
      <buildingTags>
        <li>MechClusterMember</li>
        <li>MechClusterCombatThreat</li>
      </buildingTags>
      <minMechClusterPoints>30000</minMechClusterPoints>
      <combatPower>1000</combatPower>
    </building>
    <uiOrder>2420</uiOrder>
    <rotatable>false</rotatable>
    <statBases>
      <MaxHitPoints>5000</MaxHitPoints>
      <WorkToBuild>8000</WorkToBuild>
      <Mass>500</Mass>
      <Flammability>0</Flammability>
    </statBases>
    <size>(3,3)</size>
    <comps>
  <li Class="NCL.CompProperties_HostilePresence">
        </li>
  <li Class="NCL.CompProperties_ForceFaction">
      <factionDef>Mechanoid</factionDef>
    </li>
      <li Class="CompProperties_ProjectileInterceptor">
        <radius>20</radius>
        <interceptGroundProjectiles>true</interceptGroundProjectiles>
		<interceptAirProjectiles>true</interceptAirProjectiles>
        <interceptNonHostileProjectiles>false</interceptNonHostileProjectiles>
