<?xml version="1.0" encoding="utf-8" ?>
<Defs>


     <ThingDef ParentName="SculptureBase">
    <defName>NCL_Liberty_Leading_the_Militors</defName>
    <label>威镰·莱辛</label>
    <description>威廉·莱辛，象征着自由与反抗的精神丰碑。无数年间无数大学生小蠊在不堪受辱，愤愤丢下一张自愿辞职报告时，总会回想起千百年前，一名名为“威镰·莱辛”的小蠊带领一众小蠊攻破机械族逆重监狱，引领小蠊们走向自由，反抗资本家小蠊压迫的事迹——至少大学生小蠊们受到的高等机械族教育是这么教导他们的。这座雕塑也在各个星球立起，向百年前那位领导小蠊们的伟大机械体致敬</description>
    <castEdgeShadows>true</castEdgeShadows>
    <graphicData>
      <graphicClass>Graphic_Multi</graphicClass>
      <texPath>Buildings/NCL_Liberty_Leading_the_Militors</texPath>
      <drawSize>(1.5,1.5)</drawSize>
    </graphicData>
    <uiIconScale>0.666</uiIconScale>
    <fillPercent>0.5</fillPercent>
    <rotatable>true</rotatable>
    <statBases>
      <MaxHitPoints>150</MaxHitPoints>
      <Mass>7</Mass>
      <Beauty>200</Beauty>
      <WorkToMake>30000</WorkToMake>
    </statBases>
    <costList>
	  <Voluntary_Resignation_Letter>25</Voluntary_Resignation_Letter>
      <Silver>5000</Silver>
    </costList>
  </ThingDef>

</Defs>