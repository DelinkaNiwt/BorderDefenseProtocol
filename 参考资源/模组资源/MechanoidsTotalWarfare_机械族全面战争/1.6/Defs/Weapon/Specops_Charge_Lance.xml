<?xml version="1.0" encoding="utf-8"?>
<Defs>

  
  <ThingDef ParentName="BaseGun">
    <defName>Specops_Charge_Lance</defName>
    <label>特种电荷标枪</label>
    <description>仅在伞兵静螳间装备的特殊电荷标枪，有着极远的射程与不俗的伤害</description>
    <tradeability>None</tradeability>
    <destroyOnDrop>true</destroyOnDrop>
<relicChance>0</relicChance>    
<graphicData>
      <texPath>Weapons/Specops_Charge_Lance</texPath>
      <graphicClass>Graphic_Single</graphicClass>
      <drawSize>1</drawSize>
    </graphicData>
	<uiIconPath>Weapons/Specops_Charge_Lance</uiIconPath>
    <soundInteract>Interact_ChargeLance</soundInteract>
	<equippedAngleOffset>0</equippedAngleOffset>
    <weaponClasses>
      <li>LongShots</li>
      <li>RangedHeavy</li>
    </weaponClasses>
    <statBases>
	  <WorkToMake>20000</WorkToMake>
      <Mass>6.8</Mass>
      <AccuracyTouch>1</AccuracyTouch>
      <AccuracyShort>1</AccuracyShort>
      <AccuracyMedium>0.95</AccuracyMedium>
      <AccuracyLong>0.95</AccuracyLong>
      <RangedWeapon_Cooldown>1.35</RangedWeapon_Cooldown>
    </statBases>
    <smeltable>false</smeltable>
    <verbs>
      <li>
        <verbClass>Verb_Shoot</verbClass>
        <hasStandardCommand>true</hasStandardCommand>
        <defaultProjectile>Bullet_ChargeLance</defaultProjectile>
        <warmupTime>1.2</warmupTime>
        <range>45</range>
        <burstShotCount>3</burstShotCount>
        <ticksBetweenBurstShots>12</ticksBetweenBurstShots>
        <soundCast>ChargeLance_Fire</soundCast>
        <soundCastTail>GunTail_Heavy</soundCastTail>
        <muzzleFlashScale>7</muzzleFlashScale>
      </li>
    </verbs>
    <tools>
      <li>
        <label>stock</label>
        <capacities>
          <li>Blunt</li>
        </capacities>
        <power>20</power>
        <cooldownTime>1</cooldownTime>
      </li>
      <li>
        <label>barrel</label>
        <capacities>
          <li>Blunt</li>
          <li>Poke</li>
        </capacities>
        <power>20</power>
        <cooldownTime>1</cooldownTime>
      </li>
    </tools>
    <weaponTags Inherit="False">
      <li>Specops_Charge_Lance</li>
    </weaponTags>
	<tradeTags>
      <li>Specops_Charge_Lance</li>
    </tradeTags>
  </ThingDef>
  


  <ThingDef ParentName="Proj_GrenadeExplosiveEMP">
    <defName>Proj_GrenadeExplosiveEMP</defName>
    <label>GrenadeExplosiveEMP</label>
  </ThingDef>

 <ThingDef Name="Proj_GrenadeExplosiveEMP" ParentName="BaseGrenadeProjectile" Abstract="True">
    <defName>Proj_GrenadeExplosiveEMP</defName>
    <label>GrenadeExplosiveEMP</label>
    <thingClass>Projectile_Explosive</thingClass>
    <graphicData>
      <texPath>Weapons/Proj_GrenadeExplosiveEMP</texPath>
      <graphicClass>Graphic_Single</graphicClass>
          <drawSize>0.7</drawSize>
    </graphicData>
    <projectile>
      <explosionRadius>4</explosionRadius >
      <damageDef>EMP</damageDef>
      <explosionDelay>100</explosionDelay>
      <speed>12</speed>
      <arcHeightFactor>2</arcHeightFactor>
      <shadowSize>0.4</shadowSize>
    </projectile>
    <comps>
    <li Class="NCL.CompProperties_FragmentedExplosive">
      <explosionRadius>4</explosionRadius>
      <fragmentCount>180</fragmentCount> <!-- 碎片总数 -->
      <guaranteedCenterFraction>0.75</guaranteedCenterFraction> <!-- 一半碎片落在中心 -->
      <fragmentProjectileDef>Bullet_NCL_Fragments</fragmentProjectileDef>
      <fireGlowSize>2.5</fireGlowSize>
    </li>
    </comps>
  </ThingDef>

  <AbilityDef>
    <defName>TW_LaunchGrenadeExplosiveEMP</defName>
    <label>闪耀EMP破片手榴弹</label>
    <description>闪耀EMP手榴弹原产于闪耀世界，威力巨大，可在半径 6 格内产生约180片碎片，处于爆炸中心的敌人将受到巨量伤害，可以有效打击世界各地日渐猖獗的机械体，不过设计之初为了提高对机械体控制效果，内置了EMP 芯管，导致穿甲效果较差。

意外的是，机械主巢也觉得这种手榴弹性能优异，结果被广泛列装于特战伞兵静镗，后来这件事情成了边缘世界津津乐道的黑色笑话。</description>
    <iconPath>Weapons/GrenadeExplosiveEMP</iconPath>
    <aiCanUse>true</aiCanUse>
		<cooldownTicksRange>3000</cooldownTicksRange>
		<cooldownPerCharge>true</cooldownPerCharge>
    <verbProperties>
      <verbClass>Verb_CastAbility</verbClass>
      <range>14.9</range>
      <warmupTime>0.5</warmupTime>
      <soundCast>Shot_IncendiaryLauncher</soundCast>
      <ai_IsBuildingDestroyer>true</ai_IsBuildingDestroyer>
      <targetParams>
        <canTargetLocations>true</canTargetLocations>
      </targetParams>
      <rangedFireRulepack>Combat_RangedFire_Thrown</rangedFireRulepack>
    </verbProperties>
    <comps>
      <li Class="CompProperties_AbilityLaunchProjectile">
        <projectileDef>Proj_GrenadeExplosiveEMP</projectileDef>
      </li>
    </comps>
  </AbilityDef>

  </Defs>