  <ThingDef ParentName="BaseGun">
    <defName>TW_Antiparticle_Rail_Mortar</defName>
    <label>小型核弹发射器</label>
    <description>被称为“毁灭化身”的軌道抛射系统，Doxa-0架设后可启动其核心主炮系统，将小型核弹以重力导轨形式发射出去进行远程打击。
	
可穿透护盾、结构壁垒与能量覆盖层，其打击过程常件随时间延迟。</description>
    <tradeability>None</tradeability>
    <relicChance>0</relicChance>
    <destroyOnDrop>true</destroyOnDrop>
    <graphicData>
      <texPath>Things/None</texPath>
      <graphicClass>Graphic_Single</graphicClass>
      <drawSize>1</drawSize>
    </graphicData>
	<uiIconPath>ModIcon/Antiparticle_Rail_Mortar</uiIconPath>
    <soundInteract>Interact_ChargeLance</soundInteract>
	<equippedAngleOffset>0</equippedAngleOffset>
    <weaponClasses>
      <li>LongShots</li>
      <li>RangedHeavy</li>
    </weaponClasses>
    <statBases>
	  <WorkToMake>20000</WorkToMake>
      <Mass>30</Mass>
      <AccuracyTouch>1</AccuracyTouch>
      <AccuracyShort>1</AccuracyShort>
      <AccuracyMedium>1</AccuracyMedium>
      <AccuracyLong>1</AccuracyLong>
      <RangedWeapon_Cooldown>20</RangedWeapon_Cooldown>
    </statBases>
    <smeltable>false</smeltable>
    <verbs>
      <li>
        <isMortar>true</isMortar>
	    <ai_RangedAlawaysShootGroundBelowTarget>true</ai_RangedAlawaysShootGroundBelowTarget>
        <ai_ProjectileLaunchingIgnoresMeleeThreats>true</ai_ProjectileLaunchingIgnoresMeleeThreats>
        <ai_IsBuildingDestroyer>true</ai_IsBuildingDestroyer>
        <ai_TargetHasRangedAttackScoreOffset>500</ai_TargetHasRangedAttackScoreOffset>
	    <forcedMissRadius>0.5</forcedMissRadius>
        <verbClass>NCL.Verb_AdvancedShoot</verbClass>
        <hasStandardCommand>true</hasStandardCommand>
        <defaultProjectile>Shell_TW_Antiparticle_Rail_Mortar</defaultProjectile>
        <warmupTime>5</warmupTime>
        <range>500</range>
		<minRange>25</minRange>
        <burstShotCount>10</burstShotCount>
        <requireLineOfSight>false</requireLineOfSight>
        <ticksBetweenBurstShots>30</ticksBetweenBurstShots>
        <soundCast>Shot_HellsphereCannonGun</soundCast>
        <soundCastTail>GunTail_Heavy</soundCastTail>
        <muzzleFlashScale>50</muzzleFlashScale>
		<targetParams>
          <canTargetLocations>true</canTargetLocations>
          <canTargetPawns>false</canTargetPawns>
        </targetParams>
      </li>
    </verbs>
    <comps>
		<li Class="NCL.CompProperties_AdvancedAmmo">
			<primaryProjectileCount0>1</primaryProjectileCount0>
			<secondaryProjectile0>Shell_TW_EMP_Rail_Mortar</secondaryProjectile0>
			<secondaryProjectileCount0>1</secondaryProjectileCount0>
			
		</li>
    </comps>
    <tools>
      <li>
        <label>stock</label>
        <capacities>
          <li>Blunt</li>
        </capacities>
        <power>20</power>
        <cooldownTime>1</cooldownTime>
      </li>
      <li>
        <label>barrel</label>
        <capacities>
          <li>Blunt</li>
          <li>Poke</li>
        </capacities>
        <power>20</power>
        <cooldownTime>1</cooldownTime>
      </li>
    </tools>
    <weaponTags Inherit="False">
      <li>TW_Antiparticle_Rail_Mortar</li>
    </weaponTags>
	<tradeTags>
      <li>NCLThings</li>
    </tradeTags>
  </ThingDef>
  
