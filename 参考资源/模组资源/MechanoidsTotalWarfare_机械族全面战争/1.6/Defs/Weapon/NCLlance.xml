<Defs>
  <ThingDef ParentName="BaseBullet">
    <defName>Bullet_NCLChargeLance</defName>
    <label>NCL Charge lance bullet</label>
    <graphicData>
      <texPath>Things/Projectile/ChargeLanceShot</texPath>
      <graphicClass>Graphic_Single</graphicClass>
      <drawSize>1.5</drawSize>
	  <shaderType>TransparentPostLight</shaderType>
      <color>(159,9,14)</color>
    </graphicData>
    <projectile>
      <damageDef>Bullet</damageDef>
      <damageAmountBase>24</damageAmountBase>
      <armorPenetrationBase>0.8</armorPenetrationBase>
	  <stoppingPower>1.5</stoppingPower>
      <speed>150</speed>
    </projectile>
  </ThingDef>
  
  <ThingDef ParentName="BaseGun">
    <defName>NCLLance</defName>
    <label>NCL电荷标枪</label>
    <description>武器档案：NCL Lance NCL电荷标枪
代号：NCL Charge Lance 
所属：诺亚新共产主义联盟「铁律」常规武器序列  

功能概述：  
NCL电荷标枪是专为机动兵蚁设计的特制步枪，具备出色的单发伤害、穿甲性能与射击精度。为强化机动兵蚁的近战适应性，该武器在近距离速射模式与白刃战功能上进行了专项优化，实现中远程火力压制与近身战术打击的无缝衔接。</description>
    <tradeability>None</tradeability>
    <destroyOnDrop>true</destroyOnDrop>
<relicChance>0</relicChance>     
<graphicData>
      <texPath>Weapons/NCLlance</texPath>
      <graphicClass>Graphic_Single</graphicClass>
      <drawSize>1</drawSize>
    </graphicData>
	<uiIconPath>Weapons/NCLlance</uiIconPath>
    <soundInteract>Interact_ChargeLance</soundInteract>
	<equippedAngleOffset>0</equippedAngleOffset>
    <weaponClasses>
      <li>LongShots</li>
      <li>RangedHeavy</li>
    </weaponClasses>
    <statBases>
	  <WorkToMake>20000</WorkToMake>
      <Mass>6.8</Mass>
      <AccuracyTouch>1</AccuracyTouch>
      <AccuracyShort>1</AccuracyShort>
      <AccuracyMedium>0.95</AccuracyMedium>
      <AccuracyLong>0.95</AccuracyLong>
      <RangedWeapon_Cooldown>0.88</RangedWeapon_Cooldown>
    </statBases>
    <smeltable>false</smeltable>
    <verbs>
      <li>
        <verbClass>Verb_Shoot</verbClass>
        <hasStandardCommand>true</hasStandardCommand>
        <defaultProjectile>Bullet_NCLChargeLance</defaultProjectile>
        <warmupTime>1</warmupTime>
        <range>36</range>
        <burstShotCount>2</burstShotCount>
        <ticksBetweenBurstShots>12</ticksBetweenBurstShots>
        <soundCast>ChargeLance_Fire</soundCast>
        <soundCastTail>GunTail_Heavy</soundCastTail>
        <muzzleFlashScale>7</muzzleFlashScale>
      </li>
    </verbs>
    <tools>
      <li>
        <label>stock</label>
        <capacities>
          <li>Blunt</li>
        </capacities>
        <power>20</power>
        <cooldownTime>1</cooldownTime>
      </li>
      <li>
        <label>barrel</label>
        <capacities>
          <li>Blunt</li>
          <li>Poke</li>
        </capacities>
        <power>20</power>
        <cooldownTime>1</cooldownTime>
      </li>
    </tools>
    <weaponTags Inherit="False">
      <li>NCLLance</li>
    </weaponTags>
	<tradeTags>
      <li>NCLThings</li>
    </tradeTags>
  </ThingDef>
  
