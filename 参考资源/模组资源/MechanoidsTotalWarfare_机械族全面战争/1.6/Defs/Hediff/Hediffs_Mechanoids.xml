<?xml version="1.0" encoding="utf-8" ?>
<Defs>

  
  <HediffDef>
    <defName>NCL_Mech_Ironbark_Hediff</defName>
    <label>NCL：铁树</label>
	<defaultLabelColor>(0.8, 0.2, 0.2)</defaultLabelColor>
	<description>铁木妖的蜂窝减震层与高温再生循环会在受到攻击时自动强化受损区域</description>
    <hediffClass>HediffWithComps</hediffClass>
    <comps>
	  <li Class="NCL.HediffCompProperties_MechAutoRecovery">
        <tickMultiflier>180</tickMultiflier>
        <healPoint>5</healPoint>
      </li>
	</comps>
	<stages>
      <li>
		<minSeverity>0.01</minSeverity>
		<statFactors>
			<IncomingDamageFactor>0.80</IncomingDamageFactor><!--受到伤害乘数-->
			<StaggerDurationFactor>0.5</StaggerDurationFactor><!--抑止时间系数-->
        </statFactors>
		<statOffsets>
		  <MeleeHitChance>+10</MeleeHitChance>
		  <MeleeDodgeChance>+10</MeleeDodgeChance>
        </statOffsets>
      </li>
    </stages>
    <modExtensions>
        <li Class="NCL.HediffExtension_NoNotification"/>
    </modExtensions>
  </HediffDef>

    <HediffGiverSetDef>
    <defName>NCL_Mech_Ironbark_Introduction</defName>
    <hediffGivers>
      <li Class="HediffGiver_Random">
        <hediff>NCL_Mech_Ironbark_Hediff</hediff>
        <mtbDays>0.00000001</mtbDays>
      </li>
    </hediffGivers>
  </HediffGiverSetDef>

