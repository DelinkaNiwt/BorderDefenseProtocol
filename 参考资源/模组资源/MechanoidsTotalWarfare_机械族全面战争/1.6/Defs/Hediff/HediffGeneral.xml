  <HediffDef>
    <defName>TW_WasEncouraged</defName>
    <label>被鼓励哩</label>
    <hediffClass>HediffWithComps</hediffClass>
    <description>被鼓励哩</description>
    <defaultLabelColor>(255, 80, 80)</defaultLabelColor>
	<isBad>true</isBad>
	<stages>
	  <li>
	    <statOffsets>
		   <MoveSpeed>+1.5</MoveSpeed>
           <WorkSpeedGlobal>+1.5</WorkSpeedGlobal>
		</statOffsets>
      </li>
	</stages>
	<comps>
      <li Class="HediffCompProperties_Disappears">
        <disappearsAfterTicks>30000</disappearsAfterTicks>
