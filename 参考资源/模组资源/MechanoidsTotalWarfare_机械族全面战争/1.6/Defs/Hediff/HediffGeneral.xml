										<Down>(0.4,0.5)</Down>
										<Right>(-0.55,0.4)</Right>
										<Left>(0.55,0.4)</Left>
									</li>
									<li>
										<defName>Human</defName>
										<BodyType>Fat</BodyType>
										<Default>(0,0)</Default>
										<Up>(-0.35,0.45)</Up>
										<Down>(0.35,0.5)</Down>
										<Right>(-0.5,0.4)</Right>
										<Left>(0.5,0.4)</Left>
									</li>
									<li>
										<defName>Human</defName>
										<BodyType>Male</BodyType>
										<Default>(0,0)</Default>
										<Up>(-0.3,0.45)</Up>
										<Down>(0.3,0.4)</Down>
										<Right>(-0.4,0.4)</Right>
										<Left>(0.4,0.4)</Left>
									</li>
									<li>
										<defName>Human</defName>
										<BodyType>Female</BodyType>
										<Default>(0,0)</Default>
										<Up>(-0.3,0.4)</Up>
										<Down>(0.3,0.4)</Down>
										<Right>(-0.4,0.4)</Right>
										<Left>(0.4,0.4)</Left>
									</li>
									<li>
										<defName>Human</defName>
										<BodyType>Thin</BodyType>
										<Default>(0,0)</Default>
										<Up>(-0.275,0.4)</Up>
										<Down>(0.275,0.4)</Down>
										<Right>(-0.4,0.4)</Right>
										<Left>(0.4,0.4)</Left>
									</li>
								</specificPositions>
							<scalings>
								<li>
									<defName>Human</defName>
									<BodyType>Thin</BodyType>
									<scaling>0.5</scaling>
								</li>
								<li>
									<defName>Human</defName>
									<BodyType>Male</BodyType>
									<scaling>0.5</scaling>
								</li>
								<li>
									<defName>Human</defName>
									<BodyType>Female</BodyType>
									<scaling>0.5</scaling>
								</li>
								<li>
									<defName>Human</defName>
									<BodyType>Fat</BodyType>
									<scaling>0.6</scaling>
								</li>
								<li>
									<defName>Human</defName>
									<BodyType>Hulk</BodyType>
									<scaling>0.6</scaling>
								</li>
							</scalings>
						</li>
						<li Class="MVCF.VerbComps.VerbCompProperties_Cooldown">
							<compClass>MVCF.VerbComps.VerbComp_Cooldown</compClass>
							<cooldownTime>1.5</cooldownTime>
