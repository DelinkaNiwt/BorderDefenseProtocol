<?xml version="1.0" encoding="utf-8" ?>
<Defs>
  
  <HediffDef>
    <defName>CrimsonSlagburstScorched</defName>
    <label>Crimson Slagburst Scorched</label>
    <hediffClass>HediffWithComps</hediffClass>
    <description>赤蚀凝焚伤痕</description>
    <defaultLabelColor>(128, 0, 32)</defaultLabelColor>
	<isBad>true</isBad>
	<stages>
	  <li>
	    <statOffsets>
		  <IncomingDamageFactor>+0.25</IncomingDamageFactor>
		</statOffsets>
	    <capMods>
	      <li>
	        <capacity>Moving</capacity>
            <offset>-0.2</offset>
	      </li>
	    </capMods>
      </li>
	</stages>
	<comps>
      <li Class="HediffCompProperties_Disappears">
        <disappearsAfterTicks>6000~9000</disappearsAfterTicks>
      </li>
    </comps>
  </HediffDef>
  
  <HediffDef>
    <defName>The_coming_death</defName>
    <label>死亡将至</label>
	<defaultLabelColor>(220, 220, 220)</defaultLabelColor>
    <hediffClass>HediffWithComps</hediffClass>
    <description>引爆吧</description>
	<isBad>true</isBad>
	<stages>
	  <li>
	    <statOffsets>
		  <IncomingDamageFactor>+0.25</IncomingDamageFactor>
		</statOffsets>
	    <capMods>
	      <li>
	        <capacity>Moving</capacity>
            <offset>-0.2</offset>
	      </li>
	    </capMods>
      </li>
	</stages>
	<comps>
      <li Class="HediffCompProperties_Disappears">
        <disappearsAfterTicks>120</disappearsAfterTicks>
      </li>
