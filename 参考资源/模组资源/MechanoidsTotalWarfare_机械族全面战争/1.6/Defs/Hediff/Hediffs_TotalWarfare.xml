        </statFactors>
		<statOffsets>
		  <MeleeHitChance>+10</MeleeHitChance>
		  <MeleeDodgeChance>+10</MeleeDodgeChance>
		  <ArmorRating_Sharp>0.15</ArmorRating_Sharp>
      <ArmorRating_Blunt>0.10</ArmorRating_Blunt>
        </statOffsets>
      </li>
    </stages>
  </HediffDef>
  
  
  <HediffDef ParentName="NCL_TotalWarfareHediffBase">
    <defName>TW_Overdrive_M</defName>
    <label>机械超载</label>
	<hediffClass>Hediff_High</hediffClass>
    <description>该机械体因被注入大量能量而在短时间内超载</description>
    <initialSeverity>0.01</initialSeverity>
	<maxSeverity>1</maxSeverity>
	<defaultLabelColor>(0.8, 0.2, 0.2)</defaultLabelColor>
	<comps>
        <li Class="HediffCompProperties_SeverityPerDay">
            <severityPerDay>8</severityPerDay>
        </li>
    </comps>
    <stages>
      <li>
		<minSeverity>0.01</minSeverity>
        <label>超载</label>
		<statFactors>
            <RangedCooldownFactor>0.2</RangedCooldownFactor><!--远程冷却系数-->
			<IncomingDamageFactor>0.4</IncomingDamageFactor><!--受到伤害乘数-->
			<AimingDelayFactor>0.2</AimingDelayFactor>
			<StaggerDurationFactor>0</StaggerDurationFactor>
        </statFactors>
		<statOffsets>
          <MoveSpeed>+4</MoveSpeed><!--移动速度格每秒-->
		  <MeleeHitChance>+10</MeleeHitChance>
		  <MeleeDodgeChance>+10</MeleeDodgeChance>
        </statOffsets>
		<capMods>
            <li>
                <capacity>Consciousness</capacity>
                <offset>+3</offset>
            </li>
        </capMods>
      </li>
      <li>
        <minSeverity>0.20</minSeverity>
        <label>能量过剩</label>
		<statFactors>
            <RangedCooldownFactor>0.4</RangedCooldownFactor><!--远程冷却系数-->
			<IncomingDamageFactor>0.55</IncomingDamageFactor><!--受到伤害乘数-->
			<AimingDelayFactor>0.4</AimingDelayFactor>
			<StaggerDurationFactor>0.4</StaggerDurationFactor>
        </statFactors>
		<statOffsets>
          <MoveSpeed>+2</MoveSpeed><!--移动速度格每秒-->
		  <MeleeHitChance>+10</MeleeHitChance>
		  <MeleeDodgeChance>+10</MeleeDodgeChance>
        </statOffsets>
		<capMods>
            <li>
                <capacity>Consciousness</capacity>
                <offset>+2</offset>
            </li>
        </capMods>
      </li>    
	  <li>
		<minSeverity>0.40</minSeverity>
        <label>逐渐稳定</label>
		<statFactors>
            <RangedCooldownFactor>0.6</RangedCooldownFactor><!--远程冷却系数-->
			<IncomingDamageFactor>0.7</IncomingDamageFactor><!--受到伤害乘数-->
			<AimingDelayFactor>0.6</AimingDelayFactor>
			<StaggerDurationFactor>0.6</StaggerDurationFactor>
        </statFactors>
		<statOffsets>
          <MoveSpeed>+1</MoveSpeed><!--移动速度格每秒-->
		  <MeleeHitChance>+10</MeleeHitChance>
		  <MeleeDodgeChance>+10</MeleeDodgeChance>
        </statOffsets>
		<capMods>
            <li>
                <capacity>Consciousness</capacity>
                <offset>+1</offset>
            </li>
        </capMods>
      </li>
	  <li>
		<minSeverity>0.80</minSeverity>
        <label>稳定</label>
		<statFactors>
			<RangedCooldownFactor>0.8</RangedCooldownFactor><!--远程冷却系数-->
			<IncomingDamageFactor>0.8</IncomingDamageFactor><!--受到伤害乘数-->
			<AimingDelayFactor>0.8</AimingDelayFactor><!--瞄准延迟系数-->	
        </statFactors>
		<statOffsets>
          <MoveSpeed>+0.5</MoveSpeed>
		  <MeleeHitChance>+10</MeleeHitChance>
		  <MeleeDodgeChance>+10</MeleeDodgeChance>
        </statOffsets>
      </li>
    </stages>
  </HediffDef>

</Defs>
