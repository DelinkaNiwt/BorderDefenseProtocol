        <leaveSlag>false</leaveSlag>
        <canRoofPunch>true</canRoofPunch> 
        <triggerRadius>150</triggerRadius> 

      </li>
    </comps>
    <stages>
      <!-- null -->
    </stages>
  </HediffDef>

