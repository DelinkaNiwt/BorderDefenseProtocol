	<comps>
        <li Class="NCL.HediffCompProperties_InvisibilityWithEnemyAwareness">
        <detectionRadius>5</detectionRadius> <!-- 检测半径 -->
        <checkInterval>60</checkInterval>
        <visibleToPlayer>true</visibleToPlayer>
	    </li>
    </comps>
    <stages>
