    <!-- 射击范围增大 -->
    <HediffDef ParentName="NCL_TotalWarfareHediffBase">
    <defName>TW_LongRangeBallisticsOptimizationSystem</defName>
    <label>长距弹道优化模组</label>
    <description>该单位的武器射程获得了20%增长。</description>
	<comps>
        <!-- null -->
    </comps>
    <stages>
      <li>
		<minSeverity>0.01</minSeverity>
		<statFactors>
      <ShootingAccuracyPawn>1.25</ShootingAccuracyPawn>
			<VEF_VerbRangeFactor>1.25</VEF_VerbRangeFactor>
			<RangedCooldownFactor>0.8</RangedCooldownFactor><!--远程冷却系数-->
			<IncomingDamageFactor>0.9</IncomingDamageFactor><!--受到伤害乘数-->
			<AimingDelayFactor>0.8</AimingDelayFactor><!--瞄准延迟系数-->		  
        </statFactors>
		<statOffsets>
		  <ArmorRating_Sharp>0.15</ArmorRating_Sharp>
      <ArmorRating_Blunt>0.10</ArmorRating_Blunt>
    </statOffsets>
      </li>
    </stages>
  </HediffDef>
  
    <HediffDef ParentName="NCL_TotalWarfareHediffBase">
    <defName>TW_HighMobilityPhaseShiftDrive_R</defName>
    <label>超功率推进器</label>
    <description>该单位的移动速度得到了大幅加强</description>
  <comps>
  </comps>
    <stages>
      <li>
		<minSeverity>0.01</minSeverity>
		<statFactors>
			<RangedCooldownFactor>0.8</RangedCooldownFactor><!--远程冷却系数-->
			<IncomingDamageFactor>0.9</IncomingDamageFactor><!--受到伤害乘数-->
			<AimingDelayFactor>0.8</AimingDelayFactor><!--瞄准延迟系数-->	
			<StaggerDurationFactor>0.5</StaggerDurationFactor><!--抑止时间系数-->
        </statFactors>
		<statOffsets>
          <MoveSpeed>+2</MoveSpeed><!--移动速度格每秒-->
		  <ArmorRating_Sharp>0.15</ArmorRating_Sharp>
      <ArmorRating_Blunt>0.10</ArmorRating_Blunt>
        </statOffsets>
      </li>
    </stages>
  </HediffDef>

  
