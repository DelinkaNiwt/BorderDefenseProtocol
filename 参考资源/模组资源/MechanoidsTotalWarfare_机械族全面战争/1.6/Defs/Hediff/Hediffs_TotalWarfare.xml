  <HediffDef ParentName="NCL_TotalWarfareHediffBase">
    <defName>TW_Optical_Camo_Disruption_R</defName>
    <label>光学迷彩干扰装置</label>
    <description>随机单位机械体被赋予光学迷彩模块，使其从战场上隐身。仅当玩家单位处于其附近45格范围内时隐身才会解除。（该隐身对玩家不可见）</description>
	<comps>
        <li Class="NCL.HediffCompProperties_InvisibilityWithEnemyAwareness">
        <detectionRadius>45</detectionRadius> <!-- 检测半径 -->
        <checkInterval>60</checkInterval>
        <visibleToPlayer>false</visibleToPlayer>
	    </li>
    </comps>
    <stages>
      <li>
		<minSeverity>0.01</minSeverity>
		<statFactors>
			<RangedCooldownFactor>0.8</RangedCooldownFactor><!--远程冷却系数-->
			<AimingDelayFactor>0.8</AimingDelayFactor><!--瞄准延迟系数-->	
        </statFactors>
		<statOffsets>
		  <ArmorRating_Sharp>0.15</ArmorRating_Sharp>
      <ArmorRating_Blunt>0.10</ArmorRating_Blunt>
    </statOffsets>
      </li>
    </stages>
  </HediffDef>
  
  <HediffDef ParentName="NCL_TotalWarfareHediffBase">
    <defName>TW_Optical_Camo_Disruption_M</defName>
    <label>光学迷彩干扰装置</label>
