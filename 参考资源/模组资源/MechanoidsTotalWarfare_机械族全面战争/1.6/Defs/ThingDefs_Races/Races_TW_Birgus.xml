<?xml version="1.0" encoding="utf-8" ?>
<Defs>
  
  <ThingDef ParentName="BaseMechanoid">
    <defName>TW_Mech_Birgus</defName>
    <label>椰子械</label>
    <description>机械族巢穴新增近战承伤机械体。血量越低受到的伤害越低，且有着较高的近战伤害与中等偏上的移动速度，被动能力为被攻击时释放烟雾弹效果。

作为潮汐能量机械体，敌方单位的椰子械会主动远离火焰伤害，它的装甲易燃，同时会受到更多的火焰伤害，更致命的受到帝王业火炮伤害会立刻死亡，抛开这些弱点不谈，得益于它强大的抗伤能力及相对低廉的成本，椰子械已成为机械族巢穴的强大守护者。

*作为己方单位时，在征召状态下，椰子蟹无条件服从机械师指令，虽然他的次生核心害怕的直哆嗦。</description>
    <statBases>
      <MarketValue>6400</MarketValue>
      <MoveSpeed>4.8</MoveSpeed>
      <ArmorRating_Blunt>1.45</ArmorRating_Blunt>
      <ArmorRating_Sharp>1.65</ArmorRating_Sharp>
      <ArmorRating_Heat>1.00</ArmorRating_Heat>
      <Flammability>0</Flammability>
      <PsychicSensitivity>0</PsychicSensitivity>
			<StaggerDurationFactor>0</StaggerDurationFactor>
	  <IncomingDamageFactor>1</IncomingDamageFactor>
	  <BandwidthCost MayRequire="Ludeon.Rimworld.Biotech">5</BandwidthCost>
	  <MechEnergyLossPerHP  MayRequire="Ludeon.Rimworld.Biotech">0.2</MechEnergyLossPerHP>
	  <WastepacksPerRecharge MayRequire="Ludeon.Rimworld.Biotech">3</WastepacksPerRecharge>

    </statBases>
	<size>(1,1)</size>
<tools>
      <li>
        <label>left blade</label>
        <labelNoLocation>blade</labelNoLocation>
        <capacities>
          <li>Cut</li>
          <li>Stab</li>
        </capacities>
        <power>50</power>
        <cooldownTime>1</cooldownTime>
        <linkedBodyPartsGroup>LeftBlade</linkedBodyPartsGroup>
        <alwaysTreatAsWeapon>true</alwaysTreatAsWeapon>
      </li>
      <li>
        <label>right blade</label>
        <labelNoLocation>blade</labelNoLocation>
        <capacities>
          <li>Cut</li>
          <li>Stab</li>
        </capacities>
        <power>50</power>
        <cooldownTime>1</cooldownTime>
        <linkedBodyPartsGroup>RightBlade</linkedBodyPartsGroup>
        <alwaysTreatAsWeapon>true</alwaysTreatAsWeapon>
      </li>
      <li>
        <label>head</label>
        <capacities>
          <li>Blunt</li>
        </capacities>
        <power>80</power>
        <cooldownTime>2</cooldownTime>
        <linkedBodyPartsGroup>HeadAttackTool</linkedBodyPartsGroup>
        <ensureLinkedBodyPartsGroupAlwaysUsable>true</ensureLinkedBodyPartsGroupAlwaysUsable>
        <chanceFactor>0.2</chanceFactor>
      </li>
    </tools>
	<damageMultipliers>
	  <li>
        <damageDef>Stun</damageDef>
        <multiplier>0</multiplier>
      </li>
	  <li>
        <damageDef>Vaporize</damageDef>
        <multiplier>5</multiplier>
      </li>
	  <li>
        <damageDef>Flame</damageDef>
        <multiplier>2</multiplier>
      </li>
    </damageMultipliers>
    <race>
      <intelligence>ToolUser</intelligence>
      <thinkTreeMain>Mechanoid</thinkTreeMain>
      <body>Scyther</body>
      <baseBodySize>4.5</baseBodySize>
      <baseHealthScale>8</baseHealthScale>
	  <hediffGiverSets>
	  </hediffGiverSets>
      <soundCallIntervalRange>1000~2000</soundCallIntervalRange>
      <soundMeleeHitPawn>Pawn_Melee_MechanoidBash_HitPawn</soundMeleeHitPawn>
      <soundMeleeHitBuilding>Pawn_Melee_MechanoidBash_HitBuilding</soundMeleeHitBuilding>
      <soundMeleeMiss>Pawn_Melee_MechanoidBash_Miss</soundMeleeMiss>
	  <mechWeightClass>Medium</mechWeightClass>
	  <lifeStageAges Inherit="false">
        <li>
          <def>MechanoidFullyFormed</def>
          <minAge>0</minAge>
          <soundWounded>Pawn_Mech_Centipede_Wounded</soundWounded>
          <soundDeath>Pawn_Mech_Centipede_Death</soundDeath>
          <soundCall>Pawn_Mech_Centipede_Call</soundCall>
        </li>
        <li MayRequire="Ludeon.RimWorld.Biotech">
          <def>MechanoidFullyFormed</def>
          <minAge>100</minAge>
          <soundWounded>Pawn_Mech_Centipede_Wounded</soundWounded>
          <soundDeath>Pawn_Mech_Centipede_Death</soundDeath>
          <soundCall>Pawn_Mech_Centipede_Call</soundCall>
        </li>
      </lifeStageAges>
    </race>
	<comps>  
	 <li Class="CompProperties_Forbiddable"/>
    <li Class="NCL.CompProperties_DamageReduction">
      <minHealthPercent>0.5</minHealthPercent>
      <minDamageFactor>0.5</minDamageFactor>
    </li>
    <li Class="NCL.CompProperties_SmokepopOnHit">
      <cooldownSeconds>3</cooldownSeconds>
      <smokeRadius>3.5</smokeRadius>
      <smokeDurationTicks>900</smokeDurationTicks> <!-- 15秒 -->
      <soundOnActivate>Explosion_Bomb</soundOnActivate>
    </li>
    <li Class="NCL.CompProperties_FearFire">
    </li>
	</comps>
    <butcherProducts>
      <Steel>600</Steel>
      <Plasteel>180</Plasteel>
    </butcherProducts>
  </ThingDef>

