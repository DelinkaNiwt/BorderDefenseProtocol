      <BandwidthCost MayRequire="Ludeon.RimWorld.Biotech">50</BandwidthCost>
      <MechEnergyLossPerHP  MayRequire="Ludeon.RimWorld.Biotech">0.2</MechEnergyLossPerHP>
      </statBases>
	  <comps>
  <li Class="CompProperties_AutoMechSpawner"/>
