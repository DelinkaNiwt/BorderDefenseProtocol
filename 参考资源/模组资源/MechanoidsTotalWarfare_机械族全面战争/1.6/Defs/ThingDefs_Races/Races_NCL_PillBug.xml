<?xml version="1.0" encoding="utf-8" ?>
<Defs>

  <LifeStageDef>
    <defName>NCL_Mech_PillBugFullyformed</defName>
    <label>fully-formed</label>
    <caravanRideable>true</caravanRideable>
    <visible>false</visible>
  </LifeStageDef>
  
  <ThingDef Name="NCLMechPillBug" ParentName="SuperHeavyMechanoid">
    <defName>NCL_Mech_PillBug</defName>
    <label>闪光西瓜虫</label>
    <description>单位档案：NCL-04“闪光西瓜虫”
来源：NCL「铁律」重装防御序列

这是一种被改装用于地面重火力压制的特殊战斗单位，最初作为实验性光学兵器平台诞生于NCL的末期。机体表层遍布密集的光子晶体结构，在强光环境下常被误认为是能量残影，因此得名“闪光西瓜虫”。

它行动迟缓，但极其耐打，具备高于常规机械单位的生存能力。前端搭载的“裂解者”阳电子炮可在远距离内融穿大部分掩体与装甲目标，双侧同步运行的棱镜激光系统则能精确击毁中低速飞行物，尤其擅长拦截来自低轨道的投射物。

特殊能力：
◈「跳起来滚」- 通过短距能量喷射瞬间跃向目标区域，对落点附近的敌对单位造成冲击伤害与强力击退效果</description>
    <statBases>
      <MarketValue>3200</MarketValue>
      <MoveSpeed>1.8</MoveSpeed>
      <ArmorRating_Blunt>1</ArmorRating_Blunt>
	  <EMPResistance>0.40</EMPResistance>
      <ArmorRating_Sharp>1</ArmorRating_Sharp>
	  <ShootingAccuracyPawn>1</ShootingAccuracyPawn>
      <PsychicSensitivity>0</PsychicSensitivity>
      <BandwidthCost MayRequire="Ludeon.RimWorld.Biotech">8</BandwidthCost>
      <MechEnergyLossPerHP  MayRequire="Ludeon.RimWorld.Biotech">0.2</MechEnergyLossPerHP>
    </statBases>
	<tools>
      <li>
        <label>MechanicalHead</label>
        <capacities>
          <li>Blunt</li>
        </capacities>
        <power>50</power>
        <cooldownTime>1</cooldownTime>
        <linkedBodyPartsGroup>HeadAttackTool</linkedBodyPartsGroup>
        <ensureLinkedBodyPartsGroupAlwaysUsable>true</ensureLinkedBodyPartsGroupAlwaysUsable>
        <chanceFactor>0.2</chanceFactor>
      </li>
    </tools>
	<comps>  
	 <li Class="CompProperties_Forbiddable"/>
     <li Class="TowerLaserDefense.CompProperties_LaserDefence">
                <laserDefenceProperties>
          <range>25</range>
          <interceptCount>2</interceptCount>
          <interceptTime>16</interceptTime>
					<laserOffsetX>0</laserOffsetX>
					<laserOffsetY>-0.3</laserOffsetY>
					<ignoreAirProjectiles>true</ignoreAirProjectiles>
					<connectinglaserWidth>0.7</connectinglaserWidth>
					<connectingLineFleck>NCL_Ground_LaserDefenseLine</connectingLineFleck>
					<laserLineTexture>Motes/LaserLine</laserLineTexture>
					<impactScale>0.5</impactScale>
          <secondaryImpactScale>0.3</secondaryImpactScale>
          <tertiaryImpactScale>0.3</tertiaryImpactScale>
	<randomImpactFlecks>
        <li>NCL_LaserDefenseImpact_One</li>
        <li>NCL_LaserDefenseImpact_Two</li>
        <li>NCL_LaserDefenseImpact_Three</li>
        <li>NCL_LaserDefenseImpact_Four</li>
    </randomImpactFlecks>
                    <graphicData>
                        <texPath>Things/None</texPath>
                        <graphicClass>Graphic_Single</graphicClass>
                        <drawSize>(1,1)</drawSize>
                        <shaderType>Transparent</shaderType>
                        <ignoreThingDrawColor>true</ignoreThingDrawColor>
                    </graphicData>
                    <needSight>true</needSight>
                </laserDefenceProperties>
            </li>
	</comps>
	<butcherProducts>
      <Steel>600</Steel>
      <Plasteel>180</Plasteel>
    </butcherProducts>
    <race>
      <lifeStageAges>
        <li>
          <def>NCL_Mech_PillBugFullyformed</def>
          <minAge>0</minAge>
          <soundWounded>Pawn_Mech_Diabolus_Wounded</soundWounded>
            <soundDeath>Pawn_Mech_Diabolus_Death</soundDeath>
            <soundCall>Pawn_Mech_Diabolus_Call</soundCall>
        </li>
      </lifeStageAges>
      <body>MechanicalCentipede</body>
	  <baseBodySize>4.0</baseBodySize>
      <baseHealthScale>6</baseHealthScale>
      <detritusLeavings>
        <li>
          <def>ChunkMechanoidSlag</def>
