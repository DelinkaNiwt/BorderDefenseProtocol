<?xml version="1.0" encoding="utf-8" ?>
<Defs>
  
  <ThingDef Name="TWMechShellFortification" ParentName="SuperHeavyMechanoid">
      <defName>TW_Mech_Shell_Fortification</defName>
      <label>壳堡构体</label>
      <description>『壳堡构体』是机械族中极为罕见的泰坦级单位，其体高二十米，身披多层金属混铸而成的庞大外壳，其设计理念结合了攻坚、压制与区域控制的多重战略目标，尤其擅长在敌方防线中撕裂缺口，并以绝对火力清扫战场残余。『壳堡构体』通常自天际坠落，重重地落在殖民地边缘，以“炮塔形态”进入待命状态，发射导弹引发局部地震和恐慌。与此同时，配属的机械族主力部队将从另一侧空投登陆，与其构成前后夹击态势，极大增强攻势张力。</description>
      <race>
        <body>Doxa0Body</body>
        <baseBodySize>4</baseBodySize>
		<baseHealthScale>18</baseHealthScale>
        <lifeStageAges>
          <li>
            <def>MechanoidFullyFormed</def>
            <minAge>0</minAge>
            <soundWounded>Pawn_Mech_Diabolus_Wounded</soundWounded>
            <soundDeath>Pawn_Mech_Diabolus_Death</soundDeath>
            <soundCall>Pawn_Mech_Diabolus_Call</soundCall>
          </li>
          <li>
            <def>MechanoidFullyFormed</def>
            <minAge>100</minAge>
            <soundWounded>Pawn_Mech_Diabolus_Wounded</soundWounded>
            <soundDeath>Pawn_Mech_Diabolus_Death</soundDeath>
            <soundCall>Pawn_Mech_Diabolus_Call</soundCall>
          </li>
        </lifeStageAges>
        <detritusLeavings>
          <li>
            <def>ChunkMechanoidSlag</def>
            <texOverrideIndex>3</texOverrideIndex>
            <spawnChance>0.75</spawnChance>
          </li>
          <li>
            <def>ChunkMechanoidSlag</def>
            <texOverrideIndex>17</texOverrideIndex>
            <spawnChance>0.75</spawnChance>
          </li>
          <li>
            <def>ChunkMechanoidSlag</def>
            <texOverrideIndex>1</texOverrideIndex>
            <spawnChance>0.75</spawnChance>
          </li>
        </detritusLeavings>
	<hediffGiverSets>
    </hediffGiverSets>
	<thinkTreeMain>Shell_FortificationThinkTreeMain</thinkTreeMain>
    <thinkTreeConstant>Shell_FortificationThinkTreeConstant</thinkTreeConstant>
      </race>
      <killedLeavingsPlayerHostile>
        <TW_ArmorBlitzWarfare>1</TW_ArmorBlitzWarfare>
      </killedLeavingsPlayerHostile>
      <tools>
        <li>
          <label>head</label>
          <capacities>
            <li>Blunt</li>
          </capacities>
          <power>88</power>
          <cooldownTime>2.6</cooldownTime>
          <linkedBodyPartsGroup>HeadAttackTool</linkedBodyPartsGroup>
          <ensureLinkedBodyPartsGroupAlwaysUsable>true</ensureLinkedBodyPartsGroupAlwaysUsable>
        </li>
      </tools>
      <statBases>
      <MarketValue>100000</MarketValue>
      <MoveSpeed>1.88</MoveSpeed>
      <ArmorRating_Blunt>2</ArmorRating_Blunt>
      <ArmorRating_Sharp>2</ArmorRating_Sharp>
	  <ArmorRating_Heat>2</ArmorRating_Heat>
	    <EMPResistance>0.75</EMPResistance>
		<StaggerDurationFactor>0</StaggerDurationFactor>
      <PsychicSensitivity>0</PsychicSensitivity>
      <BandwidthCost MayRequire="Ludeon.RimWorld.Biotech">999</BandwidthCost>
      <MechEnergyLossPerHP  MayRequire="Ludeon.RimWorld.Biotech">0.2</MechEnergyLossPerHP>
      </statBases>
<damageMultipliers Inherit="False">
      <li>
        <damageDef>TW_Crimson_Slagburst</damageDef>
        <multiplier>0</multiplier>
      </li>
      <li>
        <damageDef>Bomb</damageDef>
        <multiplier>0.5</multiplier>
      </li>
      <li>
        <damageDef>Bullet</damageDef>
        <multiplier>0.5</multiplier>
      </li>
      <li>
        <damageDef>Stun</damageDef>
        <multiplier>0</multiplier>
      </li>
    </damageMultipliers>
	  <comps>
    <li Class="NCL.CompProperties_ClearOwnerProjectiles">
    </li>
	  <li Class="CompProperties_Forbiddable"/>
      <li Class="TowerLaserDefense.CompProperties_LaserDefence">
                <laserDefenceProperties>
                    <range>54</range>
                    <interceptCount>8</interceptCount>
                    <interceptTime>51</interceptTime>
