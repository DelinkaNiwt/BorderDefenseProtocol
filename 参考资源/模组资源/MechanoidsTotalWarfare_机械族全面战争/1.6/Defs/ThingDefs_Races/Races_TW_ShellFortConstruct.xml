                    <graphicData>
                        <texPath>Things/None</texPath>
                        <graphicClass>Graphic_Single</graphicClass>
                        <drawSize>(1,1)</drawSize>
                        <shaderType>Transparent</shaderType>
                        <ignoreThingDrawColor>true</ignoreThingDrawColor>
                    </graphicData>
                    <needSight>true</needSight>
                </laserDefenceProperties>
            </li>
		<li Class="CompProperties_ProjectileInterceptor">
        <radius>20</radius>
        <color>(0.4, 0.4, 0.4, 0.4)</color>
		<reactivateEffect>BulletShieldGenerator_Reactivate</reactivateEffect>
		<activeSound>BulletShield_Ambience</activeSound>
		<hitPoints>10000</hitPoints>
		<interceptGroundProjectiles>true</interceptGroundProjectiles>
		<interceptAirProjectiles>true</interceptAirProjectiles>
		<hitPointsRestoreInstantlyAfterCharge>true</hitPointsRestoreInstantlyAfterCharge>
		<chargeDurationTicks>1800</chargeDurationTicks>
		<rechargeHitPointsIntervalTicks>5</rechargeHitPointsIntervalTicks>
		<minIdleAlpha>0.2</minIdleAlpha>
		<drawWithNoSelection>True</drawWithNoSelection>
		<disarmedByEmpForTicks>1800</disarmedByEmpForTicks>
		<gizmoTipKey>ProjectileInterceptorTip</gizmoTipKey>
      </li>
	<li Class="NCL.CompProperties_TurretGun_GroundTarget">
        <turretDef>TW_Mech_Shell_Fortification_AutomaticMissileLauncher</turretDef>
    </li>
	<li Class="NCL.CompProperties_OnDeathEvent">
      <incidentToTrigger>PawnSpawnerEvent</incidentToTrigger>
      <spawnThingOnDeath>false</spawnThingOnDeath>
    </li>
	<li Class="NCL.CompProperties_FearAura">
      </li>
    <li Class="NCL.CompProperties_MechanoidShield">
    </li>
    <li Class="NCL.CompProperties_DamageLimit">
      <maxDamage>200</maxDamage>
      <excludedDamageTypes>
        <li>Vaporize</li>
      </excludedDamageTypes>
    </li>
      <li Class="NCLWorm.CompProperties_DamageAbsorbedAndBoom">
        <AbsorbedTime>1</AbsorbedTime>
        <BoomTime>60</BoomTime>
        <radius>9</radius>
        <damageDef>NCL_ModBomb</damageDef>
        <amount>50</amount>
        <armorPenetration>1</armorPenetration>
      </li>
    <li Class="NCL.CompProperties_MechAutoRecovery">
        <tickInterval>180</tickInterval>
        <healAmount>10</healAmount> <!-- 每次治疗量 -->
    </li>
      <li Class="NCLWorm.CompProperties_BattleCrush">
          <battleEffect>NCL_ShellFortFightingeffects</battleEffect>
          <damageInterval>60</damageInterval>
          <damageFactor>0.1</damageFactor>
          </li>
      </comps>
	<butcherProducts>
