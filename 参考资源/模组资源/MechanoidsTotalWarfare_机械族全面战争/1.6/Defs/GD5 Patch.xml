<?xml version="1.0" encoding="utf-8" ?>
<Defs>

  <HediffGiverSetDef MayRequire="fxz.glitterworlddestroyer.mk5">
    <defName>Introduction_WarScorpion</defName>
    <hediffGivers>
      <li Class="HediffGiver_Random">
        <hediff>Introduction_WarScorpion</hediff>
        <mtbDays>0.00000001</mtbDays>
      </li>
    </hediffGivers>
  </HediffGiverSetDef>
  
  <HediffGiverSetDef MayRequire="fxz.glitterworlddestroyer.mk5">
    <defName>Introduction_PillBug</defName>
    <hediffGivers>
      <li Class="HediffGiver_Random">
        <hediff>Introduction_PillBug</hediff>
