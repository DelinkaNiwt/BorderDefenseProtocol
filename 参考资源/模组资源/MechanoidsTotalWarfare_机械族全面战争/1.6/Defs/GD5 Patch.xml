		<minSeverity>0.01</minSeverity>
		<statFactors>
			<IncomingDamageFactor>0.80</IncomingDamageFactor><!--受到伤害乘数-->
			<StaggerDurationFactor>0.5</StaggerDurationFactor><!--抑止时间系数-->
        </statFactors>
		<statOffsets>
	    	<ArmorRating_Sharp>0.45</ArmorRating_Sharp>
     	    <ArmorRating_Blunt>0.45</ArmorRating_Blunt>
        </statOffsets>
      </li>
    </stages>
    <modExtensions>
		  <li Class="GD3.ModExtension_NotSendLetter" />
	  </modExtensions>
  </HediffDef>
  
