<?xml version="1.0" encoding="utf-8"?>
<Defs>
	
  <AbilityDef>
    <defName>TW_TeleportToRandomAlly</defName>
    <label>敌方折跃</label>
    <description>将敌人拉至附近的友军身边</description>
    <aiCanUse>True</aiCanUse>
    <iconPath>UI/Abilities/Skip</iconPath>
    <cooldownTicksRange>6000</cooldownTicksRange>
    <verbProperties>
      <verbClass>Verb_CastAbility</verbClass>
      <requireLineOfSight>True</requireLineOfSight>
      <warmupTime>5</warmupTime>
      <range>55</range>
      <targetParams>
        <canTargetBuildings>False</canTargetBuildings>
        <canTargetAnimals>True</canTargetAnimals>
      </targetParams>
    <aimingTargetMote>NCL_Mote_SkipLocked</aimingTargetMote>
    </verbProperties>
    <comps>
      <li Class ="CompProperties_AbilityEffect">
        <compClass>NCLWorm.Comp_TeleportToRandomAlly</compClass>
      </li>
      <li Class ="CompProperties_AbilityEffectWithDuration">
        <compClass>CompAbilityEffect_Stun</compClass>
        <durationSecondsOverride>5~10</durationSecondsOverride>
      </li>
    </comps>
  </AbilityDef>

 

    <AbilityDef>
    <defName>NCL_TeleportSkip</defName>
    <label>精神折跃</label>
    <description>灵能小镰使用念力瞬间将一个目标折跃到指定地点</description>
    <aiCanUse>false</aiCanUse>
    <iconPath>UI/Abilities/Skip</iconPath>
    <cooldownTicksRange>600</cooldownTicksRange>
    <verbProperties>
      <verbClass>Verb_CastAbility</verbClass>
      <requireLineOfSight>false</requireLineOfSight>
      <warmupTime>0</warmupTime>
      <range>55</range>
      <targetParams>
        <canTargetBuildings>False</canTargetBuildings>
        <canTargetLocations>False</canTargetLocations>
        <canTargetSelf>True</canTargetSelf>
        <canTargetAnimals>True</canTargetAnimals>
      </targetParams>
    <aimingTargetMote>NCL_Mote_SkipLocked</aimingTargetMote>
    </verbProperties>
    <comps>
      <li Class = "CompProperties_AbilityTeleport">
        <maxBodySize>20</maxBodySize>
        <compClass>CompAbilityEffect_Teleport</compClass>
        <destination>Selected</destination>
        <requiresLineOfSight>True</requiresLineOfSight>
        <range>55</range>
        <clamorType>Ability</clamorType>
        <clamorRadius>10</clamorRadius>
        <destClamorType>Ability</destClamorType>
        <destClamorRadius>10</destClamorRadius>
        <stunTicks>18~60</stunTicks>
        <goodwillImpact>18</goodwillImpact>
        <applyGoodwillImpactToLodgers>False</applyGoodwillImpactToLodgers>
      </li>
    </comps>
  </AbilityDef>

    <AbilityDef>
    <defName>NCL_MechSelfRepair_PsycastsMilitor</defName>
    <label>范围修复</label>
    <description>灵能小镰通过念力修复25格范围内所有机械体友军身上的部分伤口</description>
    <aiCanUse>false</aiCanUse>
    <iconPath>ModIcon/FixingTheBuilding</iconPath>
    <cooldownTicksRange>900</cooldownTicksRange>
  	<stunTargetWhileCasting>false</stunTargetWhileCasting>
    <targetRequired>false</targetRequired>
    <displayGizmoWhileUndrafted>true</displayGizmoWhileUndrafted>
    <disableGizmoWhileUndrafted>false</disableGizmoWhileUndrafted>
    <showCastingProgressBar>true</showCastingProgressBar>
    <verbProperties>
      <verbClass>Verb_CastAbility</verbClass>
      <warmupTime>3</warmupTime>
      <requireLineOfSight>false</requireLineOfSight>
      <range>25</range>
      <drawAimPie>false</drawAimPie>      
      <targetParams>
        <canTargetSelf>true</canTargetSelf>
      </targetParams>
    </verbProperties>
    <comps>
	  <li Class="CompProperties_AbilityEffecterOnTarget">
        <effecterDef>BurnoutMechlinkBoosterUsed</effecterDef>
      </li>
      <li Class="NCL.CompProperties_GroupRepairAbility"/>
    </comps>
  </AbilityDef>

    <AbilityDef>
    <defName>NCL_SkipShieldGeneration_PsycastsMilitor</defName>
    <label>支援前线盾包</label>
    <description>灵能小镰使用念力，从最近的商船的货架上偷走了三个盾包，并安装在了距离敌人最近的三个友军身上。</description>
    <aiCanUse>false</aiCanUse>
    <iconPath>Things/Building/Security/BroadshieldProjector</iconPath>
    <cooldownTicksRange>4200</cooldownTicksRange>
	<stunTargetWhileCasting>True</stunTargetWhileCasting>
    <targetRequired>false</targetRequired>
    <displayGizmoWhileUndrafted>true</displayGizmoWhileUndrafted>
    <disableGizmoWhileUndrafted>false</disableGizmoWhileUndrafted>
    <showCastingProgressBar>true</showCastingProgressBar>
    <verbProperties>
      <verbClass>Verb_CastAbility</verbClass>
      <warmupTime>3</warmupTime>
      <requireLineOfSight>false</requireLineOfSight>
      <range>-1</range>
      <drawAimPie>false</drawAimPie>      
      <targetParams>
        <canTargetSelf>true</canTargetSelf>
      </targetParams>
    </verbProperties>
    <comps>
	  <li Class="CompProperties_AbilityEffecterOnTarget">
        <effecterDef>MechbandDishUsed</effecterDef>
      </li>
            <li Class="NCL.CompProperties_ApplyHediffToFrontline">
                <hediffToApply>TW_ShieldGeneration</hediffToApply>
                <numberOfTargets>3</numberOfTargets>
                <affectEnemies>false</affectEnemies>
                <includeDowned>false</includeDowned>
            </li>
    </comps>
  </AbilityDef>

