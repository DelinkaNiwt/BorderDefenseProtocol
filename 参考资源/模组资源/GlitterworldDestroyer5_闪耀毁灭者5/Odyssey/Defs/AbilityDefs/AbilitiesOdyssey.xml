<?xml version="1.0" encoding="utf-8" ?>
<Defs>
  
  <!-- 跳跃 -->
  <AbilityDef>
    <defName>Annihilator_JumpAbility</defName>
    <label>jump</label>
	<description>Leap high and land at the target location, dealing terrifying crushing damage to the enemies within the landing spot.</description>
	<jobDef>CastAbilityOnThingWithoutWeapon</jobDef>
    <iconPath>UI/Buttons/Annihilator_Jump</iconPath>
    <cooldownTicksRange>600</cooldownTicksRange>
	<aiCanUse>true</aiCanUse>
    <casterMustBeCapableOfViolence>false</casterMustBeCapableOfViolence>
	<disableGizmoWhileUndrafted>false</disableGizmoWhileUndrafted>
	<showWhenDrafted>true</showWhenDrafted>
    <verbProperties>
      <verbClass>Verb_CastAbility</verbClass>
      <warmupTime>-1</warmupTime>
      <requireLineOfSight>false</requireLineOfSight>
      <range>500</range>
      <drawAimPie>false</drawAimPie>
      <targetParams>
        <canTargetLocations>true</canTargetLocations>
        <canTargetPawns>false</canTargetPawns>
        <canTargetBuildings>false</canTargetBuildings>
      </targetParams>
    </verbProperties>
    <comps>
      <li Class="CompProperties_AbilityEffect">
		<compClass>GD3.CompAbilityEffect_AnnihilatorJump</compClass>
	  </li>
    </comps>
  </AbilityDef>
  
  <!-- 悬浮 -->
  <AbilityDef>
    <defName>Annihilator_Suspend</defName>
    <label>plasma sweep</label>
