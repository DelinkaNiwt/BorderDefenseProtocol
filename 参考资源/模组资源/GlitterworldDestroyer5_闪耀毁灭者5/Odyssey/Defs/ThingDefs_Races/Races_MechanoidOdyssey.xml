		  <drawSize>10</drawSize>
		</bodyGraphicData>
		<flyingAnimationEast>Annihilator_Suspending</flyingAnimationEast>
		<flyingAnimationNorth>Annihilator_Suspending</flyingAnimationNorth>
		<flyingAnimationSouth>Annihilator_Suspending</flyingAnimationSouth>
  	  </li>
    </lifeStages>
	<controlGroupPortraitZoom>0.2</controlGroupPortraitZoom>
    <weaponTags>
    </weaponTags>
    <abilities>
  	  <li>Annihilator_JumpAbility</li>
	  <li>Annihilator_Suspend</li>
	  <li>Annihilator_JumpAndSuspend</li>
	  <li>Annihilator_LongJump</li>
    </abilities>
  </PawnKindDef>
  
  <!-- 诶你怎么死了 -->
  <ThingDef ParentName="NonDeconstructibleAncientBuildingBase">
    <defName>AnnihilatorCorpse_Ancient</defName>
    <label>annihilator ruin</label>
    <description>The destroyed annihilator. One can study the wreckage and attempt to crack its manufacturing technology, or destroy and recycle the resources.</description>
    <rotatable>false</rotatable>
    <graphicData>
      <texPath>Annihilator/AnnihilatorCorpse_Ancient</texPath>
      <graphicClass>Graphic_Single</graphicClass>
      <drawSize>10</drawSize>
      <drawOffset>(0,0,0.5)</drawOffset>
      <shadowData>
        <volume>(6.8, 1, 3.1)</volume>
		<offset>(0, 0, -1.55)</offset>
      </shadowData>
    </graphicData>
    <size>(7,7)</size>
    <fillPercent>0.8</fillPercent>
    <passability>PassThroughOnly</passability>
    <pathCost>70</pathCost>
    <statBases>
      <MaxHitPoints>2500</MaxHitPoints>
	  <Mass>1250</Mass>
    </statBases>
    <killedLeavings>
      <Steel>500</Steel>
	  <Plasteel>400</Plasteel>
	  <ComponentIndustrial>20</ComponentIndustrial>
	  <ComponentSpacer>10</ComponentSpacer>
	  <PrecisionDeck>300</PrecisionDeck>
	  <GravlitePanel>200</GravlitePanel>
	  <Gravcore>1</Gravcore>
    </killedLeavings>
	<minifiedDef>MinifiedThing</minifiedDef>		
	<thingCategories>
	  <li>BuildingsSpecial</li>
	</thingCategories>
	<comps>
      <li>
        <compClass>GD3.CompAnnihilatorRuin</compClass>
      </li>
      <li Class="CompProperties_Hackable">
        <defence>12000</defence>
        <effectHacking>HackingTerminal</effectHacking>
        <showProgressAfterHackCompletion>false</showProgressAfterHackCompletion>
        <intellectualSkillPrerequisite>16</intellectualSkillPrerequisite>
        <notHackedInspectString>Decode for technology.</notHackedInspectString>
        <hackedMessage>{HACKER_labelShort} has finished decoding {SUBJECT_labelNoParenthesisDef}.</hackedMessage>
      </li>
    </comps>
  </ThingDef>
  
