	  <angleCurve>
	    <points>
          <li>(0,     0)</li>
          <li>(1,     0)</li>
        </points>
	  </angleCurve>
      <speed>1.05</speed>
      <shadowSize>16</shadowSize>
	  <hitRoof>false</hitRoof>
	  <ticksToImpactRange><min>240</min><max>240</max></ticksToImpactRange>
    </skyfaller>
  </ThingDef>
  
  <ThingDef ParentName="SkyfallerBase">
    <defName>GD_Skyfaller_SuspendReady</defName>
    <label>flying creature</label>
    <thingClass>GD3.Skyfaller_SuspendReady</thingClass>
