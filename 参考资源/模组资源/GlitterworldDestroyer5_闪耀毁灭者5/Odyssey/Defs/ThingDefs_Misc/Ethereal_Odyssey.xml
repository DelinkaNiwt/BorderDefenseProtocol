<?xml version="1.0" encoding="utf-8" ?>
<Defs>

  <ThingDef ParentName="SkyfallerBase">
    <defName>GD_Skyfaller_JumpingMech</defName>
    <label>flying creature</label>
    <thingClass>GD3.Skyfaller_JumpingMech</thingClass>
    <skyfaller>
	  <angleCurve>
	    <points>
          <li>(0,     0)</li>
          <li>(1,     0)</li>
        </points>
	  </angleCurve>
	  <reversed>true</reversed>
      <speed>1.05</speed>
      <shadowSize>16</shadowSize>
	  <hitRoof>false</hitRoof>
	  <anticipationSound>DropPod_Leaving</anticipationSound>
      <anticipationSoundTicks>10</anticipationSoundTicks>
      <ticksToImpactRange><min>0</min><max>0</max></ticksToImpactRange>
    </skyfaller>
  </ThingDef>

  <ThingDef ParentName="SkyfallerBase">
