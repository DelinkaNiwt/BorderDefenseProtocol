				<li Class="SafePatcher.PatchOperationSetModExtension">
					<xpath>Defs/ThingDef[defName="Gun_HighChargeLance"]</xpath>
					<value>
						<li Class="MuzzleFlash.MuzzleFlashProps">
							<def>MF_ChargedMuzzleFalsh</def>
							<drawSize>(2,1)</drawSize>
							<offsets>
								<li>(0.38,0)</li>
							</offsets>
						</li>
					</value>
				</li>

				<li Class="SafePatcher.PatchOperationSetModExtension">
					<xpath>Defs/ThingDef[defName="CataphractCentipede_SR"]</xpath>
