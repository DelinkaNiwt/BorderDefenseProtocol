	<!-- 心灵广播 -->
	<ThingDef Name="PsychicRadioBase" Abstract="True" ParentName="BuildingBase">
    <altitudeLayer>Building</altitudeLayer>
    <pathCost>50</pathCost>
    <blockWind>true</blockWind>
    <passability>Impassable</passability>
    <canOverlapZones>false</canOverlapZones>
    <fillPercent>1.0</fillPercent>
    <statBases>
      <MaxHitPoints>1500</MaxHitPoints>
      <Flammability>0</Flammability>
	  <WorkToBuild>300000</WorkToBuild>
	  <Beauty>1000</Beauty>
    </statBases>
    <damageMultipliers>
      <li>
        <damageDef>Flame</damageDef>
        <multiplier>0</multiplier>
      </li>
    </damageMultipliers>
    <building>
      <combatPower>750</combatPower>
      <claimable>false</claimable>
      <destroySound>BuildingDestroyed_Metal_Big</destroySound>
    </building>
    <comps>
      <li Class="CompProperties_WakeUpDormant" />
      <li Class="CompProperties_Initiatable" />
    </comps>
    <receivesSignals>true</receivesSignals>
    <tickerType>Normal</tickerType>
    <rotatable>false</rotatable>
    <selectable>true</selectable>
    <terrainAffordanceNeeded>Heavy</terrainAffordanceNeeded>
    <soundImpactDefault>BulletImpact_Metal</soundImpactDefault>
    <drawerType>MapMeshOnly</drawerType>
    <castEdgeShadows>True</castEdgeShadows>
    <repairEffect>ConstructMetal</repairEffect>
    <forceDebugSpawnable>true</forceDebugSpawnable>
    <killedLeavings>
      <Steel>60</Steel>
      <ComponentIndustrial>1</ComponentIndustrial>
      <Plasteel>10</Plasteel>
      <ChunkSlagSteel>4</ChunkSlagSteel>
    </killedLeavings>
  </ThingDef>
  
  <ThingDef ParentName="PsychicRadioBase">
    <defName>PsychicRadio</defName>
    <label>psychic radio</label>
    <description>This is an archotech facility built by your colonists to be able to influence the psychic sensitivity of organic life with its ability to edit psychic signals. \n\nHowever, this does not mean that the Archotech is fully understood by the colonists - copying homework to the blueprints within the persona data does not enable one to learn anything.</description>
    <size>(5,5)</size>
	<costList>
	  <Steel>250</Steel>
	  <Plasteel>250</Plasteel>
	  <ComponentIndustrial>10</ComponentIndustrial>
      <ComponentSpacer>5</ComponentSpacer>
	  <AIPersonaCore>1</AIPersonaCore>
	</costList>
	<constructionSkillPrerequisite>10</constructionSkillPrerequisite>
	<researchPrerequisites>
      <li>UltraMechtech</li>
	  <li>GD3_GiantCluster_Medium</li>
    </researchPrerequisites>
    <graphicData>
      <texPath>Buildings/PsychicRadio</texPath>
      <graphicClass>Graphic_Single</graphicClass>
      <drawSize>(7.9,7.9)</drawSize>
      <drawOffset>(0,0,0.16)</drawOffset>
      <shadowData>
        <volume>(4.9,3.5,4.9)</volume>
        <offset>(0,0,0)</offset>
      </shadowData>
      <damageData>
        <rect>(0.9, 0.9, 4.1, 4.1)</rect>
      </damageData>
    </graphicData>
	<designationCategory>Misc</designationCategory>
    <comps>
      <li Class="CompProperties_Power">
        <compClass>CompPowerTrader</compClass>
      </li>
	  <li Class="GD3.CompProperties_Radio">
	    <powerCostFst>500</powerCostFst>
		<powerCostSec>5000</powerCostSec>
		<powerCostThd>20000</powerCostThd>
	  </li>
    </comps>
  </ThingDef>

