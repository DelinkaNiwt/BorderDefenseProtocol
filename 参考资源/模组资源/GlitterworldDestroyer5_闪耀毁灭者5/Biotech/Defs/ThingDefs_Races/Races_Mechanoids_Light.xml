<?xml version="1.0" encoding="utf-8" ?>
<Defs>
    
    <!-- 观察机 -->  
    <ThingDef ParentName="LightMechanoid">
      <defName>Mech_Observer</defName>
      <label>observer</label>
      <description>A mechanoid designed for long-range reconnaissance can be designated to assist a colonist or another mechanoid with aiming, increasing its range by 25%.\n\nWhen in working mode, the observer will actively follow the bound target. The range increase effect only takes effect when it is close enough to the target.</description>
      <statBases>
        <MoveSpeed>4.8</MoveSpeed>
      </statBases>
      <race>
	    <mechEnabledWorkTypes Inherit="false">
          <!-- null -->
        </mechEnabledWorkTypes>
        <lifeStageAges>
          <li>
            <def>MechanoidFullyFormed</def>
            <minAge>0</minAge>
            <soundWounded>Pawn_Mech_Lifter_Wounded</soundWounded>
            <soundDeath>Pawn_Mech_Lifter_Death</soundDeath>
            <soundCall>Pawn_Mech_Lifter_Call</soundCall>
          </li>
          <li>
            <def>MechanoidFullyFormed</def>
            <minAge>100</minAge>
            <soundWounded>Pawn_Mech_Lifter_Wounded</soundWounded>
            <soundDeath>Pawn_Mech_Lifter_Death</soundDeath>
            <soundCall>Pawn_Mech_Lifter_Call</soundCall>
          </li>
        </lifeStageAges>
		<thinkTreeConstant>ObserverConstant</thinkTreeConstant>
      </race>
	  <comps>
		<li Class="GD3.CompProperties_ObserverLink">
		  <toggleIconPath>UI/Buttons/ObserverLink</toggleIconPath>
		  <toggleLabelKey>GD.ObserverLink</toggleLabelKey>
		  <toggleDescKey>GD.ObserverLinkDesc</toggleDescKey>
		  <hediff>GD_ObserverEnhancer</hediff>
	    </li>
	  </comps>
    </ThingDef>
    
    <PawnKindDef ParentName="NonCombatLightMechanoidKind">
      <defName>Mech_Observer</defName>
      <label>observer</label>
      <race>Mech_Observer</race>
      <lifeStages>
        <li>
          <bodyGraphicData>
            <texPath>Pawn/Observer</texPath>
            <maskPath>Pawn/Mech_Observer</maskPath>
            <shaderType>CutoutWithOverlay</shaderType>
            <graphicClass>Graphic_Multi</graphicClass>
            <drawSize>1.1</drawSize>
          </bodyGraphicData>
        </li>
        <li>
          <bodyGraphicData>
            <texPath>Pawn/ObserverAncient</texPath>
            <maskPath>Pawn/Mech_Observer</maskPath>
            <shaderType>CutoutWithOverlay</shaderType>
            <graphicClass>Graphic_Multi</graphicClass>
            <drawSize>1.1</drawSize>
          </bodyGraphicData>
        </li>
      </lifeStages>
    </PawnKindDef>

</Defs>