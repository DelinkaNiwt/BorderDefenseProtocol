  <ThingDef ParentName="BaseBullet">
    <defName>Bullet_RedThunderArrow</defName>
    <label>thunder</label>
	<thingClass>GD3.BezierProjectiles_Explosive</thingClass>
    <graphicData>
      <texPath>RedThunderArrow</texPath>
      <graphicClass>Graphic_Single</graphicClass>
      <shaderType>MoteGlow</shaderType>
      <drawSize>(0.6, 0.8)</drawSize>
    </graphicData>
    <projectile>
      <damageDef>GDRedElec</damageDef>
      <speed>22</speed>
	  <damageAmountBase>55</damageAmountBase>
	  <armorPenetrationBase>0.65</armorPenetrationBase>
      <explosionRadius>2.9</explosionRadius>
      <!-- <preExplosionSpawnSingleThingDef>Filth_BlastMark</preExplosionSpawnSingleThingDef> -->
    </projectile>
	<modExtensions>
      <li Class="GD3.ModExt_BezierProjectiles">
        <drawStartDelay>1</drawStartDelay> <!-- 延迟多少 Tick 后开始绘制尾迹 -->
        <trailFleckDef>LineEMP_Red</trailFleckDef> <!-- 使用的尾迹粒子类型 -->
        <trailThickness>0.450</trailThickness> <!-- 尾迹线条的粗细 -->
        <probeStep>0.3</probeStep> <!-- 碰撞检测步长，越小越精确但性能越差 -->
        <!-- 三阶贝塞尔 -->
        <useCubieCurve>true</useCubieCurve> <!-- 启用三阶贝塞尔曲线的开关 -->
        <enableRandomSide>true</enableRandomSide> <!-- 是否启用随机左右翻转 -->
        <randomSideChance>0.5</randomSideChance> <!-- 触发翻转的概率（0~1） --> 
        <randOffsetRange>
          <min>-3.0</min> <!-- 控制点扰动偏移的最小值,这个值别太大，十几就顶天了！ -->
          <max>3.0</max> <!-- 控制点扰动偏移的最大值,这个值别太大，十几就顶天了！ -->
        </randOffsetRange>
        <P1Offset>0.0</P1Offset> <!-- 控制点1 与起点的距离百分比（0 ~ 1之间），越大越靠近终点 -->
        <P1Side>12.0</P1Side>   <!-- 控制点1 向左（或右）偏移的距离，值越大弯曲越强 -->
        <P2Offset>0.0</P2Offset> <!-- 控制点2 与起点的距离百分比（0 ~ 1之间），通常应 > P1Offset -->
        <P2Side>7.5</P2Side>  <!-- 控制点2 向右（或左）偏移的距离，符号决定弯曲方向 -->
      </li>
    </modExtensions>
  </ThingDef>

</Defs>