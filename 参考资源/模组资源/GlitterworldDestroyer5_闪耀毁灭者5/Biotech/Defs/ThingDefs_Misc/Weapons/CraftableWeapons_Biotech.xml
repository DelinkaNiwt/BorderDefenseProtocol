<?xml version="1.0" encoding="utf-8" ?>
<Defs>
	
	<!-- 死卫冲击炮 -->
	<ThingDef ParentName="BaseHumanMakeableGun">
    <defName>GD_UrchinLauncher</defName>
    <label>war urchin blaster</label>
    <description>This is a new weapon designed by your colonists to remotely launch a war urchin to help draw fire. \n\nDon't fire it at your friends, it still hurts to hit people.</description>
    <techLevel>Industrial</techLevel>
	<tickerType>Normal</tickerType>
	<smeltable>false</smeltable>
    <graphicData>
      <texPath>GD_UrchinLauncher</texPath>
      <graphicClass>Graphic_Single</graphicClass>
	  <drawSize>1.5</drawSize>
    </graphicData>
    <statBases>
      <WorkToMake>6000</WorkToMake>
      <Mass>2.0</Mass>
    </statBases>
    <weaponClasses>
      <li>RangedHeavy</li>
    </weaponClasses>
    <tradeTags>
      <li>ExoticMisc</li>
      <li>WeaponRanged</li>
    </tradeTags>
	<relicChance>0</relicChance>
    <verbs>
      <li>
        <verbClass>Verb_ShootOneUse</verbClass>
        <hasStandardCommand>true</hasStandardCommand>
        <defaultProjectile>GD_Bullet_UrchinLauncher</defaultProjectile>
        <warmupTime>2.5</warmupTime>
		<consumeFuelPerShot>1</consumeFuelPerShot>
        <range>35.9</range>
        <soundCast>InfernoCannon_Fire</soundCast>
        <soundCastTail>GunTail_Heavy</soundCastTail>
        <onlyManualCast>true</onlyManualCast>
        <stopBurstWithoutLos>false</stopBurstWithoutLos>
        <targetParams>
          <canTargetLocations>true</canTargetLocations>
        </targetParams>
        <muzzleFlashScale>14</muzzleFlashScale>
      </li>
    </verbs>
    <tools>
      <li>
        <label>handle</label>
        <capacities>
          <li>Blunt</li>
        </capacities>
        <power>21</power>
        <cooldownTime>2.2</cooldownTime>
      </li>
    </tools>
	<recipeMaker>
		<researchPrerequisite>GD3_StrangeWeapons</researchPrerequisite>
	</recipeMaker>
	<costList>
		<Steel>60</Steel>
	    <Chemfuel>20</Chemfuel>
        <ComponentIndustrial>2</ComponentIndustrial>
	</costList>
  </ThingDef>
  
  <ThingDef ParentName="BaseBullet">
    <defName>GD_Bullet_UrchinLauncher</defName>
    <label>flying urchine</label>
    <graphicData>
      <texPath>FlyingUrchin</texPath>
      <graphicClass>Graphic_Single</graphicClass>
      <shaderType>TransparentPostLight</shaderType>
    </graphicData>
    <projectile>
      <damageDef>Blunt</damageDef>
	  <damageAmountBase>15</damageAmountBase>
      <armorPenetrationBase>0.45</armorPenetrationBase>
      <speed>55</speed>
	  <flyOverhead>false</flyOverhead>
    </projectile>
	<comps>
		<li Class="GD3.CompProperties_SpawnMech">
			<soundWhenImpact>GD_UrchinLauncher</soundWhenImpact>
			<mechanoid>Mech_WarUrchin</mechanoid>
		</li>
	</comps>
  </ThingDef>
  
</Defs>