      <biome>DryOcean</biome>
      <temperature>25</temperature>
    </pocketMapProperties>
    <genSteps>
	  <!-- <li>ElevationFertility</li> -->
	  <li>Terrain</li>
      <li>GD_Sitepart_Drysea</li>
    </genSteps>
  </MapGeneratorDef>
  
  <BiomeDef>
    <defName>DryOcean</defName>
    <label>dry sea</label>
    <description>Open ocean. Great for fish. Not so great for you.</description>
    <workerClass>GD3.BiomeWorker_Drysea</workerClass>
    <canBuildBase>true</canBuildBase>
    <allowRoads>true</allowRoads>
    <allowRivers>false</allowRivers>
    <hasVirtualPlants>false</hasVirtualPlants>
	<terrainsByFertility>
      <li>
        <terrain>SoilRich</terrain>
        <min>-999</min>
        <max>999</max>
      </li>
    </terrainsByFertility>
	<terrainPatchMakers>
      <li>
        <perlinFrequency>0.027</perlinFrequency>
        <thresholds>
          <li>
            <terrain>SoilRich</terrain>
            <min>-999</min>
            <max>999</max>
          </li>
        </thresholds>
      </li>
    </terrainPatchMakers>
    <texture>World/Biomes/Ocean</texture>
    <impassable>true</impassable>
  </BiomeDef>
  
