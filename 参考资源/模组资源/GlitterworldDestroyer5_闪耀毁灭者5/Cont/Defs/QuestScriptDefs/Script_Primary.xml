    <defName>GD_Quest_Eliminate</defName>
	<defaultChallengeRating>3</defaultChallengeRating>
    <questNameRules>
      <rulesStrings>
        <li>questName->Eliminate traitors</li>
      </rulesStrings>
    </questNameRules>
    <questDescriptionRules>
      <rulesStrings>
        <li>questDescription->We could not pick up the signal of the two traitors from the map, and could only roughly determine their movements from the location of militor. \n\nTrack the signal and clear the target. Because militor could be in danger, the faster we can act, the better.</li>
      </rulesStrings>
    </questDescriptionRules>
	<root Class="QuestNode_Sequence">
      <nodes>
		
		<li Class="GD3.QuestNode_BlackQuest" />
		
        <li Class="QuestNode_SubScript">
          <def>Util_AdjustPointsForDistantFight</def>
        </li>
        <li Class="QuestNode_GetMap" />
		
