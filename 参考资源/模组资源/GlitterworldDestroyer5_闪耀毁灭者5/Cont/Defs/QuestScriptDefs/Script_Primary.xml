        </li>
        
        <li Class="QuestNode_GetSiteThreatPoints">
          <storeAs>sitePoints</storeAs>
          <sitePartsParams>$sitePartsParams</sitePartsParams>
        </li>

        <li Class="QuestNode_SubScript">
          <def>Util_GenerateSite</def>
        </li>
		
		<li Class="GD3.QuestNode_Drysea">
		  <site>$site</site>
		</li>
        
        <li Class="QuestNode_SpawnWorldObjects">
          <worldObjects>$site</worldObjects>
        </li>

      </nodes>
    </root>
  </QuestScriptDef>
  
  <MapGeneratorDef>
    <defName>Drysea</defName>
    <label>drysea</label>
    <isUnderground>false</isUnderground>
    <forceCaves>false</forceCaves>
    <ignoreAreaRevealedLetter>true</ignoreAreaRevealedLetter>
    <disableCallAid>true</disableCallAid>
    <!-- <customMapComponents>
      <li>UndercaveMapComponent</li>
    </customMapComponents> -->
