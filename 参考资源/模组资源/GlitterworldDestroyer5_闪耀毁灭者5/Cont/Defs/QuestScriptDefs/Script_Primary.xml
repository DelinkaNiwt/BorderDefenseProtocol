  </QuestScriptDef>
  
  <!-- 巨黾集群 -->
  <!-- genStep -->
  <SitePartDef>
    <defName>GD_Sitepart_Exostrider</defName>
    <label>exostrider cluster</label>
    <description>A giant cluster defending giant exostrider.</description>
