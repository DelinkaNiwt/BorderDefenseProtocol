<?xml version="1.0" encoding="utf-8" ?>
<Defs>

  <!-- base -->
  <QuestScriptDef Name="BlackMechQuestBase" Abstract="True">
    <rootSelectionWeight>0.00001</rootSelectionWeight>
    <rootMinPoints>99999</rootMinPoints>
    <canGiveRoyalFavor>false</canGiveRoyalFavor>
	<autoAccept>false</autoAccept>
	<expireDaysRange>60</expireDaysRange>
  </QuestScriptDef>
  
  <!-- 垃圾空投 -->
  <QuestScriptDef ParentName="BlackMechQuestBase">
    <defName>GD_PollutionDump</defName>
	<defaultChallengeRating>1</defaultChallengeRating>
    <questNameRules>
      <rulesStrings>

        <!-- quest name -->
        <li>questName->Air drop of highly toxic substances</li>

      </rulesStrings>
    </questNameRules>
    <questDescriptionRules>
      <rulesStrings>
        
        <li>questDescription->A highly toxic substance is about to be dropped on your colony. These substances are difficult to handle with conventional degraders, so you should prepare a cold space to store it, or think of other ways.</li>     
      
      </rulesStrings>
    </questDescriptionRules>
    <questContentRules>
      <rulesStrings>

        <!-- Letters -->
        <li>wastepacksLetterLabel->Highly toxic substances arrived</li>
        <li>wastepacksLetterText->The highly toxic substance described by the black-clad mechanoid has arrived.</li>

      </rulesStrings>
    </questContentRules>
    <root Class="GD3.QuestNode_Root_ToxPollutionPump" />
  </QuestScriptDef>
  
  <!-- 次生核心 -->
  <QuestScriptDef ParentName="BlackMechQuestBase">
    <defName>GD_SubcoreAnalyse</defName>
	<defaultChallengeRating>1</defaultChallengeRating>
    <questNameRules>
      <rulesStrings>

        <!-- quest name -->
        <li>questName->Subcore order</li>

      </rulesStrings>
    </questNameRules>
    <questDescriptionRules>
      <rulesStrings>
        
        <li>questDescription->The subcore of the Black Mechanoid Hive is about to be parachuted into your colony. \n\nIn order to maintain the stability of the program and ensure heat dissipation, you can only study it once every eight hours, and it will be sent back automatically when the research is done. Colonists of low intellectual level may cause some surprises during the research process.</li>     
      
      </rulesStrings>
    </questDescriptionRules>
    <questContentRules>
      <rulesStrings>

        <!-- Letters -->
        <li>subcoreArriveLetterLabel->Subcore</li>
        <li>subcoreArriveLetterText->The subcore described by the black-clad mechanoid has arrived.</li>

      </rulesStrings>
    </questContentRules>
    <root Class="GD3.QuestNode_Root_SubcoreAnalyze" />
  </QuestScriptDef>
  
  <!-- 窃取三级情报 -->
  <!-- genStep -->
  <SitePartDef>
    <defName>GD_Sitepart_Cluster_Fortress</defName>
    <label>mechanoid fortress</label>
    <description>A well-defended mechanoid fortress.</description>
    <siteTexture>UI/Symbols/MechFortress</siteTexture>
    <expandingIconTexture>UI/Symbols/MechFortress</expandingIconTexture>
    <handlesWorldObjectTimeoutInspectString>true</handlesWorldObjectTimeoutInspectString>
	<wantsThreatPoints>true</wantsThreatPoints>
    <tags>
      <li>GD_Fortress</li>
    </tags>
	<minMapSize>(250, 1, 250)</minMapSize>
  </SitePartDef>
  
   <GenStepDef>
    <defName>GD_Sitepart_Cluster_Fortress</defName>
    <linkWithSite>GD_Sitepart_Cluster_Fortress</linkWithSite>
    <order>464</order>
    <genStep Class="GD3.GenStep_CustomStructureGen">
      <structureLayoutDefs>
        <li>GD_Fortress</li>
      </structureLayoutDefs>
	  <forcedfaction>Mechanoid</forcedfaction>
	  <spawnOnEdge>false</spawnOnEdge>
	  <pointMultiplier>5.0</pointMultiplier>
	  <generateBlack>true</generateBlack>
    </genStep>
  </GenStepDef>
  
  <!-- quest -->
  <QuestScriptDef ParentName="BlackMechQuestBase">
    <defName>GD_Quest_Cluster_Fortress</defName>
	<defaultChallengeRating>2</defaultChallengeRating>
    <questNameRules>
      <rulesStrings>
        <li>questName->Third-level intelligence theft</li>
      </rulesStrings>
    </questNameRules>
    <questDescriptionRules>
      <rulesStrings>
        <li>questDescription->In order to protect the information of the Black Mechanoid Hive from being leaked, we need to attack a mechanoid's fortress, hack into its central engine room and steal the relevant third level intelligence. \n\nAccess to intelligence needs to be activated with a key. It may be on one of the mechs in the fortress, which must be destroyed and the key seized. All accessible servers in the fortress must remain intact in order for us to parse the full information. \n\nBlack-clad tesseron and black-clad legionary will cover your movements.</li>
      </rulesStrings>
    </questDescriptionRules>
	<root Class="QuestNode_Sequence">
      <nodes>
		
		<li Class="GD3.QuestNode_BlackQuest" />
		
        <li Class="QuestNode_SubScript">
          <def>Util_AdjustPointsForDistantFight</def>
        </li>
        <li Class="QuestNode_GetMap" />
		
		<li Class="QuestNode_Set">
          <name>siteDistRange</name>
          <value>5~10</value>
        </li>

        <li Class="QuestNode_GetSiteTile">
          <storeAs>siteTile</storeAs>
          <preferCloserTiles>true</preferCloserTiles>
		  <selectLandmarkChance>0</selectLandmarkChance>
        </li>

        <li Class="QuestNode_GetSitePartDefsByTagsAndFaction">
          <storeAs>sitePartDefs</storeAs>
          <storeFactionAs>siteFaction</storeFactionAs>
          <sitePartsTags>
            <li><tag>GD_Fortress</tag></li>
          </sitePartsTags>
          <!-- <mustBeHostileToFactionOf>Mechanoid</mustBeHostileToFactionOf> -->
        </li>
		
		<li Class="VEF.Storyteller.QuestNode_GetFaction">
			<allowEnemy>true</allowEnemy>
			<mustBePermanentEnemy>true</mustBePermanentEnemy>
			<storeAs>siteFaction</storeAs>
			<factionDef>Mechanoid</factionDef>
		</li>

        <li Class="QuestNode_GetDefaultSitePartsParams">
          <tile>$siteTile</tile>
          <faction>$siteFaction</faction>
          <sitePartDefs>$sitePartDefs</sitePartDefs>
          <storeSitePartsParamsAs>sitePartsParams</storeSitePartsParamsAs>
        </li>
        
        <li Class="QuestNode_GetSiteThreatPoints">
          <storeAs>sitePoints</storeAs>
          <sitePartsParams>$sitePartsParams</sitePartsParams>
        </li>

        <li Class="QuestNode_SubScript">
          <def>Util_GenerateSite</def>
        </li>
		
		<li Class="GD3.QuestNode_FortressEnd" />
        
        <li Class="QuestNode_SpawnWorldObjects">
          <worldObjects>$site</worldObjects>
        </li>

        <li Class="QuestNode_WorldObjectTimeout">
          <worldObject>$site</worldObject>
          <isQuestTimeout>true</isQuestTimeout>
          <delayTicks>$(3*60000)</delayTicks>
          <inSignalDisable>site.MapGenerated</inSignalDisable>
          <node Class="QuestNode_Sequence">
            <nodes>
              <li Class="QuestNode_Letter">
                <label TKey="LetterLabelQuestExpired">Quest expired: [resolvedQuestName]</label>
                <text TKey="LetterTextQuestExpired">The mechanoid carrying the key has been moved from the fortress. The task [resolvedQuestName] has expired.</text>
              </li>
              <li Class="QuestNode_End">
                <outcome>Fail</outcome>
              </li>
            </nodes>
          </node>
        </li>

        <!-- If we enter and leave, the map is destroyed. Fail the quest. -->
        <li Class="QuestNode_Signal">
          <inSignal>site.Destroyed</inSignal>
          <node Class="QuestNode_Sequence">
            <nodes>
              <li Class="QuestNode_Letter">
                <label TKey="LetterLabelQuestFailed">Quest failed: [resolvedQuestName]</label>
                <text TKey="LetterTextQuestFailed">After the unsuccessful attack, the Mechs fortified the attacked stronghold and transferred information about it. Mission [resolvedQuestName] has failed.</text>
              </li>
              <li Class="QuestNode_End">
                <outcome>Fail</outcome>
              </li>
            </nodes>
          </node>
        </li>
      </nodes>
    </root>
  </QuestScriptDef>
  
  <!-- 护卫机械小蠊 -->
  <!-- genStep -->
  <SitePartDef>
    <defName>GD_Sitepart_Militor</defName>
    <label>militor's location</label>
    <description>militor needs your backup. Advance troops are in position.</description>
    <siteTexture>UI/Symbols/GuardMilitor</siteTexture>
    <expandingIconTexture>UI/Symbols/GuardMilitor</expandingIconTexture>
    <handlesWorldObjectTimeoutInspectString>true</handlesWorldObjectTimeoutInspectString>
	<wantsThreatPoints>true</wantsThreatPoints>
    <tags>
      <li>GD_Town</li>
    </tags>
	<minMapSize>(150, 1, 150)</minMapSize>
  </SitePartDef>
  
   <GenStepDef>
    <defName>GD_Sitepart_Militor</defName>
    <linkWithSite>GD_Sitepart_Militor</linkWithSite>
    <order>464</order>
    <genStep Class="GD3.GenStep_CustomStructureGen_Militor">
      <structureLayoutDefs>
        <li>GD_Town</li>
      </structureLayoutDefs>
	  <forcedfaction>BlackMechanoid</forcedfaction>
    </genStep>
  </GenStepDef>
  
  <!-- quest -->
  <QuestScriptDef ParentName="BlackMechQuestBase">
    <defName>GD_Quest_Militor</defName>
	<defaultChallengeRating>2</defaultChallengeRating>
    <questNameRules>
      <rulesStrings>
        <li>questName->Guard the Militor</li>
      </rulesStrings>
    </questNameRules>
    <questDescriptionRules>
      <rulesStrings>
        <li>questDescription->A large mechanoid force is approaching the runaway militor in an attempt to destroy it. We must get to the location of the militor before the large force is pinned down, then build a defense and destroy all the enemies. \n\nThe battle will take place in an abandoned town, it is recommended to carry a certain amount of materials or portable turrets to assist in defense.</li>
      </rulesStrings>
    </questDescriptionRules>
	<root Class="QuestNode_Sequence">
      <nodes>
		
		<li Class="GD3.QuestNode_BlackQuest" />
		
        <li Class="QuestNode_SubScript">
          <def>Util_AdjustPointsForDistantFight</def>
        </li>
        <li Class="QuestNode_GetMap" />
		
		<li Class="QuestNode_Set">
          <name>siteDistRange</name>
          <value>5~10</value>
        </li>

        <li Class="QuestNode_GetSiteTile">
          <storeAs>siteTile</storeAs>
          <preferCloserTiles>true</preferCloserTiles>
		  <selectLandmarkChance>0</selectLandmarkChance>
        </li>

        <li Class="QuestNode_GetSitePartDefsByTagsAndFaction">
          <storeAs>sitePartDefs</storeAs>
          <storeFactionAs>siteFaction</storeFactionAs>
          <sitePartsTags>
            <li><tag>GD_Town</tag></li>
          </sitePartsTags>
        </li>
		
		<li Class="VEF.Storyteller.QuestNode_GetFaction">
			<allowNeutral>true</allowNeutral>
			<mustBePermanentEnemy>false</mustBePermanentEnemy>
			<storeAs>siteFaction</storeAs>
			<factionDef>BlackMechanoid</factionDef>
		</li>

        <li Class="QuestNode_GetDefaultSitePartsParams">
          <tile>$siteTile</tile>
          <faction>$siteFaction</faction>
          <sitePartDefs>$sitePartDefs</sitePartDefs>
          <storeSitePartsParamsAs>sitePartsParams</storeSitePartsParamsAs>
        </li>
        
        <li Class="QuestNode_GetSiteThreatPoints">
          <storeAs>sitePoints</storeAs>
          <sitePartsParams>$sitePartsParams</sitePartsParams>
        </li>

        <li Class="QuestNode_SubScript">
          <def>Util_GenerateSite</def>
        </li>
		
		<li Class="GD3.QuestNode_Militor" />
        
        <li Class="QuestNode_SpawnWorldObjects">
          <worldObjects>$site</worldObjects>
        </li>

        <li Class="QuestNode_WorldObjectTimeout">
          <worldObject>$site</worldObject>
          <isQuestTimeout>true</isQuestTimeout>
          <delayTicks>$(randInt(15,18)*60000)</delayTicks>
          <inSignalDisable>site.MapGenerated</inSignalDisable>
          <node Class="QuestNode_Sequence">
            <nodes>
              <li Class="QuestNode_Letter">
                <label TKey="LetterLabelQuestExpired">Quest expired: [resolvedQuestName]</label>
                <text TKey="LetterTextQuestExpired">We've lost contact with the militor. The task [resolvedQuestName] has expired.</text>
              </li>
              <li Class="QuestNode_End">
                <outcome>Fail</outcome>
              </li>
            </nodes>
          </node>
        </li>

        <li Class="QuestNode_Signal">
          <inSignal>site.Destroyed</inSignal>
          <node Class="QuestNode_Sequence">
            <nodes>
              <li Class="QuestNode_Letter">
                <label TKey="LetterLabelQuestFailed">Quest failed: [resolvedQuestName]</label>
                <text TKey="LetterTextQuestFailed">We've lost contact with the militor. Mission [resolvedQuestName] has failed.</text>
              </li>
              <li Class="QuestNode_End">
                <outcome>Fail</outcome>
              </li>
            </nodes>
          </node>
        </li>

      </nodes>
    </root>
  </QuestScriptDef>
  
  <!-- 枯海 -->
