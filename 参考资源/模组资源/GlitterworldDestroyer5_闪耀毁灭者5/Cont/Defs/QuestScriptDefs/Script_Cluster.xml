<?xml version="1.0" encoding="utf-8" ?>
<Defs>
  
  <!-- base -->
  <QuestScriptDef Name="GiantClusterQuestBase" Abstract="True">
    <rootSelectionWeight>0.00001</rootSelectionWeight>
    <rootMinPoints>99999</rootMinPoints>
    <canGiveRoyalFavor>false</canGiveRoyalFavor>
	<autoAccept>true</autoAccept>
    <!-- <successHistoryEvent MayRequire="Ludeon.RimWorld.Ideology">Raided_BanditCamp</successHistoryEvent> -->
  </QuestScriptDef>
  
  <!-- 小型 -->
  <QuestScriptDef ParentName="GiantClusterQuestBase">
    <defName>GD_Quest_Cluster_S</defName>
	<defaultChallengeRating>1</defaultChallengeRating>
    <questNameRules>
      <rulesStrings>
        <li>questName->Detected giant mechanoid clusters α</li>
      </rulesStrings>
    </questNameRules>
    <questDescriptionRules>
      <rulesStrings>
        <li>questDescription->The shortwave receiver located the position of a giant cluster not far away. \n\nThis cluster looks like it was just recently established, and a handful of not-so-strong turrets are protecting a huge container that looks like a resource staging area. If we raid this cluster, we might be able to harvest a considerable amount of basic materials. \n\n*Biotech DLC: Termites are powerful offensive vanguards, so take at least one with you before you go.</li>
      </rulesStrings>
    </questDescriptionRules>
	<root Class="QuestNode_Sequence">
      <nodes>

        <li Class="QuestNode_SubScript">
          <def>Util_AdjustPointsForDistantFight</def>
        </li>
        <li Class="QuestNode_GetMap" />
		
		<li Class="QuestNode_Set">
          <name>siteDistRange</name>
          <value>5~10</value>
        </li>

        <li Class="QuestNode_GetSiteTile">
          <storeAs>siteTile</storeAs>
          <preferCloserTiles>true</preferCloserTiles>
		  <selectLandmarkChance>0</selectLandmarkChance>
        </li>

        <li Class="QuestNode_GetSitePartDefsByTagsAndFaction">
          <storeAs>sitePartDefs</storeAs>
          <storeFactionAs>siteFaction</storeFactionAs>
          <sitePartsTags>
            <li><tag>GiantCluster_S</tag></li>
          </sitePartsTags>
          <!-- <mustBeHostileToFactionOf>Mechanoid</mustBeHostileToFactionOf> -->
        </li>
		
		<li Class="VEF.Storyteller.QuestNode_GetFaction">
			<allowEnemy>true</allowEnemy>
			<mustBePermanentEnemy>true</mustBePermanentEnemy>
			<storeAs>siteFaction</storeAs>
			<factionDef>Mechanoid</factionDef>
		</li>

        <li Class="QuestNode_GetDefaultSitePartsParams">
          <tile>$siteTile</tile>
          <faction>$siteFaction</faction>
          <sitePartDefs>$sitePartDefs</sitePartDefs>
          <storeSitePartsParamsAs>sitePartsParams</storeSitePartsParamsAs>
        </li>
        
        <li Class="QuestNode_GetSiteThreatPoints">
          <storeAs>sitePoints</storeAs>
          <sitePartsParams>$sitePartsParams</sitePartsParams>
        </li>

        <li Class="QuestNode_SubScript">
          <def>Util_GenerateSite</def>
        </li>
        
        <li Class="QuestNode_SpawnWorldObjects">
          <worldObjects>$site</worldObjects>
        </li>

        <li Class="QuestNode_WorldObjectTimeout">
          <worldObject>$site</worldObject>
          <isQuestTimeout>true</isQuestTimeout>
          <delayTicks>$(randInt(15,18)*60000)</delayTicks>
          <inSignalDisable>site.MapGenerated</inSignalDisable>
          <node Class="QuestNode_Sequence">
            <nodes>
              <li Class="QuestNode_Letter">
                <label TKey="LetterLabelQuestExpired">Quest expired: [resolvedQuestName]</label>
                <text TKey="LetterTextQuestExpired">The giant cluster has achieved its residency purpose and completed its transfer. The task [resolvedQuestName] has expired.</text>
              </li>
              <li Class="QuestNode_End">
                <outcome>Fail</outcome>
              </li>
            </nodes>
          </node>
        </li>

        <!-- If we enter and leave, the map is destroyed. Fail the quest. -->
        <li Class="QuestNode_Signal">
          <inSignal>site.Destroyed</inSignal>
          <node Class="QuestNode_Sequence">
            <nodes>
              <li Class="QuestNode_Letter">
                <label TKey="LetterLabelQuestFailed">Quest end: [resolvedQuestName]</label>
                <text TKey="LetterTextQuestFailed">Mission [resolvedQuestName] has ended.</text>
              </li>
              <li Class="QuestNode_End">
                <outcome>Fail</outcome>
              </li>
            </nodes>
          </node>
        </li>
      </nodes>
    </root>
  </QuestScriptDef>
  
