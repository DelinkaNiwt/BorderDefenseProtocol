  <!-- quest -->
  <QuestScriptDef ParentName="MechHiveQuestBase">
    <defName>GD_Quest_BlackApocriton</defName>
	<defaultChallengeRating>4</defaultChallengeRating>
    <questNameRules>
      <rulesStrings>
        <li>questName->Funeral</li>
      </rulesStrings>
    </questNameRules>
    <questDescriptionRules>
      <rulesStrings>
        <li>questDescription->You have received a set of messages from mechanoid hive. \n\nThanks to your long-term assistance, mechanoids has collected sufficient information and successfully located their ultimate target - the black-clad apocriton. This advanced mechanoid with independent thinking has been regarded as a major threat since it broke away from mechanoid hive, and now the perfect opportunity to eliminate it has finally arrived. \n\nBased on the analysis of the detected psychic fluctuations, it seems that the black-clad apocriton is planning to use long-distance skip to send its dozens of surviving colleagues to other planets. Therefore, mechanoids needs your last assistance: go to its location, hold it back until the powerful psychic wave from the core of mechanoid hive erases it from this world. \n\nThe black-clad apocriton is unlikely to be killed directly by any of the methods you have in mind. But you can still force it to focus on defense by dealing damage, buying time for mechanoid hive's decisive strike.</li>
      </rulesStrings>
    </questDescriptionRules>
	<questContentRules>
      <rulesStrings>
        <li>mailLabel->mech email</li>
        <li>mailText->An email has been sent to your colony, which contains a large amount of information about the black-clad apocriton. They will come in handy during battles.</li>
      </rulesStrings>
    </questContentRules>
	<root Class="QuestNode_Sequence">
      <nodes>

        <li Class="QuestNode_SubScript">
          <def>Util_AdjustPointsForDistantFight</def>
        </li>
        <li Class="QuestNode_GetMap" />
		
		<li Class="QuestNode_GenerateThing">
		  <def>GD_DescriptionChip</def>
		  <storeAs>mail</storeAs>
		</li>
		<li Class="QuestNode_DropPods">
          <contents>$mail</contents>
          <useTradeDropSpot>true</useTradeDropSpot>
		  <sendStandardLetter>true</sendStandardLetter>
		  <customLetterLabel>[mailLabel]</customLetterLabel>
		  <customLetterText>[mailText]</customLetterText>
        </li>
		
		<li Class="QuestNode_Set">
          <name>siteDistRange</name>
          <value>5~10</value>
        </li>

        <li Class="QuestNode_GetSiteTile">
          <storeAs>siteTile</storeAs>
          <preferCloserTiles>true</preferCloserTiles>
		  <selectLandmarkChance>0</selectLandmarkChance>
        </li>

        <li Class="QuestNode_GetSitePartDefsByTagsAndFaction">
          <storeAs>sitePartDefs</storeAs>
          <storeFactionAs>siteFaction</storeFactionAs>
          <sitePartsTags>
            <li><tag>Site_BlackApocriton</tag></li>
          </sitePartsTags>
        </li>
		
		<li Class="VEF.Storyteller.QuestNode_GetFaction">
			<allowEnemy>true</allowEnemy>
			<mustBePermanentEnemy>true</mustBePermanentEnemy>
			<storeAs>siteFaction</storeAs>
			<factionDef>Mechanoid</factionDef>
		</li>

        <li Class="QuestNode_GetDefaultSitePartsParams">
          <tile>$siteTile</tile>
          <faction>$siteFaction</faction>
          <sitePartDefs>$sitePartDefs</sitePartDefs>
          <storeSitePartsParamsAs>sitePartsParams</storeSitePartsParamsAs>
        </li>
        
        <li Class="QuestNode_GetSiteThreatPoints">
          <storeAs>sitePoints</storeAs>
          <sitePartsParams>$sitePartsParams</sitePartsParams>
        </li>

        <li Class="QuestNode_SubScript">
          <def>Util_GenerateSite</def>
        </li>
		
		<li Class="QuestNode_SpawnWorldObjects">
          <worldObjects>$site</worldObjects>
        </li>
        
        <li Class="GD3.QuestNode_PlaceThing">
		  <inSignal>site.MapGenerated</inSignal>
          <site>$site</site>
		  <thingDef>GD_FinalBattleDummy</thingDef>
        </li>
		
		<li Class="QuestNode_Signal">
          <inSignal>TargetKilled</inSignal>
          <node Class="QuestNode_Sequence">
            <nodes>
			  <li Class="QuestNode_End">
				<outcome>Success</outcome>
				<sendStandardLetter>false</sendStandardLetter>
			  </li>
            </nodes>
          </node>
        </li>
		
        <!-- If we enter and leave, the map is destroyed. Fail the quest. -->
        <li Class="QuestNode_Signal">
          <inSignal>site.Destroyed</inSignal>
          <node Class="QuestNode_Sequence">
            <nodes>
              <li Class="QuestNode_Letter">
                <label TKey="LetterLabelQuestFailed">Quest failed: [resolvedQuestName]</label>
                <text TKey="LetterTextQuestFailed">Due to the loss of accurate target positioning, the psychic strike of mechanoid hive failed to achieve the expected effect. Mission [resolvedQuestName] has failed.</text>
              </li>
              <li Class="QuestNode_End">
                <outcome>Fail</outcome>
              </li>
            </nodes>
          </node>
        </li>
      </nodes>
    </root>
  </QuestScriptDef>

</Defs>