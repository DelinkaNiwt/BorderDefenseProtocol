<?xml version="1.0" encoding="utf-8" ?>
<Defs>
  
  <StructureLayoutDef>
    <defName>GD_BlackBaseSite</defName>
    <workerClass>GD3.LayoutWorker_BlackSite</workerClass>
    <canHaveMultipleLayoutsInRoom>true</canHaveMultipleLayoutsInRoom>
    <!-- <wallLampDef>AncientEmergencyLight_Blue</wallLampDef> -->
	<terrainDef>Concrete</terrainDef>
    <minRoomWidth>8</minRoomWidth>
    <minRoomHeight>8</minRoomHeight>
    <roomDefs>
      <GDJustRacksRoom>
        <countRange>2~3</countRange>
      </GDJustRacksRoom>
      <GDCasesRoom>
        <countRange>1~2</countRange>
      </GDCasesRoom>
      <GDComputerRoom>
        <countRange>1</countRange>
      </GDComputerRoom>

      <!-- Decorative -->
      <GDPlayRoom>0.6</GDPlayRoom>
      <GDGestatorRoom>1.2</GDGestatorRoom>
      <GDStorageRoom>1.2</GDStorageRoom>
      <GDPaperBoxRoom>1</GDPaperBoxRoom>

      <!-- Smaller threats -->
      <GDResearchRoom>1</GDResearchRoom>

    </roomDefs>
    <junkScaterrers>
	  <Filth_ScatteredDocuments>
        <groupsPerHundredCells>1~2</groupsPerHundredCells>
        <itemsPerGroup>2~4</itemsPerGroup>
        <groupDistRange>3~5</groupDistRange>
      </Filth_ScatteredDocuments>
      <Filth_RubbleRock>
        <groupsPerHundredCells>1~3</groupsPerHundredCells>
        <itemsPerGroup>3~8</itemsPerGroup>
        <groupDistRange>3~5</groupDistRange>
      </Filth_RubbleRock>
    </junkScaterrers>
  </StructureLayoutDef>
  
  <!--===== 房间结构 =====-->
  <LayoutRoomDef>
    <defName>GDBlackCorridor</defName>
    <roomContentsWorkerType>RoomContents_Corridor</roomContentsWorkerType>
  </LayoutRoomDef>
  
  <LayoutRoomDef>
    <defName>GDComputerRoom</defName>
    <minSingleRectWidth>8</minSingleRectWidth>
    <minSingleRectHeight>8</minSingleRectHeight>
    <dontDestroyWallsDoors>true</dontDestroyWallsDoors>
    <prefabs>
      <GD_BlackMechComputer>
        <countPerHundredCells>6</countPerHundredCells>
        <minMaxRange>1~1</minMaxRange>
      </GD_BlackMechComputer>
      <GD_SystemRack>
        <countPerTenEdgeCells>2</countPerTenEdgeCells>
        <minMaxRange>5~10</minMaxRange>
      </GD_SystemRack>
      <GD_LargeCrate>
        <countPerHundredCells>2</countPerHundredCells>
        <minMaxRange>1~5</minMaxRange>
      </GD_LargeCrate>
	  <GD_SmallCrate>
        <countPerHundredCells>2</countPerHundredCells>
        <minMaxRange>1~5</minMaxRange>
      </GD_SmallCrate>
    </prefabs>
  </LayoutRoomDef>
  
  <LayoutRoomDef>
    <defName>GDPlayRoom</defName>
    <dontDestroyWallsDoors>true</dontDestroyWallsDoors>
    <prefabs>
      <GD_BilliardsTable>
        <countPerHundredCells>3</countPerHundredCells>
        <minMaxRange>1~1</minMaxRange>
      </GD_BilliardsTable>
      <GD_TelevisionAndTable>
        <countPerTenEdgeCells>2</countPerTenEdgeCells>
        <minMaxRange>1~1</minMaxRange>
      </GD_TelevisionAndTable>
      <GD_StorageRacks>
        <countPerHundredCells>1</countPerHundredCells>
        <minMaxRange>0~1</minMaxRange>
      </GD_StorageRacks>
      <GD_EmptyRacks>
        <countPerHundredCells>1</countPerHundredCells>
        <minMaxRange>1~2</minMaxRange>
      </GD_EmptyRacks>
      <GD_PowerCell>
        <countPerHundredCells>15</countPerHundredCells>
        <minMaxRange>0~2</minMaxRange>
      </GD_PowerCell>
	  <GD_FirefoamPopper>
        <countPerHundredCells>1</countPerHundredCells>
        <minMaxRange>1</minMaxRange>
      </GD_FirefoamPopper>
    </prefabs>
	<parts>
      <GD_ArchoMineDrone>
		<countRange>0~1</countRange>
	  </GD_ArchoMineDrone>
    </parts>
    <floorTypes>
      <li>AncientWoodPlankFloor</li>
    </floorTypes>
  </LayoutRoomDef>
  
  <LayoutRoomDef>
    <defName>GDGestatorRoom</defName>
    <dontDestroyWallsDoors>true</dontDestroyWallsDoors>
    <prefabs>
      <GD_AncientMechGestator>
        <countPerHundredCells>2</countPerHundredCells>
        <minMaxRange>2~4</minMaxRange>
      </GD_AncientMechGestator>
      <GD_BandNodes>
        <countPerHundredCells>2</countPerHundredCells>
        <minMaxRange>1~2</minMaxRange>
      </GD_BandNodes>
      <GD_AncientTurret>
        <countPerTenEdgeCells>5</countPerTenEdgeCells>
        <minMaxRange>1~2</minMaxRange>
      </GD_AncientTurret>
      <GD_GiantMachine>
        <countPerTenEdgeCells>1</countPerTenEdgeCells>
        <minMaxRange>0~1</minMaxRange>
      </GD_GiantMachine>
      <GD_SystemRack>
        <countPerTenEdgeCells>2</countPerTenEdgeCells>
        <minMaxRange>5~10</minMaxRange>
      </GD_SystemRack>
    </prefabs>
    <parts>
      <GD_ArchoMineDrone>
		<countRange>0~1</countRange>
	  </GD_ArchoMineDrone>
    </parts>
  </LayoutRoomDef>
  
  <LayoutRoomDef>
    <defName>GDStorageRoom</defName>
    <dontDestroyWallsDoors>true</dontDestroyWallsDoors>
    <prefabs>
      <GD_EmptyRacks>
        <countPerTenEdgeCells>3</countPerTenEdgeCells>
      </GD_EmptyRacks>
      <GD_MechBooster>
        <countPerHundredCells>2</countPerHundredCells>
        <minMaxRange>0~1</minMaxRange>
      </GD_MechBooster>
      <GD_StorageRacks>
        <countPerTenEdgeCells>2</countPerTenEdgeCells>
        <minMaxRange>0~2</minMaxRange>
      </GD_StorageRacks>
      <GD_BigCase>
        <countPerTenEdgeCells>1</countPerTenEdgeCells>
        <minMaxRange>0~1</minMaxRange>
      </GD_BigCase>
      <GD_LargeCrate>
        <countPerHundredCells>4</countPerHundredCells>
      </GD_LargeCrate>
      <GD_SmallCrate>
        <countPerHundredCells>4</countPerHundredCells>
      </GD_SmallCrate>
    </prefabs>
    <floorTypes>
      <li>MetalTile</li>
      <li>AncientTile</li>
    </floorTypes>
  </LayoutRoomDef>
  
  <LayoutRoomDef>
    <defName>GDPaperBoxRoom</defName>
    <canMergeWithAdjacentRoom>true</canMergeWithAdjacentRoom>
    <prefabs>
      <GD_LargeCrate>
        <countPerHundredCells>3</countPerHundredCells>
      </GD_LargeCrate>
      <GD_SmallCrate>
        <countPerHundredCells>2</countPerHundredCells>
      </GD_SmallCrate>
      <GD_PaperBoxA>
        <countPerHundredCells>1</countPerHundredCells>
        <minMaxRange>1~2</minMaxRange>
      </GD_PaperBoxA>
      <GD_PaperBoxB>
        <countPerHundredCells>1</countPerHundredCells>
        <minMaxRange>1~2</minMaxRange>
      </GD_PaperBoxB>
    </prefabs>
    <floorTypes>
      <li>AncientTile</li>
    </floorTypes>
    <scatterTerrain>
      <AncientConcrete>
        <groupsPerHundredCells>5~8</groupsPerHundredCells>
        <itemsPerGroup>10~15</itemsPerGroup>
        <groupDistRange>1~5</groupDistRange>
      </AncientConcrete>
    </scatterTerrain>
  </LayoutRoomDef>
  
  <LayoutRoomDef>
    <defName>GDResearchRoom</defName>
    <dontDestroyWallsDoors>true</dontDestroyWallsDoors>
    <prefabs>
      <GD_CommsConsole>
        <countPerHundredCells>2</countPerHundredCells>
        <minMaxRange>1~1</minMaxRange>
      </GD_CommsConsole>
      <GD_BandNodes>
        <countPerHundredCells>2</countPerHundredCells>
        <minMaxRange>1~2</minMaxRange>
      </GD_BandNodes>
      <GD_AncientTurret>
        <countPerTenEdgeCells>5</countPerTenEdgeCells>
        <minMaxRange>3~4</minMaxRange>
      </GD_AncientTurret>
      <GD_ResearchTable>
        <countPerTenEdgeCells>2</countPerTenEdgeCells>
        <minMaxRange>1~2</minMaxRange>
      </GD_ResearchTable>
      <GD_SystemRack>
        <countPerTenEdgeCells>2</countPerTenEdgeCells>
        <minMaxRange>2~3</minMaxRange>
      </GD_SystemRack>
	  <GD_SmallCase>
        <countPerTenEdgeCells>2</countPerTenEdgeCells>
        <minMaxRange>1~2</minMaxRange>
      </GD_SmallCase>
    </prefabs>
    <parts>
      <GD_ArchoMineDrone>
		<countRange>1~1</countRange>
	  </GD_ArchoMineDrone>
    </parts>
  </LayoutRoomDef>
  
  <LayoutRoomDef>
    <defName>GDCasesRoom</defName>
    <dontDestroyWallsDoors>true</dontDestroyWallsDoors>
    <prefabs>
      <GD_BigCase>
        <countPerHundredCells>1</countPerHundredCells>
        <minMaxRange>1~2</minMaxRange>
      </GD_BigCase>
      <GD_SmallCase>
        <countPerHundredCells>1</countPerHundredCells>
        <minMaxRange>1~2</minMaxRange>
      </GD_SmallCase>
    </prefabs>
    <floorTypes>
      <li>AncientConcrete</li>
    </floorTypes>
  </LayoutRoomDef>
  
  <LayoutRoomDef>
    <defName>GDJustRacksRoom</defName>
    <dontDestroyWallsDoors>true</dontDestroyWallsDoors>
    <prefabs>
      <GD_EmptyRacks>
        <countPerTenEdgeCells>2</countPerTenEdgeCells>
      </GD_EmptyRacks>
      <GD_SystemRack>
        <countPerHundredCells>2</countPerHundredCells>
      </GD_SystemRack>
    </prefabs>
    <floorTypes>
      <li>MetalTile</li>
    </floorTypes>
	<parts>
      <GD_ArchoMineDrone>
		<countRange>0~1</countRange>
	  </GD_ArchoMineDrone>
    </parts>
  </LayoutRoomDef>
  
  <!--===== 房间组件 =====-->
  <RoomPartDef>
    <defName>GD_ArchoMineDrone</defName>
    <workerClass>GD3.RoomPart_CornorDroneWithEdgeTerminal</workerClass>
  </RoomPartDef>

</Defs>
