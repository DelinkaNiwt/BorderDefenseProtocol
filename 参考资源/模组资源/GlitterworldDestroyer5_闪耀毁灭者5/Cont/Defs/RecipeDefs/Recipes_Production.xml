<Defs>
  
  <RecipeDef>
    <defName>Make_GDHealerSerum</defName>
    <label>make healer serum</label>
    <description>Make a one-use super-dose of mechanites.</description>
    <jobString>Making healer serum.</jobString>
    <effectWorking>Cremate</effectWorking>
    <soundWorking>Recipe_Cremate</soundWorking>
    <workAmount>10000</workAmount>
    <workSpeedStat>GeneralLaborSpeed</workSpeedStat>
	<recipeUsers>
      <li>FabricationBench</li>
    </recipeUsers>
    <ingredients>
      <li>
        <filter>
          <thingDefs>
            <li>PrecisionDeck</li>
          </thingDefs>
        </filter>
        <count>100</count>
      </li>
	  <li>
        <filter>
          <thingDefs>
            <li>MedicineUltratech</li>
          </thingDefs>
        </filter>
        <count>5</count>
      </li>
    </ingredients>
    <fixedIngredientFilter>
      <thingDefs>
        <li>PrecisionDeck</li>
		<li>MedicineUltratech</li>
      </thingDefs>
    </fixedIngredientFilter>
    <products>
      <MechSerumHealer>1</MechSerumHealer>
    </products>
	<researchPrerequisite>GD3_GiantCluster_Ultra</researchPrerequisite>
  </RecipeDef>
  
