  <ThingDef ParentName="BaseMakeableGrenade">
    <defName>Weapon_PsychicGrenade</defName>
    <label>marine psychic grenade</label>
    <description>A replica of the psychic grenade derived from the knowledge of the marine lancer. The explosion of the shock wave can disturb the enemy's psychic nerves, making them dizzy, vomiting, and in severe cases may fall or even die.\n\nDoes not damage friendly or neutral units.</description>
    <recipeMaker>
      <researchPrerequisite>GD3_Weapons</researchPrerequisite>
	  <recipeUsers Inherit="false">
		<li>FabricationBench</li>
	  </recipeUsers>
