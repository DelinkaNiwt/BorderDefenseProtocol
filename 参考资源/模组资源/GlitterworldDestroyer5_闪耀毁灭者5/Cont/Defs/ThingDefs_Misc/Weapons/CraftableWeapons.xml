<Defs>

  <!-- 反物质步枪 -->

  <ThingDef ParentName="BaseHumanMakeableGun">
    <defName>GD_AntimatterRifle</defName>
    <label>antimatter rifle</label>
    <description>Your colonists have accessed the black mechanoids' database to harness the power of antimatter annihilation, but how the black lancer manage this power remains a mystery. \n\n The rifle is capable of firing powerful antimatter rounds, but is somewhat weakened for safety reasons.</description>
    <techLevel>Spacer</techLevel>
    <graphicData>
      <texPath>AntimatterRifle</texPath>
      <graphicClass>Graphic_Single</graphicClass>
    </graphicData>
    <soundInteract>Interact_ChargeRifle</soundInteract>
	<smeltable>false</smeltable>
    <statBases>
      <WorkToMake>45000</WorkToMake>
      <Mass>4.6</Mass>
      <AccuracyTouch>0.55</AccuracyTouch>
      <AccuracyShort>0.64</AccuracyShort>
      <AccuracyMedium>0.55</AccuracyMedium>
      <AccuracyLong>0.45</AccuracyLong>
      <RangedWeapon_Cooldown>1.70</RangedWeapon_Cooldown>
    </statBases>
    <thingSetMakerTags>
      <li>RewardStandardLowFreq</li>
      <li>RewardStandardQualitySuper</li>
    </thingSetMakerTags>
    <weaponClasses>
      <li>RangedLight</li>
    </weaponClasses>
    <verbs>
      <li>
        <verbClass>Verb_Shoot</verbClass>
        <hasStandardCommand>true</hasStandardCommand>
        <defaultProjectile>Bullet_Antimatter</defaultProjectile>
        <warmupTime>1.0</warmupTime>
        <range>35.9</range>
        <ticksBetweenBurstShots>16</ticksBetweenBurstShots>
        <burstShotCount>3</burstShotCount>
        <soundCast>Shot_Autocannon</soundCast>
        <soundCastTail>GunTail_Medium</soundCastTail>
        <muzzleFlashScale>18</muzzleFlashScale>
		<forcedMissRadius>1.5</forcedMissRadius>
        <ai_AvoidFriendlyFireRadius>3</ai_AvoidFriendlyFireRadius>
      </li>
    </verbs>
    <tools>
      <li>
        <label>point</label>
        <capacities>
          <li>Stab</li>
        </capacities>
        <power>21</power>
        <cooldownTime>2</cooldownTime>
		<armorPenetration>0.9</armorPenetration>
      </li>
      <li>
        <label>edge</label>
        <capacities>
          <li>Cut</li>
        </capacities>
        <power>16</power>
        <cooldownTime>2</cooldownTime>
		<armorPenetration>0.9</armorPenetration>
      </li>
    </tools>
	<recipeMaker>
		<researchPrerequisite>GD3_Weapons</researchPrerequisite>
		<recipeUsers>
			<li>FabricationBench</li>
		</recipeUsers>
		<skillRequirements>
			<Crafting>12</Crafting>
		</skillRequirements>
	</recipeMaker>
	<costList>
		<Steel>80</Steel>
	    <Plasteel>90</Plasteel>
	    <BlackPersonaData>3</BlackPersonaData>
        <ComponentIndustrial>5</ComponentIndustrial>
	    <ComponentSpacer>4</ComponentSpacer>
	</costList>
  </ThingDef>
  
