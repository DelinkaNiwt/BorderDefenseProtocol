	<!-- 燃烧弹火箭炮 -->
	<ThingDef ParentName="BaseHumanMakeableGun">
    <defName>GD_IncendiaryRocket</defName>
    <label>simple incendiary rocket launcher</label>
    <description>The process is simple and inexpensive, and although it is not very reliable it does not prevent it from being a good choice for soldiers during offensive battles. The high temperature generated by \n\nCan also damage the power core of some heavy armor units with relative ease.</description>
    <techLevel>Industrial</techLevel>
	<tickerType>Normal</tickerType>
	<smeltable>false</smeltable>
    <graphicData>
      <texPath>IncendiaryRocket</texPath>
      <graphicClass>Graphic_Single</graphicClass>
	  <drawSize>1.5</drawSize>
    </graphicData>
    <statBases>
      <WorkToMake>5000</WorkToMake>
      <Mass>4.6</Mass>
    </statBases>
    <weaponClasses>
      <li>RangedHeavy</li>
    </weaponClasses>
    <tradeTags>
      <li>ExoticMisc</li>
      <li>WeaponRanged</li>
    </tradeTags>
	<relicChance>0</relicChance>
    <verbs>
      <li>
        <verbClass>Verb_ShootOneUse</verbClass>
        <hasStandardCommand>true</hasStandardCommand>
        <defaultProjectile>GD_Bullet_IncendiaryRocket</defaultProjectile>
        <forcedMissRadius>0.9</forcedMissRadius>
        <warmupTime>2.5</warmupTime>
        <ai_AvoidFriendlyFireRadius>5</ai_AvoidFriendlyFireRadius>
        <range>35.9</range>
        <soundCast>InfernoCannon_Fire</soundCast>
        <soundCastTail>GunTail_Heavy</soundCastTail>
        <onlyManualCast>true</onlyManualCast>
        <stopBurstWithoutLos>false</stopBurstWithoutLos>
        <targetParams>
          <canTargetLocations>true</canTargetLocations>
        </targetParams>
        <muzzleFlashScale>14</muzzleFlashScale>
      </li>
    </verbs>
    <tools>
      <li>
        <label>handle</label>
        <capacities>
          <li>Blunt</li>
        </capacities>
        <power>21</power>
        <cooldownTime>2.2</cooldownTime>
      </li>
    </tools>
	<recipeMaker>
		<researchPrerequisite>GD3_StrangeWeapons</researchPrerequisite>
	</recipeMaker>
	<costList>
		<Steel>60</Steel>
	    <Chemfuel>40</Chemfuel>
        <ComponentIndustrial>5</ComponentIndustrial>
	</costList>
	<comps>
	<li Class="CompProperties_Explosive">
        <explosiveRadius>3.9</explosiveRadius>
        <explosiveDamageType>Bomb</explosiveDamageType>
        <requiredDamageTypeToExplode>Flame</requiredDamageTypeToExplode>
    </li>
	</comps>
  </ThingDef>
  
