  <!-- 数据库 -->
  <ThingDef ParentName="GDBlackBaseBuildingBase">
    <defName>GD_BlackMechComputer</defName>
    <label>deactivated computer</label>
    <description>A computer used by the black-clad mechanoid for temporary data storage and analysis, which has been physically damaged to prevent data leakage. However, with the technology of mechanoid hive, as long as some residual data or hardware fragments can be collected, useful information can be restored.</description>
    <graphicData>
      <texPath>Buildings/AncientUrbanRuins/Computation</texPath>
      <graphicClass>Graphic_Single</graphicClass>
      <drawSize>(2.4,2.4)</drawSize>
    </graphicData>
    <size>(2,2)</size>
    <rotatable>false</rotatable>
    <statBases>
      <MaxHitPoints>200</MaxHitPoints>
      <Flammability>0.5</Flammability>
    </statBases>
    <castEdgeShadows>false</castEdgeShadows>
    <terrainAffordanceNeeded>Heavy</terrainAffordanceNeeded>
    <building>
      <destroySound>BuildingDestroyed_Metal_Big</destroySound>
    </building>
    <costList>
      <Steel>100</Steel>
    </costList>
    <killedLeavings>
      <ChunkSlagSteel>1</ChunkSlagSteel>
      <Steel>25</Steel>
    </killedLeavings>
	<hasInteractionCell>True</hasInteractionCell>
    <interactionCellOffset>(0,0,-1)</interactionCellOffset>
    <altitudeLayer>Building</altitudeLayer>
    <canBeUsedUnderRoof>false</canBeUsedUnderRoof>
    <fillPercent>0.60</fillPercent>
    <passability>PassThroughOnly</passability>
    <pathCost>50</pathCost>
    <tickerType>Normal</tickerType>
    <comps>
      <li>
        <compClass>GD3.CompBlackComputer</compClass>
      </li>
      <li Class="CompProperties_Hackable">
        <defence>12000</defence>
        <effectHacking>HackingTerminal</effectHacking>
        <lockoutDurationHoursRange>6~8</lockoutDurationHoursRange>
        <hackedInspectString>Hacked.</hackedInspectString>
        <showProgressAfterHackCompletion>false</showProgressAfterHackCompletion>
        <intellectualSkillPrerequisite>6</intellectualSkillPrerequisite>
        <notHackedInspectString>Hack for information.</notHackedInspectString>
        <hackedMessage>{HACKER_labelShort} has finished hacking {SUBJECT_labelNoParenthesisDef}.</hackedMessage>
      </li>
      <li Class="CompProperties_Glower">
        <glowRadius>1.5</glowRadius>
        <glowColor>(144,238,144,155)</glowColor>
      </li>
    </comps>
  </ThingDef>
  
