  <!-- 通用训练器 -->
  
  <ThingDef ParentName="MechHelpCallerBase">
    <defName>UniversalTrainer</defName>
    <label>universal trainer</label>
    <description>A special skill trainer that can upgrade all skills of the user by one level.</description>
    <graphicData>
      <texPath>Things/Item/Special/MechSerumNeurotrainer</texPath>
      <graphicClass>Graphic_Single</graphicClass>
	  <drawSize>1.2</drawSize>
    </graphicData>
    <stackLimit>5</stackLimit>
    <statBases>
      <MarketValue>1300</MarketValue>
    </statBases>
    <thingCategories>
      <li>Items</li>
    </thingCategories>
    <tradeability>Sellable</tradeability>
    <comps>
      <li Class="CompProperties_Usable">
        <useJob>UseItem</useJob>
        <useLabel>Use universal trainer</useLabel>
        <useDuration>300</useDuration>
      </li>
      <li Class="CompProperties_UseEffectPlaySound">
        <soundOnUsed>MechSerumUsed</soundOnUsed>
      </li>
	  <li Class="CompProperties_UseEffect">
        <compClass>GD3.CompUseEffect_Trainer</compClass>
      </li>
    </comps>
  </ThingDef>
  
  <!-- Missions -->
  <!-- 生锈的尸体 -->
  
  <ThingDef ParentName="MechResourceBase">
    <defName>GD_MechCorpse</defName>
    <label>rusty corpse</label>
    <description>The body of a scyther was gently covered with its hat and a bouquet of flowers. \n\nThe source of this corpse is suspicious, perhaps we can check if the communication system on its body is still functioning.\n\nYou can melt it to recover a little steel.</description>
    <graphicData>
      <texPath>GD_MechCorpse</texPath>
	  <drawSize>1.6</drawSize>
      <graphicClass>Graphic_Single</graphicClass>
	  <onGroundRandomRotateAngle>50</onGroundRandomRotateAngle>
    </graphicData>
	<soundInteract>Metal_Drop</soundInteract>
    <soundDrop>Metal_Drop</soundDrop>
    <stackLimit>1</stackLimit>
	<costList>
      <Plasteel>50</Plasteel>
	  <Steel>100</Steel>
    </costList>
	<smeltable>true</smeltable>
    <statBases>
      <MarketValue>0</MarketValue>
	  <MaxHitPoints>500</MaxHitPoints>
	  <Mass>50</Mass>
      <Flammability>0</Flammability>
    </statBases>
	<tradeability>None</tradeability>
	<comps>
      <li Class="GD3.CompProperties_CompAnalyzableUnlockScript">
        <analysisID>543548361</analysisID>

        <!-- Analyzable -->

        <analysisDurationHours>0.5</analysisDurationHours>
        <destroyedOnAnalyzed>false</destroyedOnAnalyzed>
        <completedLetterLabel>Black Mechanoid Hive Discovered</completedLetterLabel>
        <completedLetter>The communication system activated, and we were able to contact an anonymous mechanoid, but he shut down the communication as soon as he received our first hello. Maybe we can get back in touch with them some other way. \n\nYou have found the faction "Black Mechanoid Hive" and can contact them on the mech-communication station.</completedLetter>
        <completedLetterDef>PositiveEvent</completedLetterDef>

        <!-- Interactable -->

        <activateTexPath>UI/Icons/Study</activateTexPath>

        <activateLabelString>Analyze...</activateLabelString>
        <activateDescString>Analyzing the rusty corpse.</activateDescString>
        <jobString>Analyze rusty corpse</jobString>
        <guiLabelString>Choose who should analyze this</guiLabelString>
        <inspectString>Can be analyzed by a colonist.</inspectString>

        <targetingParameters>
          <canTargetBuildings>false</canTargetBuildings>
          <canTargetAnimals>false</canTargetAnimals>
          <canTargetMechs>false</canTargetMechs>
          <onlyTargetControlledPawns>true</onlyTargetControlledPawns>
        </targetingParameters>
      </li>
	  <li Class="GD3.CompProperties_SendCorpse" />
    </comps>
  </ThingDef>
  
  <!-- 剧毒垃圾 -->
  
  <ThingDef ParentName="ResourceBase">
    <defName>Wastepack_Red</defName>
    <label>highly toxic wastepack</label>
    <description>Extremely unstable and highly toxic mixtures, once left the special container, will completely dissolve at a very fast rate. Getting rid of it under the radar would be a very difficult thing to do.</description>
    <possessionCount>5</possessionCount>
    <graphicData>
      <texPath>Items/ToxWastePack</texPath>
      <graphicClass>Graphic_StackCount</graphicClass>
    </graphicData>
    <soundInteract>Metal_Drop</soundInteract>
    <soundDrop>Standard_Drop</soundDrop>
    <stackLimit>5</stackLimit>
    <statBases>
      <Beauty>-80</Beauty>
      <MarketValue>0</MarketValue>
      <Mass>6</Mass>
      <Flammability>1</Flammability>
      <DeteriorationRate>50</DeteriorationRate>
    </statBases>
    <thingCategories>
      <li>ItemsMisc</li>
    </thingCategories>
    <comps>
      <li Class="CompProperties_GasOnDamage">
        <type>ToxGas</type>
        <damageFactor>6</damageFactor>
        <useStackCountAsFactor>true</useStackCountAsFactor>
      </li>
      <li Class="CompProperties_Dissolution">
        <dissolutionAfterDays>1</dissolutionAfterDays>
        <dissolutinFactorIndoors>0.5</dissolutinFactorIndoors>
        <dissolutionFactorRain>10</dissolutionFactorRain>
      </li>
      <li Class="CompProperties_DissolutionEffectPollution">
        <cellsToPollutePerDissolution>30</cellsToPollutePerDissolution>
        <tilePollutionPerDissolution>0.0020</tilePollutionPerDissolution>
        <waterTilePollutionFactor>8</waterTilePollutionFactor>
      </li>
      <li>
        <compClass>CompDissolutionEffect_Goodwill</compClass>
      </li>
    </comps>
    <tickerType>Normal</tickerType>
  </ThingDef>
  
  <!-- 次生核心（半成品）-->
  
  <ThingDef ParentName="MechResourceBase">
    <defName>GD_Subcore</defName>
    <label>subcore (semi-finished)</label>
    <description>A subcore that's been almost completely rewritten, and somehow it can't even start up stably. We need a researcher to do the analysis. \n\nThere may be some accidents during the research.\n\nNote: If you are unable to return to the subcore after completing your research, you will be judged to have completed the task by violently destroying it and then retaking it.</description>
    <graphicData>
      <texPath>Items/GD_Subcore</texPath>
	  <drawSize>1</drawSize>
      <graphicClass>Graphic_Single</graphicClass>
    </graphicData>
	<soundInteract>Metal_Drop</soundInteract>
    <soundDrop>Metal_Drop</soundDrop>
    <stackLimit>1</stackLimit>
	<tickerType>Normal</tickerType>
    <statBases>
      <MarketValue>0</MarketValue>
	  <MaxHitPoints>500</MaxHitPoints>
	  <Mass>5</Mass>
      <Flammability>0</Flammability>
    </statBases>
	<tradeability>None</tradeability>
	<comps>
      <li Class="GD3.CompProperties_CompAnalyzableSubcore">
        <analysisID>542148361</analysisID>

        <!-- Analyzable -->
		<analysisRequiredRange>10</analysisRequiredRange>
        <analysisDurationHours>0.5</analysisDurationHours>
        <destroyedOnAnalyzed>false</destroyedOnAnalyzed>
        <completedLetterLabel>Subcore rewrite complete</completedLetterLabel>
        <completedLetter>The subcore has been studied, and soon it will be sent back to the black mechanoid hive in a teleport.</completedLetter>
        <completedLetterDef>PositiveEvent</completedLetterDef>

        <!-- Interactable -->

        <activateTexPath>UI/Icons/Study</activateTexPath>

        <activateLabelString>Analyze...</activateLabelString>
        <activateDescString>Analyzing the subcore.</activateDescString>
        <jobString>Analyze subcore</jobString>
        <guiLabelString>Choose who should analyze this</guiLabelString>
        <inspectString>Can be analyzed by a colonist.</inspectString>

        <targetingParameters>
          <canTargetBuildings>false</canTargetBuildings>
          <canTargetAnimals>false</canTargetAnimals>
          <canTargetMechs>false</canTargetMechs>
          <onlyTargetControlledPawns>true</onlyTargetControlledPawns>
        </targetingParameters>
      </li>
    </comps>
  </ThingDef>
  
  <!-- 密钥 -->
  
  <ThingDef ParentName="MechResourceBase">
    <defName>GD_ServerKey</defName>
    <label>secret key</label>
    <description>Secret key used to encrypt and decrypt data. Right-click activation to give you access to the server.</description>
    <graphicData>
      <texPath>Items/ServerKey</texPath>
	  <drawSize>1.6</drawSize>
      <graphicClass>Graphic_Single</graphicClass>
	  <onGroundRandomRotateAngle>50</onGroundRandomRotateAngle>
    </graphicData>
	<soundInteract>Metal_Drop</soundInteract>
    <soundDrop>Metal_Drop</soundDrop>
    <stackLimit>1</stackLimit>
	<costList>
      <Plasteel>50</Plasteel>
	  <Steel>100</Steel>
    </costList>
	<smeltable>true</smeltable>
    <statBases>
      <MarketValue>0</MarketValue>
	  <MaxHitPoints>500</MaxHitPoints>
	  <Mass>0.5</Mass>
      <Flammability>0</Flammability>
    </statBases>
	<tradeability>None</tradeability>
	<comps>
      <li Class="CompProperties_Usable">
        <useJob>TriggerObject</useJob>
        <useLabel>activate</useLabel>
        <useDuration>60</useDuration>
        <ignoreOtherReservations>true</ignoreOtherReservations>
      </li>
	  <li Class="CompProperties_UseEffect">
        <compClass>GD3.CompUseEffect_Key</compClass>
      </li>
    </comps>
  </ThingDef>

</Defs>
