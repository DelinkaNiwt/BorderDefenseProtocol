  <AnimationDef>
    <defName>MosquitoAncientFlying_east</defName>
    <durationTicks>120</durationTicks>
	<startOnRandomTick>false</startOnRandomTick>
    <keyframeParts>
      <li>
        <key>Body</key>
        <value>
          <workerType>AnimationWorker_Keyframes</workerType>
          <keyframes>
            <li>
              <tick>0</tick>
              <graphicState>MosquitoAncientFlying_east</graphicState>
            </li>
          </keyframes>
        </value>
      </li>
    </keyframeParts>
  </AnimationDef>
  <GraphicStateDef>
    <defName>MosquitoAncientFlying_east</defName>
