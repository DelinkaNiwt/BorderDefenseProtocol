	<xpath>/Defs/ThingDef[defName="UnstablePowerCell"]/researchPrerequisites</xpath>
	<value>
		<researchPrerequisites>
		  <li>GD3_GiantCluster_Medium</li>
		</researchPrerequisites>
	</value>
  </Operation>
  
  <Operation Class="PatchOperationReplace">
	<xpath>/Defs/ThingDef[defName="UnstablePowerCell"]/costList</xpath>
	<value>
		<costList>
		  <Steel>80</Steel>
		  <ComponentIndustrial>5</ComponentIndustrial>
		</costList>
	</value>
  </Operation>
  
  <Operation Class="PatchOperationReplace">
	<xpath>/Defs/ThingDef[defName="ShieldGeneratorBullets"]/comps</xpath>
	<value>
		<comps>
		  <li Class="CompProperties_ProjectileInterceptor">
			<radius>20</radius>
			<interceptGroundProjectiles>true</interceptGroundProjectiles>
			<interceptNonHostileProjectiles>false</interceptNonHostileProjectiles>
			<color>(0.4, 0.4, 0.4)</color>
			<reactivateEffect>BulletShieldGenerator_Reactivate</reactivateEffect>
			<activeSound>BulletShield_Ambience</activeSound>
			<disarmedByEmpForTicks>1080</disarmedByEmpForTicks>
			<chargeIntervalTicks>600000</chargeIntervalTicks>
			<chargeDurationTicks>60000</chargeDurationTicks>
		  </li>
		  <li Class="CompProperties_WakeUpDormant">
			<wakeUpSound>MechanoidsWakeUp</wakeUpSound>
		  </li>
		</comps>
	</value>
  </Operation>
  
</Patch>