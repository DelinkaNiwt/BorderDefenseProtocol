<?xml version="1.0" encoding="utf-8"?>
<Patch>

    <Operation Class="PatchOperationFindMod">
		<mods>
			<li>Mechanoid Modifications</li>
		</mods>
		<match Class="PatchOperationSequence">
		  <success>Always</success>
		  <operations>
			<li Class="PatchOperationAdd">
				<xpath>Defs/RecipeDef[@Name="InstallModificationBaseAll"]/recipeUsers</xpath>
				<value>
				  <li>Mech_Observer</li>	 
				  <li>Mech_CataphractCentipede</li>
				  <li>Mech_MarineLancer</li>
				  <li>Mech_ReconScyther</li>
				  <li>Mech_Firefly</li>	  	
				  <li>Mech_CentipedeSword</li>
				</value>
			</li>
			<li Class="PatchOperationAdd">
				<xpath>Defs/RecipeDef[@Name="RemoveModificationBase"]/recipeUsers</xpath>
				<value>
				  <li>Mech_Observer</li>
				  <li>Mech_CataphractCentipede</li>
				  <li>Mech_MarineLancer</li>
				  <li>Mech_ReconScyther</li>
				  <li>Mech_Firefly</li>	
				  <li>Mech_CentipedeSword</li>
				</value>
			</li>
		  </operations>	  
	  </match>
	</Operation>
	
</Patch>