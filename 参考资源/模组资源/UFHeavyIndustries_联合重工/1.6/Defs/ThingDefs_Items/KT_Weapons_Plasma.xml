<?xml version="1.0" encoding="utf-8"?>

<Defs> 
   <ThingDef ParentName="KT_BaseMakeableGun" Name="KT_Plasma_Pistol">
    <defName>KT_Plasma_Pistol</defName>
    <label>KT_Plasma_Pistol</label>
    <description>KT_Plasma_Pistol</description>
    <graphicData>
      <texPath>Things/Weapons/KT_Plasma_Pistol</texPath>
      <graphicClass>Graphic_Single</graphicClass>
    </graphicData>
    <soundInteract>Interact_Rifle</soundInteract>
    <thingSetMakerTags><li>RewardStandardQualitySuper</li></thingSetMakerTags>
    <tradeability>None</tradeability>
    <generateAllowChance>0</generateAllowChance>
    <generateCommonality>0</generateCommonality>
    <relicChance>0</relicChance>
    <statBases>
      <WorkToMake>35000</WorkToMake>
      <Mass>5</Mass>
      <AccuracyTouch>0.75</AccuracyTouch>
      <AccuracyShort>0.65</AccuracyShort>
      <AccuracyMedium>0.55</AccuracyMedium>
      <AccuracyLong>0.45</AccuracyLong>
      <RangedWeapon_Cooldown>1.2</RangedWeapon_Cooldown>
    </statBases>
    <costList>
      <Plasteel>80</Plasteel>
      <Steel>150</Steel>
	  <ComponentIndustrial>3</ComponentIndustrial>
	  <ComponentSpacer>1</ComponentSpacer>
    </costList>
    <recipeMaker>
      <researchPrerequisite>KT_Base_t3_plasma_weapon</researchPrerequisite>
      <skillRequirements>
        <Crafting>9</Crafting>
      </skillRequirements>
      <recipeUsers Inherit="True">
        <li>KT_Workbench</li>
      </recipeUsers>
      <displayPriority>500</displayPriority>
    </recipeMaker>
    <techLevel>Spacer</techLevel>

    <weaponClasses>
      <li>RangedLight</li>
    </weaponClasses>
	<weaponTags>
	  <li>KT_weapon</li>
    </weaponTags>
	<comps>
	  <li Class="SRA.CompProperties_WeaponRenderDynamic">
		<TexturePath>Things/Weapons/KT_Plasma_Pistol_light</TexturePath>
		<totalFrames>1</totalFrames>
		<ticksPerFrame>1</ticksPerFrame>
	  </li>
    </comps>
	<drawerType>MapMeshAndRealTime</drawerType>
	
    <verbs>
      <li>
        <verbClass>Verb_Shoot</verbClass>
        <hasStandardCommand>true</hasStandardCommand>
        <defaultProjectile>Bullet_KT_Plasma_Pistol</defaultProjectile>
        <warmupTime>0.6</warmupTime>
        <range>28</range>
		<burstShotCount>1</burstShotCount>
        <soundCast>KTPLASMACANNONRound</soundCast>
        <soundCastTail>GunTail_Light</soundCastTail>
        <muzzleFlashScale>35</muzzleFlashScale>
      </li>
    </verbs>
	<modExtensions>
      <li Class="MuzzleFlash.MuzzleFlashProps" MayRequire="IssacZhuang.MuzzleFlash">
        <def>MF_ChargedMuzzleFalsh</def>
        <drawSize>(1.1)</drawSize>
        <offsets>
          <li>(0.2,0)</li>
        </offsets>
        <isAlternately>true</isAlternately>
      </li>
    </modExtensions>
    <tools>
      <li>
        <label>barrels</label>
        <capacities>
          <li>Blunt</li>
        </capacities>
        <power>12</power>
        <cooldownTime>1.1</cooldownTime>
      </li>
    </tools>
  </ThingDef>
  
  <ThingDef ParentName="BaseBullet">
    <defName>Bullet_KT_Plasma_Pistol</defName>
    <label>Bullet_KT_Plasma_Pistol</label>
    <thingClass>SRA.Projectile_MultiExplosive</thingClass>
    <graphicData>
      <texPath>Things/Projectile/Bullet_kt_plasma</texPath>
      <graphicClass>Graphic_Single</graphicClass>
    </graphicData>
    <projectile>
      <damageDef>KTBLUEBomb</damageDef>
        <explosionRadius>1.5</explosionRadius>
        <speed>120</speed>
        <damageAmountBase>60</damageAmountBase>
        <arcHeightFactor>0</arcHeightFactor>
        <soundExplode>Explosion_Rocket</soundExplode>
		<flyOverhead>false</flyOverhead>
		<armorPenetrationBase>1.0</armorPenetrationBase>
		<stoppingPower>1.1</stoppingPower>
    </projectile>
	<modExtensions>
		  <li Class="SRA.TailBulletDef">
       		   <tailFleckDef>KT_Fleck_blue_particle_Tail_II</tailFleckDef>
      	 	   <fleckMakeFleckTickMax>10</fleckMakeFleckTickMax><!-- 疑似无效 -->
			   <fleckDelayTicks>5</fleckDelayTicks><!-- 出膛后多久出现轨迹 -->
			   <fleckMakeFleckNum>1</fleckMakeFleckNum>
     	    </li>
          <li Class="SRA.MultiExplosiveExtension">
         <multiexplosions>
          <li>
            <radius>1.5</radius>
            <damageDef>KTBLUEBomb</damageDef>
            <damageAmount>60</damageAmount>
            <armorPenetration>1.0</armorPenetration>
            <explosionSound>Explosion_Rocket</explosionSound>
            <explosionDamageFalloff>true</explosionDamageFalloff><!-- 默认true -->
            <onlyAntiHostile>false</onlyAntiHostile> <!-- 智能弹药：这个爆炸只伤害敌对目标，默认false -->
            <!-- 现阶段就支持这么多参数 -->
          </li>
		  <li>
			<radius>2</radius>
			<damageDef>EMP</damageDef>
			<damageAmount>50</damageAmount>
			<armorPenetration>8</armorPenetration>
			<explosionSound>Explosion_EMP</explosionSound>
			<explosionDamageFalloff>true</explosionDamageFalloff>
			<onlyAntiHostile>true</onlyAntiHostile>
		  </li>
        </multiexplosions>
        <bulletLaunches>
          <li>
            <projectileDef>KT_Bullet_shield_overloader</projectileDef>
            <bulletCount>2</bulletCount>
            <angleRange>120</angleRange>
            <distanceRange>
              <min>1</min>
              <max>1</max>
            </distanceRange>
          </li>
        </bulletLaunches>
      </li>
    </modExtensions>
  </ThingDef>
  
  <ThingDef ParentName="BaseBullet">
    <defName>KT_Bullet_shield_overloader</defName>
    <label>KT_Bullet_shield_overloader</label>
    <thingClass>SRA.Projectile_MultiExplosive</thingClass>
    <graphicData>
      <texPath>Things/Mote/KTempty</texPath>
      <graphicClass>Graphic_Single</graphicClass>
    </graphicData>
    <projectile>
      <damageDef>EMP</damageDef>
        <explosionRadius>1</explosionRadius>
        <speed>80</speed>
        <damageAmountBase>640</damageAmountBase>
        <arcHeightFactor>0</arcHeightFactor>
        <soundExplode>KTNONESOUND</soundExplode>
		<flyOverhead>false</flyOverhead>
		<armorPenetrationBase>1</armorPenetrationBase>
    </projectile>
	<modExtensions>
        <li Class="SRA.MultiExplosiveExtension">
      </li>
    </modExtensions>
   </ThingDef>
</Defs>