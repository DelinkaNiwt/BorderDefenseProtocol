<?xml version="1.0" encoding="utf-8" ?>
<Defs>
	<!--涡喷飞行背包-->
	<ThingDef ParentName="ApparelNoQualityBase">
		<defName>TurbojetBackpack</defName>
		<label>"War Angel" Turbojet Flight Backpack</label>
		<description>This jetpack was originally designed to promote family harmony in multi-species Pact Nations. When flight-capable species marry non-flight-capable species, it enables the latter to accompany their partners in flight. However, in the RimWorld, a certain indigenous religion has developed a keen interest in it.\n\n&lt;color=#FFAA00&gt;&lt;i&gt;The jetpack offers multiple assisted flight modes and features a built-in special shield that helps the user immune to melee attacks and extreme terrain damage (immune to damage below 8). More importantly, it includes an additional storage compartment to help users carry items such as quick snacks, rare specimens, and cool rocks.&lt;/i&gt;&lt;/color&gt;\n\n&lt;color=#FFAA00&gt;&lt;i&gt;Extremely high world map movement speed&lt;/i&gt;&lt;/color&gt;</description>
		<!--材质设置-->
		<tickerType>Normal</tickerType>
		<graphicData>
			<drawSize>(2,2)</drawSize>
			<shaderType>CutoutComplex</shaderType>
			<texPath>Things/Apparel/KT_Jetpack/KT_Jetpack_north</texPath>
			<graphicClass>Graphic_Single</graphicClass>
		</graphicData>
		<!--基本属性-->
		<techLevel>Spacer</techLevel>
		<statBases>
			<Mass>35</Mass>
			<EquipDelay>5</EquipDelay>
			<WorkToMake>10000</WorkToMake>
			<Flammability>0</Flammability>
			<MaxHitPoints>1000</MaxHitPoints>
			<ArmorRating_Heat>1</ArmorRating_Heat>
			<ArmorRating_Sharp>1</ArmorRating_Sharp>
			<ArmorRating_Blunt>1</ArmorRating_Blunt>
			<DeteriorationRate>0</DeteriorationRate>
		</statBases>
		<tradeTags>
			<li>Clothing</li>
		</tradeTags>
		<thingCategories>
			<li>ApparelUtility</li>
		</thingCategories>
		<equippedStatOffsets>
			<MoveSpeed>5</MoveSpeed>
			<MeleeDodgeChance>10</MeleeDodgeChance>
			<CarryingCapacity>50</CarryingCapacity>
			<AdditionalQualityCarry>100</AdditionalQualityCarry>
		</equippedStatOffsets>
		<!--制造材料-->
		<smeltable>false</smeltable>
		<costList>
			<KT_steel>60</KT_steel>
			<Uranium>50</Uranium>
			<ComponentSpacer>1</ComponentSpacer>
			<ComponentIndustrial>6</ComponentIndustrial>
		</costList>
		<!--配方属性-->
		<recipeMaker>
			<!--制造设置-->
			<workSkill>Crafting</workSkill>
			<displayPriority>1131</displayPriority>
			<workSpeedStat>GeneralLaborSpeed</workSpeedStat>
			<unfinishedThingDef>UnfinishedPack</unfinishedThingDef>
			<recipeUsers Inherit="False">
				<li>KT_SWorkbench</li>
			</recipeUsers>
			<!--材质设置-->
			<effectWorking>Smith</effectWorking>
			<soundWorking>Recipe_Machining</soundWorking>
			<useIngredientsForColor>false</useIngredientsForColor>
			<!--科技需求-->
			<skillRequirements>
				<Crafting>10</Crafting>
			</skillRequirements>
			<researchPrerequisites>
				<li>KT_Jetpack</li>
			</researchPrerequisites>
		</recipeMaker>
		<!--参数拓展-->
		<modExtensions>
			<li Class="TurbojetBackpack.TurbojetExtension">
				<!--远行速度-->
				<worldMapSpeedFactor>150</worldMapSpeedFactor>
				<!--飞行参数-->
				<flightHeight>3</flightHeight>
				<takeoffSpeed>0.05</takeoffSpeed>
				<landingSpeed>0.05</landingSpeed>
				<flightMoveSpeed>25</flightMoveSpeed>
				<!--飞行起伏-->
				<hoverFrequency>0.3</hoverFrequency>
				<hoverAmplitude>0.15</hoverAmplitude>
				<!--飞行烟尘-->
				<flightMote>TurbojetSmoke</flightMote>
				<flightSmokeScaleMin>5</flightSmokeScaleMin>
				<flightSmokeScaleMax>7</flightSmokeScaleMax>
				<!--怠速烟雾-->
				<standbyMote>TurbojetSmoke</standbyMote>
				<standbyMoteScale>1~1</standbyMoteScale>
				<standbyMoteInterval>1</standbyMoteInterval>
				<!--阴影效果-->
				<shadowMote>TurbojetShadow</shadowMote>
				<shadowMoteInterval>1</shadowMoteInterval>
				<!--图标路径-->
				<flightModeIconPath>KT_UI/UI_TurbojetHover</flightModeIconPath>
				<combatModeIconPath>KT_UI/UI_TurbojetStrike</combatModeIconPath>
				<!--喷流粒子-->
				<thrustMoteEffects>
					<li>
						<moteDef>Mote_TurbojetFlame_Red</moteDef>
						<spread>1</spread>
						<speed>10~10</speed>
						<scale>0.3~0.3</scale>
						<interval>1</interval>
					</li>
					<li>
						<moteDef>Mote_TurbojetFlame_Orange</moteDef>
						<spread>1</spread>
						<speed>10~10</speed>
						<scale>0.5~0.5</scale>
						<interval>1</interval>
					</li>
					<li>
						<moteDef>Mote_TurbojetFlame_White</moteDef>
						<spread>1</spread>
						<speed>10~10</speed>
						<scale>0.7~0.7</scale>
						<interval>1</interval>
					</li>
				</thrustMoteEffects>
				<jumpMoteEffects>
					<li>
						<moteDef>Mote_TurbojetFlame_Red</moteDef>
						<spread>1</spread>
						<speed>10~10</speed>
						<scale>1.3~1.3</scale>
						<interval>1</interval>
					</li>
					<li>
						<moteDef>Mote_TurbojetFlame_Orange</moteDef>
						<spread>1</spread>
						<speed>10~10</speed>
						<scale>1.5~1.5</scale>
						<interval>1</interval>
					</li>
					<li>
						<moteDef>Mote_TurbojetFlame_White</moteDef>
						<spread>1</spread>
						<speed>10~10</speed>
						<scale>1.7~1.7</scale>
						<interval>1</interval>
					</li>
				</jumpMoteEffects>
				<!--喷流位置-->
				<jetsVertical>
					<li>
						<angle>195</angle>
						<offset>(-0.8,0,-0.7)</offset>
					</li>
					<li>
						<angle>165</angle>
						<offset>(0.8,0,-0.7)</offset>
					</li>
				</jetsVertical>
				<jetsHorizontal>
					<li>
						<angle>195</angle>
						<offset>(-0.9,0,-0.6)</offset>
					</li>
				</jetsHorizontal>
			</li>
		</modExtensions>
		<!--工作组件-->
		<comps>
			<!--战斗开关-->
			<li Class="TurbojetBackpack.CompProperties_TurbojetFlight" />
			<!--涡喷跳跃-->
			<li Class="TurbojetBackpack.CompProperties_ApparelGiveAbility">
				<abilityDef>TurbojetJump_Ability</abilityDef>
			</li>
			<!--涡喷冲刺-->
			<li Class="TurbojetBackpack.CompProperties_ApparelGiveAbility">
				<abilityDef>TurbojetDash_Ability</abilityDef>
			</li>
			<!--气动护盾-->
    		<li Class="TurbojetBackpack.CompProperties_TurbojetShield">
				<!--材质设置-->
				<minDrawSize>2.4</minDrawSize>
				<maxDrawSize>2.5</maxDrawSize>
				<shieldColor>(1,1,1,1)</shieldColor>
				<shieldTexPath>Things/Apparel/KT_Jetpack/TurbojetShieldBubble</shieldTexPath>
				<!--护盾参数-->
				<maxEnergy>800</maxEnergy>
				<maxDamageCap>9999</maxDamageCap>
				<energyRegenRate>1</energyRegenRate>
				<resetDelayTicks>1000</resetDelayTicks>
				<minDamageThreshold>8</minDamageThreshold>
			</li>
			<!--自动炮塔-->
			<!--li Class="CompProperties_CauseHediff_Apparel">
				<hediff>KT_JETPACK_TURRET</hediff>
				<part>Body</part>
			</li-->
		</comps>
		<!--穿戴外观-->
		<apparel>
			<!--穿戴属性-->
			<wearPerDay>0</wearPerDay>
			<careIfDamaged>false</careIfDamaged>
			<careIfWornByCorpse>false</careIfWornByCorpse>
			<countsAsClothingForNudity>false</countsAsClothingForNudity>
			<!--材质设置-->
			<scoreOffset>3</scoreOffset>
			<useWornGraphicMask>true</useWornGraphicMask>
			<wornGraphicPath>Things/Apparel/KT_Jetpack/KT_Jetpack</wornGraphicPath>
			<tags>
				<li>PackJump</li>
			</tags>
			<layers>
				<li>Belt</li>
			</layers>
			<bodyPartGroups>
				<li>Waist</li>
			</bodyPartGroups>
			<drawData>
	    		<dataEast>
					<layer>999</layer>
            	</dataEast>
            	<dataWest>
					<layer>999</layer>	
           	 	</dataWest>
				<dataNorth>
					<layer>999</layer>	
            	</dataNorth>
				<dataSouth>
					<layer>-10</layer>	
            	</dataSouth>
     		</drawData>

			<wornGraphicData>
				<renderUtilityAsPack>true</renderUtilityAsPack>
				<north>
					<offset>(0,0)</offset>
				</north>
				<south>
					<offset>(0,0.1)</offset>
				</south>
				<east>
					<offset>(-0.7,0.05)</offset>
				</east>
				<west>
					<offset>(0.7,0.05)</offset>
				</west>
				<male>
					<scale>(1.5,1.5)</scale>
				</male>
				<female>
					<scale>(1.5,1.5)</scale>
				</female>
				<thin>
					<scale>(1.5,1.5)</scale>
				</thin>
				<hulk>
					<scale>(1.5,1.5)</scale>
				</hulk>
				<fat>
					<scale>(1.5,1.5)</scale>
				</fat>
			</wornGraphicData>
		</apparel>
	</ThingDef>
</Defs>