  <ThingDef ParentName="ResourceBase">
    <defName>KT_steel</defName>
    <label>Mundite</label>
    <description>This is a second-class alloy material allocated for use by Convention member states. It possesses extremely high strength while being almost weightless. Rumors suggest it is refined from the grime produced during shipgirls' bathing routines.</description>
    <graphicData>
      <texPath>Things/Material/KT_steel</texPath>
      <graphicClass>Graphic_StackCount</graphicClass>
    </graphicData>
    <soundInteract>Metal_Drop</soundInteract>
    <soundDrop>Metal_Drop</soundDrop>
    <useHitPoints>false</useHitPoints>
    <healthAffectsPrice>false</healthAffectsPrice>
	<stackLimit>2000</stackLimit>
    <statBases>
      <MarketValue>30</MarketValue>
      <Mass>0.1</Mass>
      <StuffPower_Armor_Sharp>4</StuffPower_Armor_Sharp>
      <StuffPower_Armor_Blunt>4</StuffPower_Armor_Blunt>
      <StuffPower_Armor_Heat>4</StuffPower_Armor_Heat>
      <StuffPower_Insulation_Cold>80</StuffPower_Insulation_Cold>
      <StuffPower_Insulation_Heat>80</StuffPower_Insulation_Heat>
      <SharpDamageMultiplier>1.5</SharpDamageMultiplier>
      <BluntDamageMultiplier>1.5</BluntDamageMultiplier>
    </statBases>
    <thingCategories>
      <li>ResourcesRaw</li>
    </thingCategories>
    <!-- <deepCommonality>0</deepCommonality>
    <deepCountPerPortion>10</deepCountPerPortion>
    <deepLumpSizeRange>2~10</deepLumpSizeRange> -->
    <burnableByRecipe>false</burnableByRecipe>
    <smeltable>true</smeltable>
    <stuffProps>
      <categories>
        <li>Metallic</li>
      </categories>
      <appearance>Metal</appearance>
      <commonality>0.01</commonality>
      <constructEffect>ConstructMetal</constructEffect>
	  <color>(255,255,255)</color>
      <!--<soundImpactDefault>BulletImpact_Metal</soundImpactDefault>-->
      <soundMeleeHitSharp>MeleeHit_Metal_Sharp</soundMeleeHitSharp>
      <soundMeleeHitBlunt>MeleeHit_Metal_Blunt</soundMeleeHitBlunt>
	    <isAirtight>true</isAirtight>
      <statFactors>
        <MaxHitPoints>10</MaxHitPoints>
        <Beauty>4</Beauty>
        <Flammability>0</Flammability>
        <WorkToMake>0.1</WorkToMake>
        <WorkToBuild>0.1</WorkToBuild>
        <MeleeWeapon_CooldownMultiplier>0.2</MeleeWeapon_CooldownMultiplier>
      </statFactors>
    </stuffProps>
    <terrainAffordanceNeeded>Medium</terrainAffordanceNeeded>
    <allowedArchonexusCount>80</allowedArchonexusCount>
  </ThingDef>
