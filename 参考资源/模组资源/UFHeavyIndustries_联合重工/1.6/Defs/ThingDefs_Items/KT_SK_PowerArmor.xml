<?xml version="1.0" encoding="utf-8" ?>
<Defs>
  <ThingDef ParentName="KT_BaseUnMakeableArmor">
    <defName>KT_SK_Powerarmor</defName>
    <label>"Star Defender" Sacred Psycho-Warrior Armor</label>
    <description>Super power armor with exceptional protective performance and built-in jetpack. However, females are strictly prohibited from wearing it. Once discovered, it will be considered heresy and punished by means including but not limited to: execution by firing squad, heavy artillery bombardment, orbital strikes, and planet-destroying weapons.\n\n&lt;color=#ffe400>&lt;i>Gained powerful stats, but at what cost...&lt;/i>&lt;/color>\n\n&lt;color=#FFAA00&gt;&lt;i&gt;Only species without clothing restrictions can wear this armor; those with restrictions need to use CE MOD to force equip it&lt;/i&gt;&lt;/color&gt;</description>
	<techLevel>Spacer</techLevel>
    <statBases>
		<MaxHitPoints>40000</MaxHitPoints>
		<WorkToMake>75000</WorkToMake>
		<Mass>20</Mass>
		<Flammability>0</Flammability>
		<ArmorRating_Sharp>2</ArmorRating_Sharp>
		<ArmorRating_Blunt>2</ArmorRating_Blunt>
		<ArmorRating_Heat>2</ArmorRating_Heat>
		<Insulation_Cold>70</Insulation_Cold>
		<Insulation_Heat>1200</Insulation_Heat>
		<EquipDelay>15</EquipDelay>
		<JumpRange>50</JumpRange>
	</statBases>
    <generateAllowChance>0</generateAllowChance>
    <generateCommonality>0</generateCommonality>
    <relicChance>0</relicChance>
	
    <equippedStatOffsets>
      <Flammability>-1</Flammability>
	  <IncomingDamageFactor>-0.5</IncomingDamageFactor>
	  <MoveSpeed>-0.1</MoveSpeed>
	  <StaggerDurationFactor>0</StaggerDurationFactor>
	  <VacuumResistance MayRequire="Ludeon.RimWorld.Odyssey">0.3</VacuumResistance>
	  <MeleeDamageFactor>2</MeleeDamageFactor>
	  <CarryingCapacity>500</CarryingCapacity>
	  <AdditionalQualityCarry>300</AdditionalQualityCarry>
    </equippedStatOffsets>
    <costList>
      <Steel>1500</Steel>
    </costList>
    <graphicData>
      <texPath>Things/Apparel/KT_SKPowerarmor/KT_SK_Thin_south</texPath>
      <graphicClass>Graphic_Single</graphicClass>
	  <shaderType>CutoutComplex</shaderType>
	  <drawSize>1.5</drawSize>
    </graphicData>
    <apparel>
      <scoreOffset>4</scoreOffset>
      <wornGraphicPath>Things/Apparel/KT_SKPowerarmor/KT_SK</wornGraphicPath>
	  <useWornGraphicMask>true</useWornGraphicMask>
	  <tags>
           <li>SpacerMilitary</li>
           <li>RoyalTier2</li>
           <li>RoyalTier3</li>
           <li>RoyalTier4</li>
           <li>RoyalTier5</li>
           <li>RoyalTier6</li>
           <li>RoyalTier7</li>
		   <li>Kiiro_Vacsuit</li>
      </tags>
	  <drawData>
	    <scale>1.6</scale>
        <dataSouth>
          <offset>(0,0,0)</offset>
        </dataSouth>
        <dataEast>
          <offset>(0,0,0)</offset>
		  <layer>999</layer>
        </dataEast>
        <dataWest>
          <offset>(0,0,0)</offset>
		  <layer>999</layer>
        </dataWest>
        <dataNorth>
          <offset>(0,0,0)</offset>
		  <layer>999</layer>
        </dataNorth>
      </drawData>
	  <bodyPartGroups>
        <li>Torso</li>
        <li>Neck</li>
        <li>Shoulders</li>
        <li>Arms</li>
        <li>Legs</li>
      </bodyPartGroups>
      <layers>
        <li>Middle</li>
        <li>Shell</li>
      </layers>
      <defaultOutfitTags>
        <li>Soldier</li>
        <li>Spacefarer</li>
      </defaultOutfitTags>
      <useDeflectMetalEffect>true</useDeflectMetalEffect>
      <soundWear>Wear_PowerArmor</soundWear>
      <soundRemove>Remove_PowerArmor</soundRemove>
    </apparel>
    <comps>
	  <li Class="SRA.CompProperties_BodyShapeAjuster"></li>
      <li Class="CompProperties_ApparelReloadable">
          <maxCharges>12</maxCharges>
          <ammoDef>Chemfuel</ammoDef>
          <ammoCountPerCharge>10</ammoCountPerCharge>
          <baseReloadTicks>60</baseReloadTicks>
          <soundReload>Standard_Reload</soundReload>
          <hotKey>Misc4</hotKey>
          <chargeNoun>jump</chargeNoun>
          <displayGizmoWhileUndrafted>false</displayGizmoWhileUndrafted>
      </li>
    </comps>
	<verbs>
      <li>
         <verbClass>Verb_Jump</verbClass>
         <label>喷射起跳</label>
         <violent>false</violent>
         <hasStandardCommand>true</hasStandardCommand>
         <onlyManualCast>True</onlyManualCast>
         <forceNormalTimeSpeed>false</forceNormalTimeSpeed>
         <warmupTime>0</warmupTime>
         <warmupEffecter>JumpWarmupEffect</warmupEffecter>
         <requireLineOfSight>true</requireLineOfSight>
         <flightEffecterDef>JumpFlightEffect</flightEffecterDef>
         <soundLanding>JumpPackLand</soundLanding>
         <targetParams>
              <canTargetLocations>true</canTargetLocations>
              <canTargetPawns>false</canTargetPawns>
              <canTargetBuildings>false</canTargetBuildings>
         </targetParams>
      </li>
    </verbs>
 
    <thingCategories>
      <li>ApparelArmor</li>
    </thingCategories>

  </ThingDef>

  <ThingDef ParentName="KT_BaseUnMakeableHelmet">
