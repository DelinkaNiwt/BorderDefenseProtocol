    <apparel>
      <wornGraphicPath>Things/Apparel/KT_SKPowerarmor/KT_SK_Helmet/KT_SK_Helmet</wornGraphicPath>
      <useWornGraphicMask>true</useWornGraphicMask>
	  <drawData>
	    <scale>1.6</scale>
        <dataSouth>
          <offset>(0,0,-0.35)</offset>
		  <layer>999</layer>
        </dataSouth>
        <dataEast>
          <offset>(-0.10,0,-0.35)</offset>
        </dataEast>
        <dataWest>
          <offset>(0.10,0,-0.35)</offset>
        </dataWest>
        <dataNorth>
          <offset>(0,0,-0.35)</offset>
        </dataNorth>
      </drawData>
	  <bodyPartGroups>
        <li>FullHead</li>
      </bodyPartGroups>
	  <tags>
           <li>SpacerMilitary</li>
           <li>RoyalTier2</li>
           <li>RoyalTier3</li>
           <li>RoyalTier4</li>
           <li>RoyalTier5</li>
           <li>RoyalTier6</li>
           <li>RoyalTier7</li>
      </tags>
      <layers>
        <li>Overhead</li>
      </layers>
      <defaultOutfitTags>
        <li>Soldier</li>
        <li>Spacefarer</li>
      </defaultOutfitTags>
      <useDeflectMetalEffect>false</useDeflectMetalEffect>
    </apparel>
  </ThingDef>
</Defs>