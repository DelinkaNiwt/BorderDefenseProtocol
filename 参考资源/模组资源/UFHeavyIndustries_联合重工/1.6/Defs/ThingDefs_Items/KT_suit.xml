<Defs>
  <!--如果在想为啥鼠鼠智人没有这个衣服穿，因为画的时候只考虑到了有脖子的物种=======-->
  
  <!--美狐=======-->
  <ThingDef ParentName="KT_BaseMakeableArmor" MayRequire="miho.fortifiedoutremer">
		<defName>KT_Fox</defName>
		<label>「断源」公约国美狐制服</label>
		<description>这件看似轻薄的制服其实是一件精密的动力装甲，兼顾了外观与实用性，专为某个平行宇宙的美狐公约国设计，传闻其设计者是某位联合高级成员的妻子。\n根据史料记载，该平行宇宙的美狐公约国因为性欲寡淡，导致人口稀少，她们还实施了严格的禁毒政策，公民普遍拥有成瘾品厌恶特质，最特别的是她们没有任何个体拥有灵能潜质。</description>
		<costList>
			<Steel>200</Steel>
	 		<Plasteel>80</Plasteel>
			<ComponentSpacer>2</ComponentSpacer>
		</costList>
		<graphicData>
			<texPath>Things/Apparel/KT_Suit/KT_Fox/KT_Fox_display</texPath>
			<shaderType>CutoutComplex</shaderType>
		</graphicData>
		<statBases>
			<MaxHitPoints>3000</MaxHitPoints>
			<WorkToMake>28000</WorkToMake>
			<Mass>2</Mass>
			<Flammability>0</Flammability>
			<ArmorRating_Sharp>1.0</ArmorRating_Sharp>
			<ArmorRating_Blunt>1.0</ArmorRating_Blunt>
			<ArmorRating_Heat>1.2</ArmorRating_Heat>
			<StuffEffectMultiplierArmor>0.35</StuffEffectMultiplierArmor>
			<StuffEffectMultiplierInsulation_Cold>0.65</StuffEffectMultiplierInsulation_Cold>
			<StuffEffectMultiplierInsulation_Heat>0.5</StuffEffectMultiplierInsulation_Heat>
			<Insulation_Cold>10</Insulation_Cold>
			<Insulation_Heat>5</Insulation_Heat>
		</statBases>
		<apparel>
      		<useWornGraphicMask>true</useWornGraphicMask>
      		<shellRenderedBehindHead>true</shellRenderedBehindHead>
      		<developmentalStageFilter>Adult</developmentalStageFilter>
      		<layers>
        		<li>Shell</li>
      		</layers>
      		<bodyPartGroups>
                <li>Torso</li>
                <li>Shoulders</li>
                <li>Arms</li>
                <li>Neck</li>
                <li>Legs</li>
                <li>Feet</li>
                <li>Hands</li>
            </bodyPartGroups>
      		<tags>
        		<li></li>
      		</tags>
      		<wornGraphicPath>Things/Apparel/KT_Suit/KT_Fox/KT_Fox</wornGraphicPath>
    	</apparel>
		<equippedStatOffsets>
			<MeleeDodgeChance>4.0</MeleeDodgeChance>
			<MoveSpeed>1.2</MoveSpeed>
			<IncomingDamageFactor>-0.10</IncomingDamageFactor>
			<PainShockThreshold>0.6</PainShockThreshold>
			<MeleeDamageFactor>0.25</MeleeDamageFactor>
			<AdditionalQualityCarry>30</AdditionalQualityCarry>
		</equippedStatOffsets>
		<recipeMaker>
      	 	<researchPrerequisite>KT_Base_Workbench</researchPrerequisite>
      	 	<displayPriority>520</displayPriority>
	  	 	<skillRequirements>
        	 	<Crafting>7</Crafting>
      	 	</skillRequirements>
			<recipeUsers Inherit="False">
				<li>KT_SWorkbench</li>
			</recipeUsers>
    	</recipeMaker>
	</ThingDef>
  
