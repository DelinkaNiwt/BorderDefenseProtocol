  <ThingDef Name="KT_BaseMakeableArmor" ParentName="ArmorMachineableBase" Abstract="True">
    <techLevel>Spacer</techLevel>
    <recipeMaker>
      <unfinishedThingDef>UnfinishedTechArmor</unfinishedThingDef>
      <skillRequirements>
        <Crafting>12</Crafting>
      </skillRequirements>
      <recipeUsers Inherit="False">
        <li>KT_SWorkbench</li>
      </recipeUsers>
    </recipeMaker>
    <graphicData>
      <texPath>Things/Apparel/KT_Powerarmor/KT_uniform_display</texPath>
      <graphicClass>Graphic_Single</graphicClass>
    </graphicData>
    <uiIconScale>1.25</uiIconScale>
    <generateCommonality>2</generateCommonality>
    <statBases>
		<MaxHitPoints>5500</MaxHitPoints>
		<WorkToMake>75000</WorkToMake>
		<Mass>12</Mass>
		<Flammability>0</Flammability>
		<ArmorRating_Sharp>1.65</ArmorRating_Sharp>
		<ArmorRating_Blunt>1.55</ArmorRating_Blunt>
		<ArmorRating_Heat>1.98</ArmorRating_Heat>
		<Insulation_Cold>70</Insulation_Cold>
		<Insulation_Heat>1200</Insulation_Heat>
		<EquipDelay>15</EquipDelay>
	</statBases>
   <equippedStatOffsets>
      <Flammability>-1</Flammability>
	  <ToxicEnvironmentResistance>1</ToxicEnvironmentResistance>
	  <MoveSpeed>0.25</MoveSpeed>
	  <ShootingAccuracyPawn>10</ShootingAccuracyPawn>
    </equippedStatOffsets>
    <thingCategories>
      <li>ApparelArmor</li>
    </thingCategories>
    <apparel>
      <bodyPartGroups>
        <li>Torso</li>
        <li>Neck</li>
        <li>Shoulders</li>
        <li>Arms</li>
        <li>Legs</li>
      </bodyPartGroups>
      <wornGraphicPath>Things/Pawn/Humanlike/Apparel/CataphractArmor/CataphractArmor</wornGraphicPath>
      <layers>
        <li>Middle</li>
        <li>Shell</li>
      </layers>
      <defaultOutfitTags>
        <li>Soldier</li>
        <li>Spacefarer</li>
      </defaultOutfitTags>
      <useDeflectMetalEffect>true</useDeflectMetalEffect>
      <soundWear>Wear_PowerArmor</soundWear>
      <soundRemove>Remove_PowerArmor</soundRemove>
    </apparel>
    <colorGenerator Class="ColorGenerator_Options">
      <options>
        <li>
          <weight>10</weight>
          <only>(0.9,0.9,0.9)</only>
        </li>
        <li>
          <weight>10</weight>
          <only>(0.33,0.33,0.33)</only>
        </li>
        <li>
          <weight>10</weight>
          <only>(0.65,0.65,0.65)</only>
        </li>
        <li>
          <weight>6</weight>
          <min>(0.3,0.3,0.3)</min>
          <max>(0.5,0.5,0.5)</max>
        </li>
      </options>
    </colorGenerator>
    <comps>
      <li Class="CompProperties_Biocodable"/>
    </comps>
    <thingSetMakerTags>
      <li>RewardStandardHighFreq</li>
    </thingSetMakerTags>
  </ThingDef>
  
