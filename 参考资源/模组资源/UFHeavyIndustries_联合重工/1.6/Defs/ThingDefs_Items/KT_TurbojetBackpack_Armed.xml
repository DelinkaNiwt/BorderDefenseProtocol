<Defs>
    <!--涡喷飞行背包-->
	<ThingDef ParentName="ApparelNoQualityBase">
		<defName>TurbojetBackpack_Armed</defName>
		<label>"War Angel" Turbojet Flight Backpack - Armed Variant</label>
		<description>This War Angel has undergone additional modifications, featuring enhanced shields plus two additional autocannon turrets and missile launchers. Due to increased weight, flight performance is slightly inferior to the standard model, and turbojet dash capability is disabled.\n\n&lt;color=#FFAA00&gt;&lt;i&gt;The jetpack offers multiple assisted flight modes and features a built-in special shield that helps the user immune to melee attacks and extreme terrain damage (immune to damage below 15). More importantly, it includes an additional storage compartment to help users carry items such as quick snacks, rare specimens, and cool rocks.&lt;/i&gt;&lt;/color&gt;\n\n&lt;color=#FFAA00&gt;&lt;i&gt;Extremely high world map movement speed&lt;/i&gt;&lt;/color&gt;\n&lt;color=#FFAA00&gt;&lt;i&gt;Autocannon turrets&lt;/i&gt;&lt;/color&gt;\n&lt;color=#FFAA00&gt;&lt;i&gt;Oscillation missile launcher&lt;/i&gt;&lt;/color&gt;\n&lt;color=#FFAA00&gt;&lt;i&gt;Point-defense missile system&lt;/i&gt;&lt;/color&gt;</description>
		<!--材质设置-->
		<tickerType>Normal</tickerType>
		<tradeability>None</tradeability>
		<graphicData>
			<drawSize>(2,2)</drawSize>
			<shaderType>CutoutComplex</shaderType>
			<texPath>Things/Apparel/KT_Jetpack/KT_Jetpack_Armed/TurbojetBackpack_Worn_north</texPath>
			<graphicClass>Graphic_Single</graphicClass>
		</graphicData>
		<!--基本属性-->
		<techLevel>Spacer</techLevel>
		<statBases>
			<Mass>70</Mass>
			<EquipDelay>5</EquipDelay>
			<WorkToMake>50000</WorkToMake>
			<Flammability>0</Flammability>
			<MaxHitPoints>1000</MaxHitPoints>
			<ArmorRating_Heat>1</ArmorRating_Heat>
			<ArmorRating_Sharp>1</ArmorRating_Sharp>
			<ArmorRating_Blunt>1</ArmorRating_Blunt>
			<DeteriorationRate>0</DeteriorationRate>
		</statBases>
		<tradeTags>
			<li>Clothing</li>
		</tradeTags>
		<thingCategories>
			<li>ApparelUtility</li>
		</thingCategories>
		<equippedStatOffsets>
			<MoveSpeed>3</MoveSpeed>
			<MeleeDodgeChance>10</MeleeDodgeChance>
			<CarryingCapacity>35</CarryingCapacity>
			<AdditionalQualityCarry>90</AdditionalQualityCarry>
		</equippedStatOffsets>
		<!--制造材料-->
		<smeltable>false</smeltable>
		<recipeMaker>
			<!--制造设置-->
			<workSkill>Crafting</workSkill>
			<displayPriority>1131</displayPriority>
			<workSpeedStat>GeneralLaborSpeed</workSpeedStat>
			<unfinishedThingDef>UnfinishedPack</unfinishedThingDef>
			<recipeUsers Inherit="False">
				<li>KT_SWorkbench</li>
			</recipeUsers>
			<!--材质设置-->
			<effectWorking>Smith</effectWorking>
			<soundWorking>Recipe_Machining</soundWorking>
			<useIngredientsForColor>false</useIngredientsForColor>
			<!--科技需求-->
			<skillRequirements>
				<Crafting>13</Crafting>
			</skillRequirements>
			<researchPrerequisites>
				<li>KT_Jetpack</li>
				<li>KT_Base_t3_weapon</li>
			</researchPrerequisites>
		</recipeMaker>
		<costList>
			<KT_steel>350</KT_steel>
			<Uranium>200</Uranium>
			<ComponentSpacer>12</ComponentSpacer>
			<ComponentIndustrial>20</ComponentIndustrial>
		</costList>
		<!--配方属性-->

		<!--参数拓展-->
		<modExtensions>
			<li Class="TurbojetBackpack.TurbojetExtension">
				<!--远行速度-->
				<worldMapSpeedFactor>120</worldMapSpeedFactor>
				<!--飞行参数-->
				<flightHeight>3</flightHeight>
				<takeoffSpeed>0.05</takeoffSpeed>
				<landingSpeed>0.05</landingSpeed>
				<flightMoveSpeed>15</flightMoveSpeed>
				<!--飞行起伏-->
				<hoverFrequency>0.3</hoverFrequency>
				<hoverAmplitude>0.15</hoverAmplitude>
				<!--飞行烟尘-->
				<flightMote>TurbojetSmoke</flightMote>
				<flightSmokeScaleMin>5</flightSmokeScaleMin>
				<flightSmokeScaleMax>7</flightSmokeScaleMax>
				<!--怠速烟雾-->
				<standbyMote>TurbojetSmoke</standbyMote>
				<standbyMoteScale>1~1</standbyMoteScale>
				<standbyMoteInterval>1</standbyMoteInterval>
				<!--阴影效果-->
				<shadowMote>TurbojetShadow</shadowMote>
				<shadowMoteInterval>1</shadowMoteInterval>
				<!--图标路径-->
				<flightModeIconPath>KT_UI/UI_TurbojetHover</flightModeIconPath>
				<combatModeIconPath>KT_UI/UI_TurbojetStrike</combatModeIconPath>
				<!--喷流粒子-->
				<thrustMoteEffects>
					<li>
						<moteDef>Mote_TurbojetFlame_Red</moteDef>
						<spread>1</spread>
						<speed>10~10</speed>
						<scale>0.3~0.3</scale>
						<interval>1</interval>
					</li>
					<li>
						<moteDef>Mote_TurbojetFlame_Orange</moteDef>
						<spread>1</spread>
						<speed>10~10</speed>
						<scale>0.5~0.5</scale>
						<interval>1</interval>
					</li>
					<li>
						<moteDef>Mote_TurbojetFlame_White</moteDef>
						<spread>1</spread>
						<speed>10~10</speed>
						<scale>0.7~0.7</scale>
						<interval>1</interval>
					</li>
				</thrustMoteEffects>
				<jumpMoteEffects>
					<li>
						<moteDef>Mote_TurbojetFlame_Red</moteDef>
						<spread>1</spread>
						<speed>10~10</speed>
						<scale>1.3~1.3</scale>
						<interval>1</interval>
					</li>
					<li>
						<moteDef>Mote_TurbojetFlame_Orange</moteDef>
						<spread>1</spread>
						<speed>10~10</speed>
						<scale>1.5~1.5</scale>
						<interval>1</interval>
					</li>
					<li>
						<moteDef>Mote_TurbojetFlame_White</moteDef>
						<spread>1</spread>
						<speed>10~10</speed>
						<scale>1.7~1.7</scale>
						<interval>1</interval>
					</li>
				</jumpMoteEffects>
				<!--喷流位置-->
				<jetsVertical>
					<li>
						<angle>195</angle>
						<offset>(-0.8,0,-0.7)</offset>
					</li>
					<li>
						<angle>165</angle>
						<offset>(0.8,0,-0.7)</offset>
					</li>
				</jetsVertical>
				<jetsHorizontal>
					<li>
						<angle>195</angle>
						<offset>(-0.9,0,-0.6)</offset>
					</li>
				</jetsHorizontal>
			</li>
