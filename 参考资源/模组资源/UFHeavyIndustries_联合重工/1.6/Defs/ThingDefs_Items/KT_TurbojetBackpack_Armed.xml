				<renderUtilityAsPack>true</renderUtilityAsPack>
				<north>
					<offset>(0,0)</offset>
				</north>
				<south>
					<offset>(0,0.1)</offset>
				</south>
				<east>
					<offset>(-0.7,0.05)</offset>
				</east>
				<west>
					<offset>(0.7,0.05)</offset>
				</west>
				<male>
					<scale>(1.5,1.5)</scale>
				</male>
				<female>
					<scale>(1.5,1.5)</scale>
				</female>
				<thin>
					<scale>(1.5,1.5)</scale>
				</thin>
				<hulk>
					<scale>(1.5,1.5)</scale>
				</hulk>
				<fat>
					<scale>(1.5,1.5)</scale>
				</fat>
			</wornGraphicData>
		</apparel>
