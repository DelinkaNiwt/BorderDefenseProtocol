		<!--工作组件-->
		<comps>
			<!--战斗开关-->
			<li Class="TurbojetBackpack.CompProperties_TurbojetFlight" />
			<!--涡喷跳跃-->
			<li Class="TurbojetBackpack.CompProperties_ApparelGiveAbility">
				<abilityDef>TurbojetJump_Ability</abilityDef>
			</li>
			<!--气动护盾-->
    		<li Class="TurbojetBackpack.CompProperties_TurbojetShield">
				<!--材质设置-->
				<minDrawSize>2.4</minDrawSize>
				<maxDrawSize>2.5</maxDrawSize>
				<shieldColor>(1,1,1,1)</shieldColor>
				<shieldTexPath>Things/Apparel/KT_Jetpack/TurbojetShieldBubble</shieldTexPath>
				<!--护盾参数-->
				<maxEnergy>500</maxEnergy>
				<maxDamageCap>9999</maxDamageCap>
				<energyRegenRate>1</energyRegenRate>
				<resetDelayTicks>1000</resetDelayTicks>
				<minDamageThreshold>15</minDamageThreshold>
			</li>
			<!--自动炮塔-->
			<li Class="CompProperties_CauseHediff_Apparel">
				<hediff>KT_JETPACK_TURRET</hediff>
				<part>Body</part>
			</li>
			<!--导弹齐射-->
			<li Class="TurbojetBackpack.CompProperties_ApparelGiveAbility">
				<abilityDef>Ability_BezierMissileLaunch_II</abilityDef>
			</li>
			<!--主动防御-->
			<li Class="TurbojetBackpack.CompProperties_InterceptorSystem">
				<burstCount>1</burstCount><!--魔法无上限火力通道，对同一个敌对目标发射多少发拦截弹数量-->
				<checkInterval>720</checkInterval>
				<uiIconPath>KT_UI/UI_ADS</uiIconPath>
				<launchSound>InfernoCannon_Fire</launchSound>
				<interceptorProjectileDef>Projectile_InterceptorMissile</interceptorProjectileDef>
			</li>
		</comps>
		<!--穿戴外观-->
		<apparel>
			<!--穿戴属性-->
			<wearPerDay>0</wearPerDay>
			<careIfDamaged>false</careIfDamaged>
			<careIfWornByCorpse>false</careIfWornByCorpse>
