<?xml version="1.0" encoding="utf-8" ?>
<Defs>
  <ThingDef ParentName="KT_BaseMakeableArmor">
    <defName>KT_Powerarmor</defName>
    <label>KT_Powerarmor</label>
    <description>KT_Powerarmor</description>
	<techLevel>Spacer</techLevel>
    <statBases>
		<MaxHitPoints>7000</MaxHitPoints>
		<WorkToMake>75000</WorkToMake>
		<Mass>12</Mass>
		<Flammability>0</Flammability>
		<ArmorRating_Sharp>1.65</ArmorRating_Sharp>
		<ArmorRating_Blunt>1.55</ArmorRating_Blunt>
		<ArmorRating_Heat>1.98</ArmorRating_Heat>
		<Insulation_Cold>70</Insulation_Cold>
		<Insulation_Heat>1200</Insulation_Heat>
		<EquipDelay>15</EquipDelay>
	</statBases>
    <generateAllowChance>0</generateAllowChance>
    <generateCommonality>0</generateCommonality>
    <relicChance>0</relicChance>
	
    <equippedStatOffsets>
      <Flammability>-1</Flammability>
	  <IncomingDamageFactor>-0.2</IncomingDamageFactor>
	  <MoveSpeed>0.7</MoveSpeed>
	  <ShootingAccuracyPawn>10</ShootingAccuracyPawn>
	  <CarryingCapacity>120</CarryingCapacity>
	  <AdditionalQualityCarry>100</AdditionalQualityCarry>
	  <VacuumResistance MayRequire="Ludeon.RimWorld.Odyssey">0.3</VacuumResistance>
    </equippedStatOffsets>
    <costList>
      <Steel>400</Steel>
	  <Plasteel>200</Plasteel>
	  <ComponentSpacer>6</ComponentSpacer>
	  <Gold>5</Gold>
	  <Uranium>50</Uranium>
    </costList>
    <graphicData>
      <texPath>Things/Apparel/KT_Powerarmor/KT_uniform_display</texPath>
      <graphicClass>Graphic_Single</graphicClass>
	  <shaderType>CutoutComplex</shaderType>
    </graphicData>
    <apparel>
      <scoreOffset>4</scoreOffset>
      <wornGraphicPath>Things/Apparel/KT_Powerarmor/KT_uniform</wornGraphicPath>
	  <useWornGraphicMask>true</useWornGraphicMask>
	  <tags>
           <li>SpacerMilitary</li>
           <li>RoyalTier2</li>
           <li>RoyalTier3</li>
           <li>RoyalTier4</li>
           <li>RoyalTier5</li>
           <li>RoyalTier6</li>
           <li>RoyalTier7</li>
      </tags>
    </apparel>
    <comps>
      <li Class="CompProperties_ApparelReloadable">
        <maxCharges>8</maxCharges>
        <ammoDef>Steel</ammoDef>
        <ammoCountPerCharge>25</ammoCountPerCharge>
        <baseReloadTicks>30</baseReloadTicks>
        <soundReload>Standard_Reload</soundReload>
        <hotKey>Misc4</hotKey>
        <chargeNoun>incendiary</chargeNoun>
        <displayGizmoWhileUndrafted>false</displayGizmoWhileUndrafted>
      </li>
	  <li Class="SRA.CompProperties_BodyShapeAjuster"></li>
    </comps>
    <verbs>
      <li>
        <label>120mm高爆弹</label>
        <verbClass>Verb_LaunchProjectileStatic</verbClass>
        <hasStandardCommand>true</hasStandardCommand>
        <onlyManualCast>True</onlyManualCast>
        <range>70</range>
		<minRange>20</minRange>
        <forcedMissRadius>1.5</forcedMissRadius>
		<requireLineOfSight>false</requireLineOfSight>
        <warmupTime>1.5</warmupTime>
        <noiseRadius>14</noiseRadius>
        <soundCast>KTSound_Cannonii</soundCast>
        <soundCastTail>GunTail_Medium</soundCastTail>
        <muzzleFlashScale>20</muzzleFlashScale>
        <drawHighlightWithLineOfSight>true</drawHighlightWithLineOfSight>
        <targetParams>
          <canTargetLocations>true</canTargetLocations>
        </targetParams>
        <defaultProjectile>Proj_120mm</defaultProjectile>
        <rangedFireRulepack>Combat_RangedFire_Thrown</rangedFireRulepack>
      </li>
	  <li>
        <label>EMP等离子炮</label>
        <verbClass>Verb_LaunchProjectileStatic</verbClass>
        <hasStandardCommand>true</hasStandardCommand>
        <onlyManualCast>True</onlyManualCast>
        <range>35</range>
        <forcedMissRadius>1</forcedMissRadius>
        <warmupTime>1.5</warmupTime>
        <noiseRadius>4</noiseRadius>
        <soundCast>KTPLASMACANNONRound</soundCast>
        <soundCastTail>GunTail_Medium</soundCastTail>
        <muzzleFlashScale>14</muzzleFlashScale>
        <drawHighlightWithLineOfSight>true</drawHighlightWithLineOfSight>
        <targetParams>
          <canTargetLocations>true</canTargetLocations>
        </targetParams>
        <defaultProjectile>Proj_plasmabullet</defaultProjectile>
        <rangedFireRulepack>Combat_RangedFire_Thrown</rangedFireRulepack>
      </li>
    </verbs>

    <recipeMaker>
      <researchPrerequisite>KT_Base_armor</researchPrerequisite>
      <displayPriority>520</displayPriority>
    </recipeMaker>
  </ThingDef>

  <ThingDef ParentName="BaseIncendiaryProjectile_KTarmor">
    <defName>Proj_120mm</defName>
    <label>Proj_120mm</label>
    <graphicData>
      <texPath>Things/Projectile/Bullet_100MM</texPath>
      <graphicClass>Graphic_Single</graphicClass>
      <shaderType>MoteGlow</shaderType>
    </graphicData>
    <projectile>
        <damageDef>Bomb</damageDef>
        <explosionRadius>2</explosionRadius>
        <speed>250</speed>
        <damageAmountBase>150</damageAmountBase>
        <arcHeightFactor>0</arcHeightFactor>
        <soundExplode>Explosion_Rocket</soundExplode>
		<armorPenetrationBase>1.1</armorPenetrationBase>
		<stoppingPower>1.5</stoppingPower>
		<flyOverhead>true</flyOverhead>
    </projectile>
  </ThingDef>
  
  <ThingDef ParentName="BaseIncendiaryProjectile_KTarmor">
    <defName>Proj_plasmabullet</defName>
    <label>Proj_plasmabullet</label>
    <graphicData>
      <texPath>Things/Projectile/LauncherShot</texPath>
      <graphicClass>Graphic_Single</graphicClass>
      <shaderType>TransparentPostLight</shaderType>
      <color>(0.3,1,0.9)</color>
    </graphicData>
    <projectile>
      <damageDef>KTBLUEBomb</damageDef>
        <explosionRadius>3</explosionRadius>
		<stoppingPower>5</stoppingPower>
        <speed>120</speed>
        <damageAmountBase>70</damageAmountBase>
        <arcHeightFactor>0</arcHeightFactor>
        <soundExplode>Explosion_Rocket</soundExplode>
		<flyOverhead>false</flyOverhead>
		<armorPenetrationBase>1.3</armorPenetrationBase>
		<stoppingPower>1.5</stoppingPower>
		<preExplosionSpawnSingleThingDef>KT_Shell_EMP_small</preExplosionSpawnSingleThingDef>
    </projectile>
  </ThingDef>

