		<description>(核光焰点燃的简介)</description>
		<deathMessage>{0} was ignited under the scorching light of the nuclear fireball.(被核火球的炽热光芒点燃)</deathMessage>
		<combatLogRules>Damage_Flame</combatLogRules>
		<!--音效定义-->
		<impactSoundType>Blunt</impactSoundType>
		<soundExplosion>Explosion_EMP</soundExplosion>
		<!--伤害类型为外源性爆炸-->
		<externalViolence>true</externalViolence>
		<isExplosive>true</isExplosive>
		<!--对生物体表造成高温点燃-->
		<hediff>Burn</hediff>
		<makesBlood>false</makesBlood>
		<hasForcefulImpact>true</hasForcefulImpact>
		<harmAllLayersUntilOutside>false</harmAllLayersUntilOutside>
		<explosionAffectOutsidePartsOnly>true</explosionAffectOutsidePartsOnly>
		<!--对建筑结构造成冲击崩落-->
		<hediffSolid>Crack</hediffSolid>
		<plantDamageFactor>1.5</plantDamageFactor>
		<corpseDamageFactor>0.1</corpseDamageFactor>
		<buildingDamageFactorPassable>0.1</buildingDamageFactorPassable>
		<buildingDamageFactorImpassable>0.1</buildingDamageFactorImpassable>
		<scaleDamageToBuildingsBasedOnFlammability>true</scaleDamageToBuildingsBasedOnFlammability>
		<!--惊扰生物-->
		<canInterruptJobs>true</canInterruptJobs>
		<makesAnimalsFlee>true</makesAnimalsFlee>
		<!--甲弹对抗参数-->
		<armorCategory>Heat</armorCategory>
		<defaultArmorPenetration>0.5</defaultArmorPenetration>
		<!--造伤效果参数-->
		<defaultDamage>50</defaultDamage>
		<minDamageToFragment>5</minDamageToFragment>
		<defaultStoppingPower>5</defaultStoppingPower>
		<explosionHeatEnergyPerCell>50</explosionHeatEnergyPerCell>
		<!--爆炸特效参数-->
		<explosionCellFleck>BlastEMP</explosionCellFleck>
		<explosionColorCenter>(0.4, 1, 1)</explosionColorCenter>
		<explosionColorEdge>(0.4, 0.8, 0.8)</explosionColorEdge>
		<expolosionPropagationSpeed>1</expolosionPropagationSpeed>
	</DamageDef>
</Defs>
