  <HediffDef>
    <hediffClass>HediffWithComps</hediffClass>
    <defName>KT_Special_SMG_crystal</defName>
    <label>KT_Special_SMG_crystal</label>
    <labelNoun>weakened</labelNoun>
	<initialSeverity>0.1</initialSeverity>
    <maxSeverity>1</maxSeverity>
	<defaultLabelColor>(255, 228, 0)</defaultLabelColor>
    <description>Shrapnel fragments have embedded themselves in this unit, rendering it more vulnerable to injury.</description>

	
	  <comps>
      <li Class="HediffCompProperties_Disappears">
        <disappearsAfterTicks>6000~6000</disappearsAfterTicks>
        <showRemainingTime>true</showRemainingTime>
      </li>
    </comps>
	<stages>
      <li>
		<statOffsets>
			<IncomingDamageFactor>0.3</IncomingDamageFactor>
		</statOffsets>
      </li>
	  <li>
        <minSeverity>0.25</minSeverity>
		<statOffsets>
			<IncomingDamageFactor>0.8</IncomingDamageFactor>
		</statOffsets>
      </li>
	   <li>
        <minSeverity>0.5</minSeverity>
		<statOffsets>
			<IncomingDamageFactor>1.5</IncomingDamageFactor>
		</statOffsets>
      </li>
	  <li>
        <minSeverity>0.75</minSeverity>
		<statOffsets>
			<IncomingDamageFactor>2.4</IncomingDamageFactor>
		</statOffsets>
      </li>
	  <li>
        <minSeverity>0.95</minSeverity>
		<statOffsets>
			<IncomingDamageFactor>3.5</IncomingDamageFactor>
		</statOffsets>
      </li>
    </stages>
  </HediffDef>
  
