<Defs>
  <HediffDef><!-- 承伤背包 -->
    <defName>KT_Backpack_Hediff</defName>
    <label>KT_Backpack_Hediff</label>
    <hediffClass>HediffWithComps</hediffClass>
    <description>KT_Backpack_Hediff</description>
	<defaultLabelColor>(75, 200, 255)</defaultLabelColor>
    <isBad>false</isBad>
    <priceImpact>false</priceImpact>
    <comps>
      <li Class="SRA.HediffCompProperties_SRABarrier">
        <maxBarrier>30</maxBarrier>
        <DamageTakenMult>1</DamageTakenMult><!-- 小于等于0则无敌 -->
        <DamageTakenMax>45</DamageTakenMax><!-- 小于等于0则不工作 -->
        <DamageTakenReduce>35</DamageTakenReduce><!-- 小于等于0则不工作 -->
        <regenRate>2</regenRate>
        <regenDelay>0</regenDelay>
        <rechargeCooldown>10</rechargeCooldown>
        <RemoveWhenDestroy>false</RemoveWhenDestroy><!-- 是否在护盾被击毁时设状态程度为0 -->
        <priority>2000</priority><!-- 承伤优先级，越大越先，int -->
      </li>
	  <li Class="HediffCompProperties_RemoveIfApparelDropped" />
    </comps>
    <stages>
      <li>
      </li>
    </stages>
  </HediffDef>

