<?xml version="1.0" encoding="utf-8"?>
<Defs>

  <HediffDef ParentName="ImplantHediffBase">
    <defName>KT_medical</defName>
	<defaultLabelColor>(0, 220, 0)</defaultLabelColor>
    <label>KT_medical_Chip</label>
    <labelNoun>KT_medical_Chip</labelNoun>
    <description>KT_medical_Chip</description>
    <descriptionHyperlinks><ThingDef>KT_medical_Chip</ThingDef></descriptionHyperlinks>
    <stages>
      <li>
        <totalBleedFactor>0</totalBleedFactor>
      </li>
    </stages>
    <spawnThingOnRemoved>KT_medical_Chip</spawnThingOnRemoved>
	
	<comps>
      <li Class="SRA.HediffCompProperties_SRARegen">
        <healPerSecond>0.5</healPerSecond>
        <checkInterval>60</checkInterval>
      </li>
    </comps>
  </HediffDef>
  
  <ThingDef ParentName="BodyPartProstheticKTBase">
    <defName>KT_medical_Chip</defName>
    <label>KT_medical_Chip</label>
    <description>KT_medical_Chip</description>
    <descriptionHyperlinks><RecipeDef>InstallKTMED</RecipeDef></descriptionHyperlinks>
	<graphicData>
      <texPath>Things/Others/KT_Chip_green</texPath>
      <graphicClass>Graphic_Single</graphicClass>
      <drawSize>1.00</drawSize>
    </graphicData>
	<statBases>
		<WorkToMake>6000</WorkToMake>
		<MarketValue>3200</MarketValue>
		<Mass>0.2</Mass>
	</statBases>
    <thingSetMakerTags>
      <li>RewardStandardLowFreq</li>
    </thingSetMakerTags>
    <costList>
      <Steel>50</Steel>
	  <Plasteel>80</Plasteel>
	  <Gold>30</Gold>
      <ComponentIndustrial>5</ComponentIndustrial>
	  <ComponentSpacer>10</ComponentSpacer>
    </costList>
	<recipeMaker>
		  <researchPrerequisite>KT_chip_tech</researchPrerequisite>
		  <skillRequirements>
			<Crafting>12</Crafting>
		  </skillRequirements>
		  <recipeUsers Inherit="False">
			<li>KT_SWorkbench</li>
		  </recipeUsers>
		  <displayPriority>200</displayPriority>
	</recipeMaker>
  </ThingDef>
  
  <RecipeDef ParentName="SurgeryInstallImplantBase">
    <defName>InstallKTMED</defName>
    <label>install Medical Chip</label>
    <description>Install a Medical Chip.</description>
    <descriptionHyperlinks>
      <ThingDef>KT_medical_Chip</ThingDef>
      <HediffDef>KT_medical</HediffDef>
    </descriptionHyperlinks>
    <jobString>Installing Kai Yang chip.</jobString>
    <ingredients>
      <li>
        <filter>
          <thingDefs>
            <li>KT_medical_Chip</li>
          </thingDefs>
        </filter>
        <count>1</count>
      </li>
    </ingredients>
    <fixedIngredientFilter>
      <thingDefs>
        <li>KT_medical_Chip</li>
      </thingDefs>
    </fixedIngredientFilter>
    <appliedOnFixedBodyParts>
      <li>Brain</li>
    </appliedOnFixedBodyParts>
    <addsHediff>KT_medical</addsHediff>
  </RecipeDef>

  <RecipeDef ParentName="SurgeryRemoveImplantBase">
    <defName>RemoveKTMED</defName>
    <label>remove Medical Chip</label>
    <description>Remove the Medical Chip.</description>
    <descriptionHyperlinks>
      <ThingDef>KT_medical_Chip</ThingDef>
      <HediffDef>KT_medical</HediffDef>
    </descriptionHyperlinks>
    <jobString>Removing Medical Chip.</jobString>
    <removesHediff>KT_medical</removesHediff>
  </RecipeDef>
</Defs>

  