      <drawSize>(2.9)</drawSize>
	  <drawOffsetSouth>(0,0,0.2)</drawOffsetSouth>
	  <drawOffsetNorth>(0,0,-0.05)</drawOffsetNorth>
	  <drawOffsetEast>(-0.11,0,0.5)</drawOffsetEast>
	  <drawOffsetWest>(0.10,0,0.5)</drawOffsetWest>
