<?xml version="1.0" encoding="utf-8"?>
<Defs>
  <ThingDef ParentName="BuildingBase">
    <defName>KT_kebabseal</defName> <!-- def名 -->
    <label>KT_kebabseal</label>  
    <description>KT_kebabseal</description> <!-- 描述文本 -->
    <surfaceType>None</surfaceType> <!-- 表面类型 -->
    <uiOrder>1500</uiOrder> <!-- UI栏顺序 -->
	<uiIconScale>1</uiIconScale> <!-- ui图标比例 -->
	<thingCategories>
      <li>BuildingsTemperature</li>
    </thingCategories>
	<minifiedDef>MinifiedThing</minifiedDef>
    <graphicData> <!-- 图形数据 -->
      <texPath>Things/Building/KT_kebabseal</texPath> <!-- 贴图路径 -->
      <graphicClass>Graphic_Multi</graphicClass> <!-- 图形类 -->
	  <drawSize>(5,2.5)</drawSize> <!-- 贴图大小 -->
	  <drawOffsetNorth>(0,0,0)</drawOffsetNorth> <!-- 绘制偏移北 -->
      <drawOffsetSouth>(0,0,0)</drawOffsetSouth> <!-- 绘制偏移南 -->
      <drawOffsetWest>(0,0,0)</drawOffsetWest> <!-- 绘制偏移西 -->
      <drawOffsetEast>(0,0,0)</drawOffsetEast> <!-- 绘制偏移东 -->
    </graphicData>
    <statBases> <!-- 统计基础 -->
      <MaxHitPoints>250</MaxHitPoints> <!-- 最大生命值 -->
      <WorkToBuild>100</WorkToBuild> <!-- 工作量 -->
      <Flammability>0</Flammability> <!-- 易燃性 -->
      <Beauty>-100</Beauty> <!-- 美观 -->
	  <Mass>20</Mass>
    </statBases>
    <size>(4,2)</size> <!-- 尺寸 -->
    <defaultPlacingRot>North</defaultPlacingRot> <!-- 默认放置位置 -->
    <costList>
      <Steel>10</Steel>
	  <WoodLog>20</WoodLog>
	</costList>  
	<constructionSkillPrerequisite>1</constructionSkillPrerequisite> <!-- 施工技能先决条件 -->
	<altitudeLayer>Building</altitudeLayer> <!-- 图层高度 -->
    <passability>Standable</passability> <!-- 通过性 -->
    <blockWind>false</blockWind> <!-- 气流阻挡 -->
    <placeWorkers>
      <li>PlaceWorker_PreventInteractionSpotOverlap</li>
      <li>PlaceWorker_Heater</li>
      <li>PlaceWorker_GlowRadius</li>
    </placeWorkers>
    <coversFloor>false</coversFloor> <!-- 覆盖地板 -->
    <rotatable>true</rotatable> <!-- 可旋转 -->
    <selectable>true</selectable> <!-- 可选择 -->
	<useStuffTerrainAffordance>false</useStuffTerrainAffordance> <!-- 使用地形承受能力 -->
    <terrainAffordanceNeeded>Light</terrainAffordanceNeeded> <!-- 需要地形承受能力，石材所需的承担特质 -->
    <holdsRoof>false</holdsRoof> <!-- 支撑屋顶 -->
    <designationCategory>KT_designation_group</designationCategory> <!-- UI栏位置 -->
    <castEdgeShadows>True</castEdgeShadows> <!-- 投射边缘阴影 -->
    <blockLight>false</blockLight> <!-- 光线遮挡 -->
	<fertility>0</fertility> <!-- 肥沃 -->
	<building> <!-- 建筑 -->
	  <isEdifice>true</isEdifice> <!-- 是建筑 -->
	  <paintable>true</paintable> <!-- 可涂漆 -->
	  <ai_chillDestination>false</ai_chillDestination> <!-- ai冷却目的地 -->
	</building>
	<tickerType>Normal</tickerType>
	<comps>
	  <li Class="CompProperties_Refuelable">
        <fuelConsumptionRate>0</fuelConsumptionRate>
        <fuelCapacity>20.0</fuelCapacity>
        <fuelFilter>
          <thingDefs>
            <li>WoodLog</li>
          </thingDefs>
        </fuelFilter>
        <initialFuelPercent>1</initialFuelPercent>
        <showAllowAutoRefuelToggle>true</showAllowAutoRefuelToggle>
        <functionsInVacuum>false</functionsInVacuum>
      </li>
      <li Class="CompProperties_HeatPusher">
        <compClass>CompHeatPusherPowered</compClass>
        <heatPerSecond>500</heatPerSecond>
        <heatPushMaxTemperature>1000</heatPushMaxTemperature>
      </li>
	  <li Class="CompProperties_Glower">
        <glowRadius>7</glowRadius>
        <glowColor>(252,255,255,0)</glowColor>
      </li>
	  <li>
        <compClass>CompGatherSpot</compClass>
      </li>
      <li Class="CompProperties_MeditationFocus">
        <statDef>MeditationFocusStrength</statDef>
        <focusTypes><li>Flame</li></focusTypes>
        <offsets>
          <li Class="FocusStrengthOffset_Lit">
            <offset>0.12</offset>
          </li>
          <li Class="FocusStrengthOffset_BuildingDefsLit">
            <defs>
              <li>Campfire</li>
              <li>TorchLamp</li>
              <li MayRequire="Ludeon.RimWorld.Royalty">Brazier</li>
              <li MayRequire="Ludeon.RimWorld.Royalty,Ludeon.RimWorld.Ideology">DarklightBrazier</li>
              <li MayRequire="Ludeon.RimWorld.Ideology">Darktorch</li>
              <li MayRequire="Ludeon.RimWorld.Ideology">DarktorchFungus</li>
            </defs>
            <offsetPerBuilding>0.02</offsetPerBuilding>
            <radius>9.9</radius>
            <maxBuildings>8</maxBuildings>
            <explanationKey>MeditationFocusPerFlame</explanationKey>
            <explanationKeyAbstract>MeditationFocusPerFlameAbstract</explanationKeyAbstract>
          </li>
        </offsets>
      </li>
    </comps>
  </ThingDef>
  
