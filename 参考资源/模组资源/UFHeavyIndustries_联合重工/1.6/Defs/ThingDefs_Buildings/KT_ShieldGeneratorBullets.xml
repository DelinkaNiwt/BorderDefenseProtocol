<?xml version="1.0" encoding="utf-8"?>
<Defs>
  <ThingDef ParentName="BuildingBase">
    <defName>KTShieldGeneratorBullets</defName>
    <label>KTShieldGeneratorBullets</label>
    <description>A shielding device which projects a momentum repulsor field. Shots can go out, but not in.\n\nThis one is tuned to low angles, so it will block ground-level projectiles like bullets.\n\nThe unit can be temporarily disabled by EMP attacks, either by shocking the projector unit itself, or using EMP munitions on the shield.</description>
    <receivesSignals>true</receivesSignals>
	<uiOrder>2301</uiOrder> <!-- UI栏顺序 -->
    <statBases>
      <MaxHitPoints>2000</MaxHitPoints>
      <Flammability>0</Flammability>
      <MarketValue>1000</MarketValue>
      <WorkToBuild>300</WorkToBuild>
	  <Mass>10</Mass> <!-- 质量 -->
    </statBases>
	<thingCategories>
        <li>BuildingsSecurity</li> <!-- 建筑类别：安全 -->
    </thingCategories>
	<designationCategory>KT_designation_group</designationCategory> <!-- 指定分类：安全 -->
	<rotatable>false</rotatable>
    <graphicData>
      <texPath>Things/Building/KTshield</texPath>
      <graphicClass>Graphic_Single</graphicClass>
	  <shaderType>TransparentPostLight</shaderType>
      <drawSize>(1,1)</drawSize>
      <shadowData>
        <volume>(0.6, 0.4, 0.6)</volume>
      </shadowData>
      <damageData>
        <rect>(0.2, 0.2, 0.6, 0.6)</rect>
      </damageData>
    </graphicData>
	<costList>
      <Steel>500</Steel>
	  <Plasteel>200</Plasteel>
      <ComponentIndustrial>15</ComponentIndustrial>
	  <ComponentSpacer>3</ComponentSpacer>
    </costList>
    <building>
      <destroySound>BuildingDestroyed_Metal_Small</destroySound>
	  <isEdifice>false</isEdifice>
	  <canBuildNonEdificesUnder>true</canBuildNonEdificesUnder>
    </building>
    <isMechClusterThreat>true</isMechClusterThreat>
    <drawerType>MapMeshAndRealTime</drawerType>
    <placeWorkers>
      <li>PlaceWorker_ShowProjectileInterceptorRadius</li>
    </placeWorkers>
    <comps>
      <li Class="CompProperties_ProjectileInterceptor">
        <radius>25</radius>
        <interceptGroundProjectiles>true</interceptGroundProjectiles>
        <color>(0.4, 0.4, 0.4)</color>
        <reactivateEffect>BulletShieldGenerator_Reactivate</reactivateEffect>
        <activeSound>BulletShield_Ambience</activeSound>

      </li>
      <li Class="CompProperties_WakeUpDormant">
        <wakeUpSound>MechanoidsWakeUp</wakeUpSound>
      </li>
    </comps>
	<altitudeLayer>BuildingOnTop</altitudeLayer>
	<clearBuildingArea>false</clearBuildingArea>
	<passability>PassThroughOnly</passability>
    <canOverlapZones>true</canOverlapZones>
    <minifiedDef>MinifiedThing</minifiedDef>
    <tradeability>Sellable</tradeability>
    <resourcesFractionWhenDeconstructed>1</resourcesFractionWhenDeconstructed>
    <leaveResourcesWhenKilled>false</leaveResourcesWhenKilled>
    <killedLeavings>
      <Plasteel>7</Plasteel>
    </killedLeavings>
	
	<researchPrerequisites>
	  <li>KT_Shield</li>
    </researchPrerequisites>
  </ThingDef>

