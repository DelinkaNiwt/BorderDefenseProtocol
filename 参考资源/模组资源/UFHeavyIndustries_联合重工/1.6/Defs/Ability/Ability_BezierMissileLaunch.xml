<?xml version="1.0" encoding="utf-8" ?>
<Defs>
	<!--截击导弹-->
	<ThingDef ParentName="BaseBullet">
		<defName>Projectile_InterceptorMissile</defName>
		<label>Projectile Interceptor Missile</label>
		<!--材质设置-->
		<graphicData>
			<drawSize>1.2</drawSize>
			<texPath>Things/Projectile/Bullet_KT_missile</texPath>
			<graphicClass>Graphic_Single</graphicClass>
			<shaderType>TransparentPostLight</shaderType>
		</graphicData>
		<!--基本参数-->
		<projectile>
			<speed>150</speed>
			<damageDef>Bomb</damageDef>
			<flyOverhead>true</flyOverhead>
			<explosionRadius>1.5</explosionRadius>
			<damageAmountBase>0</damageAmountBase>
			<soundExplode>Explosion_Bomb</soundExplode>
		</projectile>
		<thingClass>TurbojetBackpack.Projectile_ActiveInterceptor</thingClass>
		<!-- 视觉特效：蓝白色烟雾尾迹 -->
		<modExtensions>
			<li Class="TurbojetBackpack.BarrageExtension">
				<!--振荡曲线-->
				<curveVarianceMin>15</curveVarianceMin>
				<curveVarianceMax>15</curveVarianceMax>
				<!--尾迹参数-->
				<tailLayers>
					<li>
						<scale>1</scale>
						<interval>3</interval>
						<fleckDef>MicroSparks</fleckDef>
					</li>
					<li>
						<scale>1.5</scale>
						<interval>3</interval>
						<offsetZ>-0.5</offsetZ>
						<fleckDef>Smoke</fleckDef>
						<color>(255,255,255,255)</color>
					</li>
					<li>
						<scale>1.5</scale>
						<interval>1</interval>
						<fleckDef>ShotFlash</fleckDef>
						<color>(255,200,150,220)</color>
						<drawConnectingLine>True</drawConnectingLine>
					</li>
				</tailLayers>
			</li>
		</modExtensions>
	</ThingDef>
	<!--振荡导弹-->
	<ThingDef ParentName="BaseBullet">
		<defName>Projectile_BezierMissile</defName>
		<label>Bezier Oscillation Missile</label>
		<!--材质设置-->
		<graphicData>
			<drawSize>1.5</drawSize>
			<texPath>Things/Projectile/Bullet_KT_missile</texPath>
			<graphicClass>Graphic_Single</graphicClass>
			<shaderType>TransparentPostLight</shaderType>
		</graphicData>
		<!--基本参数-->
		<projectile>
			<speed>90</speed>
			<damageDef>Bomb</damageDef>
			<flyOverhead>true</flyOverhead>
			<explosionRadius>4</explosionRadius>
			<damageAmountBase>180</damageAmountBase>
			<soundExplode>Explosion_Bomb</soundExplode>
		</projectile>
		<thingClass>TurbojetBackpack.Projectile_BezierMissile</thingClass>
		<!--参数拓展-->
		<modExtensions>
			<li Class="TurbojetBackpack.BarrageExtension">
				<!--振荡曲线-->
				<curveVarianceMin>15</curveVarianceMin>
				<curveVarianceMax>15</curveVarianceMax>
				<!--齐射参数-->
				<burstCount>16</burstCount>
				<randomFireRadius>15</randomFireRadius>
				<!--振荡击晕-->
				<extraStun>True</extraStun>
				<stunAmount>25</stunAmount>
				<stunRadius>3.5</stunRadius>
				<!--辐射烧伤-->
				<extraFire>True</extraFire>
				<fireChance>0.5</fireChance>
				<fireRadius>3.5</fireRadius>
				<fireDamageAmount>12</fireDamageAmount>
				<!--尾迹参数-->
				<tailLayers>
					<li>
						<scale>1</scale>
						<interval>3</interval>
						<fleckDef>MicroSparks</fleckDef>
					</li>
					<li>
						<scale>1.5</scale>
						<interval>3</interval>
						<offsetZ>-0.5</offsetZ>
						<fleckDef>Smoke</fleckDef>
						<color>(200,200,200,100)</color>
					</li>
					<li>
						<scale>1.5</scale>
						<interval>1</interval>
						<fleckDef>ShotFlash</fleckDef>
						<color>(255,200,150,100)</color>
						<drawConnectingLine>True</drawConnectingLine>
					</li>
				</tailLayers>
			</li>
		</modExtensions>
	</ThingDef>
	<!--导弹齐射-->
	<AbilityDef>
		<defName>Ability_BezierMissileLaunch</defName>
		<label>Missile Salvo</label>
		<description>Launches a salvo of Bessel Oscillation missiles at the target area. Upon impact, missiles ignite and stun targets.\n\n&lt;color=#FFAA00&gt;&lt;i&gt;Reload time per salvo is 12 hours.&lt;/i&gt;&lt;/color&gt;</description>
		<!--材质设置-->
		<iconPath>KT_UI/UI_MissileLaunch</iconPath>
		<displayGizmoWhileUndrafted>false</displayGizmoWhileUndrafted>
		<!--派系设置-->
		<hostile>true</hostile>
		<aiCanUse>false</aiCanUse>
		<!--工作组件-->
		<comps>
			<!--弹舱设置-->
			<li Class="TurbojetBackpack.CompProperties_AbilityMagazine">
				<maxCharges>4</maxCharges>
				<reloadTicks>43200</reloadTicks>
				<soundReload>Standard_Reload</soundReload>
			</li>
		</comps>
		<!--技能属性-->
		<jobDef>CastAbilityOnThing</jobDef>
		<targetRequired>true</targetRequired>
		<cooldownTicksRange>120</cooldownTicksRange>
		<canUseAoeToGetTargets>false</canUseAoeToGetTargets>
		<abilityClass>TurbojetBackpack.Ability_MagazineLaunch</abilityClass>
		<verbProperties>
			<range>500</range>
			<warmupTime>1</warmupTime>
			<soundCast>InfernoCannon_Fire</soundCast>
			<requireLineOfSight>false</requireLineOfSight>
			<verbClass>TurbojetBackpack.Verb_BezierMissileLaunch</verbClass>
			<defaultProjectile>Projectile_BezierMissile</defaultProjectile>
			<targetParams>
				<canTargetPawns>True</canTargetPawns>
				<canTargetBuildings>True</canTargetBuildings>
				<canTargetLocations>True</canTargetLocations>
			</targetParams>
		</verbProperties>
	</AbilityDef>
	
	<!--导弹齐射-->
	<AbilityDef>
		<defName>Ability_BezierMissileLaunch_II</defName>
		<label>Missile Salvo</label>
		<description>Launches a salvo of Bessel Oscillation missiles at the target area. Upon impact, missiles ignite and stun targets.\n\n&lt;color=#FFAA00&gt;&lt;i&gt;Reload time per salvo is 12 hours.&lt;/i&gt;&lt;/color&gt;</description>
		<!--材质设置-->
		<iconPath>KT_UI/UI_MissileLaunch</iconPath>
		<displayGizmoWhileUndrafted>false</displayGizmoWhileUndrafted>
		<!--派系设置-->
		<hostile>true</hostile>
		<aiCanUse>false</aiCanUse>
		<!--工作组件-->
		<comps>
			<!--弹舱设置-->
			<li Class="TurbojetBackpack.CompProperties_AbilityMagazine">
				<maxCharges>2</maxCharges>
				<reloadTicks>43200</reloadTicks>
				<soundReload>Standard_Reload</soundReload>
			</li>
		</comps>
		<!--技能属性-->
		<jobDef>CastAbilityOnThing</jobDef>
		<targetRequired>true</targetRequired>
		<cooldownTicksRange>120</cooldownTicksRange>
		<canUseAoeToGetTargets>false</canUseAoeToGetTargets>
		<abilityClass>TurbojetBackpack.Ability_MagazineLaunch</abilityClass>
		<verbProperties>
			<range>500</range>
			<warmupTime>1</warmupTime>
			<soundCast>InfernoCannon_Fire</soundCast>
			<requireLineOfSight>false</requireLineOfSight>
			<verbClass>TurbojetBackpack.Verb_BezierMissileLaunch</verbClass>
			<defaultProjectile>Projectile_BezierMissile</defaultProjectile>
			<targetParams>
				<canTargetPawns>True</canTargetPawns>
				<canTargetBuildings>True</canTargetBuildings>
				<canTargetLocations>True</canTargetLocations>
			</targetParams>
		</verbProperties>
	</AbilityDef>
</Defs>