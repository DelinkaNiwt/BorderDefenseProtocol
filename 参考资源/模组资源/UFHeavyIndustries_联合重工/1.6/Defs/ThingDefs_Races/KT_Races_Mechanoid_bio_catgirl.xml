<?xml version="1.0" encoding="utf-8"?>
<Defs>

  <PawnKindDef Name="KTLightMechanoidKind" Abstract="True">
    <defaultFactionType>Mechanoid</defaultFactionType>
    <aiAvoidCover>false</aiAvoidCover>
    <destroyGearOnDrop>true</destroyGearOnDrop>
    <canStrip>false</canStrip>
    <minGenerationAge>100</minGenerationAge>
    <forceNormalGearQuality>true</forceNormalGearQuality>
    <allowInMechClusters>false</allowInMechClusters>

    <weaponMoney>2000~3000</weaponMoney>
    <combatPower>50</combatPower>
    <techHediffsChance>1</techHediffsChance>
    <techHediffsMoney>1000~2000</techHediffsMoney>
    <controlGroupPortraitZoom>0.8</controlGroupPortraitZoom>
  </PawnKindDef>
  
  <ThingDef Abstract="True" Name="KTLightMechanoid" ParentName="LightMechanoid">
    <statBases>
      <MoveSpeed>8</MoveSpeed>
      <MarketValue>3000</MarketValue>
      <ControlTakingTime>3</ControlTakingTime>
      <BandwidthCost>1</BandwidthCost>
      <ArmorRating_Blunt>2</ArmorRating_Blunt>
      <ArmorRating_Sharp>2</ArmorRating_Sharp>
      <ArmorRating_Heat>2</ArmorRating_Heat>
      <ComfyTemperatureMin>-200</ComfyTemperatureMin>
      <ComfyTemperatureMax>2000</ComfyTemperatureMax>
      <StaggerDurationFactor>-1</StaggerDurationFactor>
      <PsychicSensitivity>0</PsychicSensitivity>
      <MechEnergyUsageFactor>0</MechEnergyUsageFactor>
      <MechEnergyLossPerHP>0</MechEnergyLossPerHP>
      <WastepacksPerRecharge>0</WastepacksPerRecharge>
    </statBases>
    <race>
      <hasCorpse>false</hasCorpse>
      <intelligence>ToolUser</intelligence>
      <thinkTreeMain>Mechanoid</thinkTreeMain>
      <baseHealthScale>1</baseHealthScale>
      <mechWeightClass>UltraHeavy</mechWeightClass>
    </race>
    <butcherProducts Inherit="False">
      <Steel>30</Steel>
      <Plasteel>20</Plasteel>
    </butcherProducts>
	
	<damageMultipliers>
      <li>
        <damageDef>Flame</damageDef>
        <multiplier>0</multiplier>
      </li>
      <li>
        <damageDef>EMP</damageDef>
        <multiplier>0</multiplier>
      </li>
    </damageMultipliers>
  </ThingDef>
  
  <ThingDef ParentName="KTLightMechanoid">
      <defName>KT_BIO_CATGIRL_fabricor</defName>
      <label>KT_BIO_CATGIRL_fabricor</label>
      <description>KT_BIO_CATGIRL_fabricor</description>
	  <statBases>
	    <IncomingDamageFactor>0.1</IncomingDamageFactor>
		<CleaningSpeed>0.8</CleaningSpeed>
		<WorkSpeedGlobal>2.00</WorkSpeedGlobal>
		<FoodPoisonChance>0.001</FoodPoisonChance>		
      </statBases>
      <race>
        <mechEnabledWorkTypes>
          <li>Crafting</li>
          <li>Smithing</li>
          <li>Tailoring</li>
		  <li>Cooking</li>
		  <li>Doctor</li>
		  <li>Hauling</li>
		  <li>Cleaning</li>
        </mechEnabledWorkTypes>
		<mechFixedSkillLevel>15</mechFixedSkillLevel>
		<baseBodySize>2</baseBodySize>
		<baseHealthScale>4</baseHealthScale>
        <lifeStageAges>
          <li>
            <def>MechanoidFullyFormed</def>
            <minAge>0</minAge>
            <soundWounded>Pawn_KT_BIO_CATGIRL_Wounded</soundWounded>
            <soundDeath>Pawn_KT_BIO_CATGIRL_Death</soundDeath>
            <soundCall>Pawn_KT_BIO_CATGIRL_Call</soundCall>
          </li>
        </lifeStageAges>
      </race>
	  
	  <comps>
        <li Class="SRA.CompProperties_GlobalMechCommand" />
		
		<li Class="SRA.CompProperties_MultiTurretGun">
		    <ID>0</ID>
        <turretDef>KT_BIO_CATGIRL_ghost_turret</turretDef>
        <!-- <angleOffset>-90</angleOffset> -->
        <renderNodeProperties>
          <li>
            <nodeClass>PawnRenderNode_TurretGun</nodeClass>
            <workerClass>PawnRenderNodeWorker_TurretGun</workerClass>
            <parentTagDef>Body</parentTagDef>
            <overrideMeshSize>(1,1)</overrideMeshSize>
            <pawnType>Any</pawnType>
            <drawData>
              <dataNorth>
                <offset>(-0.5, 0, 0.4)</offset>
				<rotationOffset>270</rotationOffset>
                <flip>true</flip>
                <layer>-80</layer>
              </dataNorth>
			  <dataSouth>
			    <layer>40</layer>
			    <rotationOffset>270</rotationOffset>
                <offset>(0.5, 0,0.4)</offset>
              </dataSouth>
              <dataEast>
                <layer>-80</layer>
				<rotationOffset>270</rotationOffset>
                <offset>(0.2, 0, 0.3)</offset>
              </dataEast>
              <dataWest>
			  <layer>40</layer>
                <offset>(-0.6, 0, 0.4)</offset>
				<rotationOffset>-270</rotationOffset>
              </dataWest>
            </drawData>
          </li>
        </renderNodeProperties>
      </li> 
      </comps>
	
    </ThingDef>
    
