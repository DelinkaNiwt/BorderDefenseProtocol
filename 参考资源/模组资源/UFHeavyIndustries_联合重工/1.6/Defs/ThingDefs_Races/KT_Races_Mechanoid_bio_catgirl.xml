			<cooldownTime>1.2</cooldownTime>
			<armorPenetration>1.5</armorPenetration>
			<extraMeleeDamages>
          		<li>
            		<def>EMP</def>
        			<amount>25</amount>
        		</li>
			</extraMeleeDamages>
		</li>
		</tools>
		
	</ThingDef>
	
