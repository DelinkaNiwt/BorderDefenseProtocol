  <ThingDef ParentName="BaseBullet">
    <defName>KT_Bullet_BIO_CATGIRL_Grenadelauncher</defName>
    <label>KT_Bullet_BIO_CATGIRL_Grenadelauncher</label>
    <thingClass>SRA.Projectile_MultiExplosive</thingClass>
        <category>Projectile</category>
        <tickerType>Normal</tickerType>
        <altitudeLayer>Projectile</altitudeLayer>
        <graphicData>
            <texPath>Things/Projectile/Bullet_kt_plasma</texPath> <!-- 子弹贴图路径 -->
            <graphicClass>Graphic_Single</graphicClass> <!-- 使用单一图形 -->
			<shaderType>MoteGlow</shaderType>
      		<drawSize>(1.5)</drawSize>
        </graphicData>
        <projectile>
            <damageDef>KTBLUEBomb</damageDef>
            <explosionRadius>2.5</explosionRadius>
            <speed>80</speed>
            <damageAmountBase>90</damageAmountBase>
            <arcHeightFactor>0</arcHeightFactor>
            <soundExplode>Explosion_Bomb</soundExplode>
			<armorPenetrationBase>1.2</armorPenetrationBase>
			<stoppingPower>1.2</stoppingPower>
		</projectile>
	    <modExtensions>
		  <li Class="SRA.TailBulletDef">
       		   <tailFleckDef>KT_Fleck_blue_particle_Tail_II</tailFleckDef>
      	 	   <fleckMakeFleckTickMax>10</fleckMakeFleckTickMax><!-- 疑似无效 -->
			   <fleckDelayTicks>5</fleckDelayTicks><!-- 出膛后多久出现轨迹 -->
			   <fleckMakeFleckNum>1</fleckMakeFleckNum>
     	  </li>
          <li Class="SRA.MultiExplosiveExtension">
            <multiexplosions>
            <li>
            <radius>2.5</radius>
            <damageDef>KTBLUEBomb</damageDef>
            <damageAmount>90</damageAmount>
            <armorPenetration>1.2</armorPenetration>
            <explosionSound>Explosion_Bomb</explosionSound>
            <explosionDamageFalloff>true</explosionDamageFalloff><!-- 默认true -->
            <onlyAntiHostile>true</onlyAntiHostile> <!-- 智能弹药：这个爆炸只伤害敌对目标，默认false -->
            <!-- 现阶段就支持这么多参数 -->
          </li>
		  <li>
			<radius>4</radius>
			<damageDef>EMP</damageDef>
			<damageAmount>60</damageAmount>
			<armorPenetration>8</armorPenetration>
			<explosionSound>Explosion_EMP</explosionSound>
			<explosionDamageFalloff>true</explosionDamageFalloff>
			<onlyAntiHostile>true</onlyAntiHostile>
		  </li>
        </multiexplosions>
      </li>
    </modExtensions>
  </ThingDef>
  
  
