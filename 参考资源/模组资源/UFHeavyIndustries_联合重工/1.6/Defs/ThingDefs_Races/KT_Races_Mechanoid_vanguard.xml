  <ThingDef ParentName="BaseBullet">
    <defName>KT_Bullet_Main_battlewalker_main_gun</defName>
    <label>KT_Bullet_Main_battlewalker_main_gun</label>
    <thingClass>SRA.Projectile_MultiExplosive</thingClass>
        <category>Projectile</category>
        <tickerType>Normal</tickerType>
        <altitudeLayer>Projectile</altitudeLayer>
        <graphicData>
            <texPath>Things/Projectile/Bullet_381MM</texPath> <!-- 子弹贴图路径 -->
            <graphicClass>Graphic_Single</graphicClass> <!-- 使用单一图形 -->
			<shaderType>MoteGlow</shaderType>
      		<drawSize>(2.6)</drawSize>
        </graphicData>
        <projectile>
            <damageDef>Bomb</damageDef>
            <explosionRadius>4</explosionRadius>
            <speed>180</speed>
            <damageAmountBase>300</damageAmountBase>
            <arcHeightFactor>0</arcHeightFactor>
            <soundExplode>Explosion_Rocket</soundExplode>
			<flyOverhead>true</flyOverhead>
			<armorPenetrationBase>1.8</armorPenetrationBase>
			<stoppingPower>1.5</stoppingPower>
		</projectile>
		<modExtensions>
        <li Class="SRA.MultiExplosiveExtension">
        <multiexplosions>
          <li>
            <radius>4</radius>
            <damageDef>Bomb</damageDef>
            <damageAmount>300</damageAmount>
            <armorPenetration>1.8</armorPenetration>
            <explosionSound>Explosion_Bomb</explosionSound>
            <explosionDamageFalloff>true</explosionDamageFalloff><!-- 默认true -->
            <onlyAntiHostile>false</onlyAntiHostile> <!-- 智能弹药：这个爆炸只伤害敌对目标，默认false -->
            <!-- 现阶段就支持这么多参数 -->
          </li>
        </multiexplosions>
        <bulletLaunches>
          <li>
            <projectileDef>KT_Bullet_AG_TANK_Turret</projectileDef>
            <bulletCount>5</bulletCount>
            <angleRange>120</angleRange>
            <distanceRange>
              <min>4</min>
              <max>8</max>
            </distanceRange>
          </li>
        </bulletLaunches>
      </li>
    </modExtensions>
  </ThingDef>
  
