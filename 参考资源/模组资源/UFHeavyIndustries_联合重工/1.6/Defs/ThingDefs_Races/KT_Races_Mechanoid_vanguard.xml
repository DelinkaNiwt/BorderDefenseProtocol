  <ThingDef ParentName="BaseBullet">
    <defName>KT_Main_battlewalker_EMPlauncher_BULLET</defName>
    <label>KTEMPMORTAR_BULLET</label>
    <thingClass>SRA.Projectile_MultiExplosive_NorthArcTrail</thingClass>
    <graphicData>
      <texPath>Things/Projectile/Bullet_MORTAR_II</texPath>
