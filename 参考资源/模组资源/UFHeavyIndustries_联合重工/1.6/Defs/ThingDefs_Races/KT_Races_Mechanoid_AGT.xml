		   <targetParams>
			   <canTargetLocations>true</canTargetLocations>
		   </targetParams>
      </li>
		</verbs>
		<tools>
			<li>
				<label>Trample</label>
				<capacities>
					<li>Blunt</li>
				</capacities>
				<power>64</power>
				<cooldownTime>2</cooldownTime>
			</li>
		</tools>
		
	</ThingDef>
	
	
