    <ThingDef ParentName="BaseBullet">
    <defName>KT_Bullet_AG_TANK_Turret_Rocket</defName>
    <label>"Iron Curtain" Rocket Launcher</label>
    <thingClass>SRA.Projectile_MultiExplosive_NorthArcTrail</thingClass>
    <graphicData>
      <texPath>Things/Projectile/Bullet_doommissile</texPath>
      <graphicClass>Graphic_Single</graphicClass>
      <shaderType>TransparentPostLight</shaderType>
	    <drawSize>1.3</drawSize>
    </graphicData>
    <projectile>
			<damageDef>Bomb</damageDef>
			<explosionRadius>4.5</explosionRadius>
			<damageAmountBase>55</damageAmountBase>
			<armorPenetrationBase>1.2</armorPenetrationBase>
			<stoppingPower>3</stoppingPower>
			<speed>80</speed>
      <flyOverhead>true</flyOverhead>
      <soundHitThickRoof>Artillery_HitThickRoof</soundHitThickRoof>
      <soundImpactAnticipate>MortarRound_PreImpact</soundImpactAnticipate>
      <soundAmbient>MortarRound_Ambient</soundAmbient>
    </projectile>
    <modExtensions>
      <li Class="SRA.NorthArcModExtension">
        <northOffsetDistance>5</northOffsetDistance>
        <curveSteepness>1.5</curveSteepness>
        <useArcTrajectory>true</useArcTrajectory>
      </li>
      <li Class="SRA.TailBulletDef">
        <tailFleckDef>KT_Fleck_Smoke_Tail</tailFleckDef>
        <fleckMakeFleckTickMax>5</fleckMakeFleckTickMax>
        <fleckDelayTicks>1</fleckDelayTicks>
        <fleckMakeFleckNum>1~2</fleckMakeFleckNum>
        <fleckScale>0.5~1.0</fleckScale>
        <fleckSpeed>0.1~0.3</fleckSpeed>
        <fleckAngle>-30~30</fleckAngle>
      </li>
      <li Class="SRA.MultiExplosiveExtension">
        <multiexplosions>
          <li>
            <radius>4.5</radius>
            <damageDef>Bomb</damageDef>
            <damageAmount>60</damageAmount>
            <armorPenetration>1.2</armorPenetration>
            <explosionSound>Explosion_Bomb</explosionSound>
            <explosionDamageFalloff>true</explosionDamageFalloff>
            <!--explosionEffect>SRA_GiantExplosion</explosionEffect>
            <explosionEffectLifetimeTicks>180</explosionEffectLifetimeTicks--> 
            <onlyAntiHostile>false</onlyAntiHostile>
          </li>
        </multiexplosions>
      </li>
    </modExtensions>
  </ThingDef>
  
