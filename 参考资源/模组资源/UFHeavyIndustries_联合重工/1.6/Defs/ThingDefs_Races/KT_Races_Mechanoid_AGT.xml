<?xml version="1.0" encoding="utf-8"?>
<Defs>

  <ThingDef Name="KT_AG_TANK" ParentName="KTSuperHeavyMechanoid">
    <defName>KT_AG_TANK</defName> <!-- 修改了defName以避免冲突 -->
    <label>KT_AG_TANK</label>
    <description>KT_AG_TANK</description>
    <statBases>
      <BandwidthCost>6</BandwidthCost>
      <MoveSpeed>6</MoveSpeed>
    </statBases>
    <race>
      <body>Mech_Warqueen</body>
      <baseBodySize>6</baseBodySize>
      <lifeStageAges>
        <li>
          <def>MechanoidFullyFormed</def>
          <minAge>0</minAge>
          <soundWounded>Pawn_Mech_Warqueen_Wounded</soundWounded>
          <soundDeath>Pawn_Mech_Warqueen_Death</soundDeath>
          <soundCall>Pawn_Mech_Warqueen_Call</soundCall>
        </li>
      </lifeStageAges>
      <baseHealthScale>10</baseHealthScale>
      <!-- <thinkTreeConstant>WarUrchinConstant</thinkTreeConstant> -->
    </race>
    <tools>
      <li>
        <label>Trample</label>
        <capacities>
          <li>Blunt</li>
        </capacities>
        <power>300</power>
        <cooldownTime>6</cooldownTime>
        <linkedBodyPartsGroup>Torso</linkedBodyPartsGroup>
        <ensureLinkedBodyPartsGroupAlwaysUsable>true</ensureLinkedBodyPartsGroupAlwaysUsable>
      </li>
    </tools>
    <damageMultipliers>
      <li>
        <damageDef>Flame</damageDef>
        <multiplier>0</multiplier>
      </li>
      <li>
        <damageDef>EMP</damageDef>
        <multiplier>0</multiplier>
      </li>
    </damageMultipliers>
	<statBases>
	  <IncomingDamageFactor>0.3</IncomingDamageFactor>
    </statBases>
    <comps>
      <!--加上这个组件的机械体会直接跳过原版指挥范围判定-->
      <li Class="SRA.CompProperties_GlobalMechCommand" />
      <li Class="CompProperties_CanBeDormant" />
      <li Class="CompProperties_WakeUpDormant">
        <wakeUpOnDamage>true</wakeUpOnDamage>
        <wakeUpCheckRadius>30</wakeUpCheckRadius>
        <wakeUpSound>MechanoidsWakeUp</wakeUpSound>
      </li>
      <li Class="SRA.CompProperties_VehicleWeapon">
        <drawData>
          <dataEast>
            <offset>(0,0,0)</offset>
			<layer>10</layer>
          </dataEast>
          <dataWest>
            <offset>(0,0,0.27)</offset>
            <layer>20</layer>
          </dataWest>
          <dataSouth>
            <offset>(-0.12,0,0.05)</offset>
			<layer>40</layer>
          </dataSouth>
          <dataNorth>
            <offset>(0.15,0,0)</offset>
          </dataNorth>
        </drawData>
        <turretRotationFollowPawn>true</turretRotationFollowPawn>
        <rotationSmoothTime>0.20</rotationSmoothTime>
      </li>
      <li Class="SRA.CompProperties_MultiTurretGun">
		    <ID>0</ID>
        <turretDef>KT_AG_TANK_LMG</turretDef>
        <!-- <angleOffset>-90</angleOffset> -->
        <renderNodeProperties>
          <li>
            <nodeClass>PawnRenderNode_TurretGun</nodeClass>
            <workerClass>PawnRenderNodeWorker_TurretGun</workerClass>
            <parentTagDef>Body</parentTagDef>
            <overrideMeshSize>(2,2)</overrideMeshSize>
            <pawnType>Any</pawnType>
            <drawData>
              <dataNorth>
                <offset>(0.95, 0, 1.6)</offset>
				<rotationOffset>270</rotationOffset>
                <flip>true</flip>
                <layer>40</layer>
              </dataNorth>
			  <dataSouth>
			    <layer>40</layer>
			    <rotationOffset>270</rotationOffset>
                <offset>(-0.9, 0,-1.5)</offset>
              </dataSouth>
              <dataEast>
                <layer>40</layer>
				<rotationOffset>270</rotationOffset>
                <offset>(1.6, 0, -0.7)</offset>
              </dataEast>
              <dataWest>
			  <layer>40</layer>
                <offset>(-1.55, 0, 0.85)</offset>
				<rotationOffset>-270</rotationOffset>
              </dataWest>
            </drawData>
          </li>
        </renderNodeProperties>
      </li> 
	  <li Class="SRA.CompProperties_PawnRenderExtra">
        <path>Things/Pawn/Mechanoid/KT_AG_TANK_light</path>
        <size>(12,0,12)</size>
        <colorAlly>(255,255,255)</colorAlly>
        <colorEnemy>(255,255,255)</colorEnemy>
        <shader>TransparentPostLight</shader>
        <drawData>
          <dataEast>
            <offset>(0,0,0)</offset>
            <layer>1</layer>
          </dataEast>
          <dataWest>
            <offset>(0,0,0)</offset>
            <layer>1</layer>
          </dataWest>
          <dataSouth>
            <offset>(0,0,0)</offset>
            <layer>1</layer>
          </dataSouth>
          <dataNorth>
            <offset>(0,0,0)</offset>
            <layer>1</layer>
          </dataNorth>
        </drawData>
      </li>
    </comps>
  </ThingDef>
