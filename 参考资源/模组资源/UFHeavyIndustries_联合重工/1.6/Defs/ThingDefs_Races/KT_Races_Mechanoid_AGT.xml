  <ThingDef ParentName="KT_Mecha_WeaponBase">
		<defName>KT_AG_TANK_Turret</defName>
		<label>KT_AG_TANK_Turret</label>
		<description>KT_AG_TANK_Turret</description>
		<graphicData>
			<texPath>Things/Pawn/Mechanoid/KT_AG_TANK_turret</texPath>
			<graphicClass>Graphic_Single</graphicClass>
			<drawSize>(12, 6)</drawSize>
		</graphicData>
		<uiIconScale>0.5</uiIconScale>
		<equippedAngleOffset>0</equippedAngleOffset>
    	<smeltable>false</smeltable>
		<statBases>
			<MarketValue>1600</MarketValue>
			<MaxHitPoints>640</MaxHitPoints>
			<Mass>200</Mass>
			<AccuracyTouch>0.8</AccuracyTouch>
			<AccuracyShort>0.8</AccuracyShort>
			<AccuracyMedium>0.9</AccuracyMedium>
			<AccuracyLong>0.75</AccuracyLong>
			<RangedWeapon_Cooldown>2.5</RangedWeapon_Cooldown>
			<Flammability>0</Flammability>
		</statBases>
		<tradeability>None</tradeability>
		<relicChance>0</relicChance>
		<weaponTags>
			<li>KT_AG_TANK_Turret</li>
		</weaponTags>
		<verbs>
      <li>
        <verbClass>Verb_Shoot</verbClass>
        <defaultProjectile>KT_Bullet_AG_TANK_Turret</defaultProjectile>
        <hasStandardCommand>true</hasStandardCommand>
         <warmupTime>2</warmupTime>
         <range>120</range>
		 <minRange>5</minRange>
         <soundCast>KT_Largecannon_V</soundCast>
		 <ticksBetweenBurstShots>20</ticksBetweenBurstShots>
		 <burstShotCount>3</burstShotCount>
        <soundCastTail>GunTail_Heavy</soundCastTail>
        <muzzleFlashScale>25</muzzleFlashScale>
