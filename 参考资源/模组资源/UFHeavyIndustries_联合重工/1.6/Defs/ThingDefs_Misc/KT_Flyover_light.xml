<?xml version="1.0" encoding="utf-8"?>
<Defs>
  <ThingDef Parent="EtherealThingBase">
    <defName>KT_FlyOver_Bomber</defName>
    <label>KT_FlyOver_Bomber</label>
    <thingClass>SRA.FlyOver</thingClass>
    <tickerType>Normal</tickerType>
    <drawerType>RealtimeOnly</drawerType>
    <graphicData>
      <!-- <texPath>ArachnaeSwarm/Weapon/ARA_Weapon_Empty</texPath> -->
      <texPath>Things/FlyOverThing/KT_Bomber</texPath>
      <graphicClass>Graphic_Single</graphicClass>
      <shaderType>TransparentPostLight</shaderType>
      <drawSize>(28,28)</drawSize>
      <color>(255,255,255,255)</color>
    </graphicData>
    <castEdgeShadows>false</castEdgeShadows>
    <staticSunShadowHeight>0</staticSunShadowHeight>
    <skyfaller>
      <shadow>Things/FlyOverThing/KT_EMPTY</shadow>
      <shadowSize>(0, 0)</shadowSize>
      <motesPerCell>0</motesPerCell>
      <floatingSound></floatingSound>
      <impactSound></impactSound>
    </skyfaller>
    <modExtensions>
      <li Class="SRA.FlyOverShadowExtension">
        <customShadowPath>Things/FlyOverThing/KT_EMPTY</customShadowPath>
        <useCustomShadow>true</useCustomShadow>
        <shadowIntensity>0.8</shadowIntensity>
        <minShadowAlpha>0</minShadowAlpha>
        <maxShadowAlpha>0</maxShadowAlpha>
        <minShadowScale>0</minShadowScale>
        <maxShadowScale>0</maxShadowScale>
      </li>
    </modExtensions>
    <seeThroughFog>true</seeThroughFog>
    <useHitPoints>false</useHitPoints>
    <selectable>false</selectable>
    <alwaysHaulable>false</alwaysHaulable>
    <altitudeLayer>MetaOverlays</altitudeLayer>
    <comps>
	  <!-- 入场音效 -->
      <li Class="SRA.CompProperties_PlaySoundOnSpawn">
        <sound>KT_flyby</sound>
      </li>
	<!-- 扫射 -->
      <li Class="SRA.CompProperties_GroundStrafing">
        <projectileDef>KT_FlyOver_Bomber_bullet</projectileDef>
        <range>120</range>
    
        <!-- 横向偏移配置（左右） -->
        <lateralOffsetDistance>18</lateralOffsetDistance>
        <lateralInitialOffsetAngle>0</lateralInitialOffsetAngle>
        <lateralMaxOffsetAngle>0</lateralMaxOffsetAngle>
        <lateralAngleIncrement>0</lateralAngleIncrement>
        <lateralOffsetMode>Alternating</lateralOffsetMode>
        
        <!-- 纵向偏移配置（前后） -->
        <longitudinalInitialOffset>25</longitudinalInitialOffset>
        <longitudinalMinOffset>0</longitudinalMinOffset>
        <longitudinalMaxOffset>0</longitudinalMaxOffset>
        <longitudinalOffsetMode>Fixed</longitudinalOffsetMode>

        <!-- 视觉效果 -->
        <spawnOffsetEffect>true</spawnOffsetEffect>
        <offsetEffectDef>Mote_SparkSimple</offsetEffectDef>
      </li>
	  <!-- 攻击范围内目标 -->
      <li Class="SRA.CompProperties_SectorSurveillance">
        <projectileDef>KT_FlyOver_Bomber_bullet</projectileDef>
        <sectorAngle>30</sectorAngle>      <!-- 扇形角度 -->
        <sectorRange>120</sectorRange>      <!-- 射程 -->
        <shotCount>1</shotCount>           <!-- 发射次数 -->
        <shotInterval>2</shotInterval>   <!-- 发射间隔 -->
        <maxProjectiles>6</maxProjectiles><!-- 最大射弹数量限制-->
    
        <!-- 横向偏移配置（左右） -->
        <lateralOffsetDistance>18</lateralOffsetDistance>
        <lateralInitialOffsetAngle>0</lateralInitialOffsetAngle>
        <lateralMaxOffsetAngle>0</lateralMaxOffsetAngle>
        <lateralAngleIncrement>0</lateralAngleIncrement>
        <lateralOffsetMode>Alternating</lateralOffsetMode>
        
        <!-- 纵向偏移配置（前后） -->
        <longitudinalInitialOffset>25</longitudinalInitialOffset>
        <longitudinalMinOffset>0</longitudinalMinOffset>
        <longitudinalMaxOffset>0</longitudinalMaxOffset>
        <longitudinalOffsetMode>Fixed</longitudinalOffsetMode>

        <!-- 视觉效果 -->
        <spawnOffsetEffect>true</spawnOffsetEffect>
        <offsetEffectDef>Mote_SparkSimple</offsetEffectDef>
      </li>
    </comps>
  </ThingDef>
  
  <ThingDef>
        <defName>KT_FlyOver_Bomber_bullet</defName>
        <label>KT_FlyOver_Bomber_bullet</label>
        <thingClass>SRA.Projectile_MultiExplosive</thingClass>
        <category>Projectile</category>
        <tickerType>Normal</tickerType>
        <altitudeLayer>Projectile</altitudeLayer>
        <graphicData>
            <texPath>Things/Projectile/Bullet_doommissile</texPath> <!-- 子弹贴图路径 -->
            <graphicClass>Graphic_Single</graphicClass> <!-- 使用单一图形 -->
      		<drawSize>(2)</drawSize>
        </graphicData>
        <projectile>
            <damageDef>EMP</damageDef>
			<flyOverhead>true</flyOverhead>
            <explosionRadius>6</explosionRadius>
            <speed>180</speed>
            <damageAmountBase>350</damageAmountBase>
            <arcHeightFactor>0</arcHeightFactor>
            <soundExplode>Explosion_Rocket</soundExplode>
			<armorPenetrationBase>2.5</armorPenetrationBase>
        </projectile>
		<modExtensions>
		  <li Class="SRA.TailBulletDef">
       		 <tailFleckDef>KT_Fleck_Smoke_Tail</tailFleckDef>
			 <fleckDelayTicks>35</fleckDelayTicks><!-- 出膛后多久出现轨迹 -->
			 <fleckMakeFleckNum>1</fleckMakeFleckNum>
			 <!--FloatRangefleckAngle>90</FloatRangefleckAngle -->
     	  </li>
        <li Class="SRA.MultiExplosiveExtension">
        <multiexplosions>
          <li>
            <radius>6</radius>
            <damageDef>KTBLUEBomb</damageDef>
            <damageAmount>350</damageAmount>
            <armorPenetration>1.5</armorPenetration>
            <explosionSound>KT_explosion</explosionSound>
            <explosionDamageFalloff>true</explosionDamageFalloff><!-- 默认true -->
            <onlyAntiHostile>false</onlyAntiHostile> <!-- 智能弹药：这个爆炸只伤害敌对目标，默认false -->
            <!-- 现阶段就支持这么多参数 -->
          </li>
		  <li>
			<radius>4</radius>
			<damageDef>EMP</damageDef>
			<damageAmount>60</damageAmount>
			<armorPenetration>8</armorPenetration>
			<explosionSound>Explosion_EMP</explosionSound>
			<explosionDamageFalloff>true</explosionDamageFalloff>
			<onlyAntiHostile>true</onlyAntiHostile>
		  </li>
        </multiexplosions>
      </li>
    </modExtensions>
  </ThingDef>	
  
  
  
