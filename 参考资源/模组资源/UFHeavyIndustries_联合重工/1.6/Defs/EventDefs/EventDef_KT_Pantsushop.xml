        <effects>
		<!-- 当前时间减去购买时间变量 -->
		  <li Class="SRA.Effect_ModifyVariable">
            <name>KT_Current_time_trade</name>
            <valueVariableName>KT_Purchase_time_trade</valueVariableName>
            <operation>Subtract</operation>
          </li>
        </effects>
      </li>
