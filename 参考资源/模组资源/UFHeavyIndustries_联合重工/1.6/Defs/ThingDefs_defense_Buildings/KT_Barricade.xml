      <li>KT_Barricade</li>
    </replaceTags>
    <graphicData>
      <texPath>Things/Building/Barricade/KT_Barricade</texPath>
      <graphicClass>Graphic_Single</graphicClass>
	  <shaderType>CutoutComplex</shaderType>
      <linkType>Basic</linkType>
      <linkFlags>
        <li>Barricades</li>
