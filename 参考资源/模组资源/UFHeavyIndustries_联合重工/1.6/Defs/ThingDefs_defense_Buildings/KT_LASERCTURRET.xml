<Defs>
	<ThingDef ParentName="KT_AutocannonTurret">
    <defName>KTLASERTURRET</defName>
    <label>KTLASERTURRET</label>
	<thingClass>SRA.Building_TurretGunHasSpeed</thingClass>
	<modExtensions>
	   <li Class="SRA.ModExt_HasSpeedTurret"><!-- SRA炮塔转速 -->
		 <speed>1.8</speed>
	   </li>
  	</modExtensions>
    <description>KTLASERTURRET</description>
    <uiIconPath>Things/Building/Security/KTLASERTURRET_Ico</uiIconPath>
	<uiOrder>1800</uiOrder> <!-- UI栏顺序 -->
	<graphicData>
		<texPath>Things/Building/Security/KT100MMCANNON_Base</texPath>
		<graphicClass>Graphic_Single</graphicClass>
		<drawSize>(6,6)</drawSize>
	</graphicData>
	<size>(3,3)</size>
    <statBases>
	  <MaxHitPoints>3600</MaxHitPoints>
	  <Flammability>0</Flammability>
      <ShootingAccuracyTurret>1</ShootingAccuracyTurret>
	  <WorkToBuild>1800</WorkToBuild>
    </statBases>
	<drawerType>MapMeshAndRealTime</drawerType>
	<tickerType>Normal</tickerType>
	<killedLeavings>
      <ChunkSlagSteel>3</ChunkSlagSteel>
    </killedLeavings>
    <costList>
      <Steel>800</Steel>
	  <Plasteel>150</Plasteel>
      <ComponentIndustrial>5</ComponentIndustrial>
	  <ComponentSpacer>6</ComponentSpacer>
    </costList>
    <comps>
	  <li Class="SRA.CompProperties_ForceTargetable" /><!-- 善良手操 -->	
      <li Class="CompProperties_Forbiddable"/>
      <li Class="CompProperties_Power">
        <compClass>CompPowerTrader</compClass>
        <basePowerConsumption>2500</basePowerConsumption>
      </li>
      <li Class="CompProperties_Flickable"/>
      <li Class="CompProperties_Breakdownable"/>
    </comps>

    <building>
      <turretGunDef>Gun_KTLASERTURRET</turretGunDef>
	  <ai_combatDangerous>true</ai_combatDangerous> <!-- AI认为它具有危险性 -->
	  <turretTopDrawSize>7</turretTopDrawSize>
	   <turretTopOffset>(0, -0.1)</turretTopOffset>
      <turretBurstCooldownTime>3</turretBurstCooldownTime>
    </building>
    <researchPrerequisites>
      <li>KT_Base_t3_energy_turret</li>
    </researchPrerequisites>
	<designationCategory>KT_designation_group</designationCategory> <!-- 指定分类：联合 -->

	
  </ThingDef>
  
  <ThingDef ParentName="BaseWeaponTurret">
    <defName>Gun_KTLASERTURRET</defName>
    <label>Gun_KTLASERTURRET</label>
    <description>Gun_KTLASERTURRET</description>
    <graphicData>
      <texPath>Things/Building/Security/KTLASERTURRET</texPath>
      <graphicClass>Graphic_Single</graphicClass>
      <drawSize>(3.8,3.8)</drawSize>
    </graphicData>
    <statBases>
      <AccuracyTouch>1</AccuracyTouch>
      <AccuracyShort>1</AccuracyShort>
      <AccuracyMedium>1</AccuracyMedium>
      <AccuracyLong>1</AccuracyLong>
      <RangedWeapon_Cooldown>3</RangedWeapon_Cooldown>
      <DeteriorationRate>0</DeteriorationRate>
      <Mass>40</Mass>
      <Flammability>0</Flammability>
    </statBases>
	<verbs>
      <li>
        <verbClass>SRA.Verb_ShootWithOffset</verbClass> <!-- 射击行为 -->
        <hasStandardCommand>true</hasStandardCommand>
        <defaultProjectile>Bullet_KTLASERTURRET</defaultProjectile>
        <warmupTime>0.3</warmupTime>
        <minRange>5</minRange>
        <range>100</range> <!-- 射程 -->
		<burstShotCount>1</burstShotCount>
        <soundCast>KT_Beamflashlight_heavy</soundCast>
        <soundCastTail>GunTail_Medium</soundCastTail>
        <muzzleFlashScale>80</muzzleFlashScale>
        <aimingChargeMote>Mote_BeamRepeater_Charge</aimingChargeMote>
        <aimingChargeMoteOffset>0.1</aimingChargeMoteOffset>
      </li>
    </verbs>
	<weaponTags>
	  <li>KT_weapon</li>
    </weaponTags>
	<modExtensions>
      <li Class="MuzzleFlash.MuzzleFlashProps" MayRequire="IssacZhuang.MuzzleFlash">
         <def>MF_ChargedMuzzleFalsh</def>
         <drawSize>(2)</drawSize>
         <offsets>
           <li>(0.2,0)</li>
         </offsets>
         <isAlternately>true</isAlternately>
     </li>	 
   </modExtensions>
  </ThingDef>
  
  <ThingDef ParentName="BaseBullet">
    <defName>Bullet_KTLASERTURRET</defName>
    <label>Bullet_KTLASERTURRET</label>
    <thingClass>SRA.Projectile_MultiExplosive_Beam</thingClass>
    <graphicData>
      <texPath>Things/Projectile/Bullet_KT_flashlight</texPath>
      <graphicClass>Graphic_Single</graphicClass>
    </graphicData>
    <projectile>
      <damageDef>KT_Beamflashlight</damageDef>
	  <explosionRadius>3</explosionRadius>
      <damageAmountBase>70</damageAmountBase>
      <beamMoteDef>KT_Beamflashlight_turret_blue</beamMoteDef>
      <beamStartOffset>0</beamStartOffset>
      <armorPenetrationBase>1.2</armorPenetrationBase>
	  <stoppingPower>1</stoppingPower>
    </projectile>
    
    <modExtensions>
      <li Class="SRA.MultiExplosive_BeamExtension">
        <MultiExplosive_Beams>
		  <li>
            <radius>3</radius>
            <damageDef>EMP</damageDef>
            <damageAmount>50</damageAmount>
            <armorPenetration>4</armorPenetration>
            <explosionSound>Explosion_EMP</explosionSound>
            <explosionDamageFalloff>true</explosionDamageFalloff>
          </li>
          <li>
            <radius>2</radius>
            <damageDef>KTBLUEBomb_slow</damageDef>
            <damageAmount>50</damageAmount>
            <armorPenetration>1.2</armorPenetration>
            <explosionSound>Explosion_Bomb</explosionSound>
            <explosionDamageFalloff>true</explosionDamageFalloff><!-- 默认true -->
            <onlyAntiHostile>false</onlyAntiHostile> <!-- 智能弹药：这个爆炸只伤害敌对目标，默认false -->
          </li>
        </MultiExplosive_Beams>
      </li>
    </modExtensions>
  </ThingDef>

</Defs>