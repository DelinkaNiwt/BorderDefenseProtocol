<?xml version="1.0" encoding="utf-8" ?>

<Defs>
    <ThingDef ParentName="BuildingBase">
        <defName>KT_LARGEAUTOCANNON</defName>
        <label>"Python" 25mm Twin Autocannon</label>
        <description>This turret is equipped with 25mm armor-piercing rounds, designed to shred lightly and moderately armored targets that attempt to close in.</description>
        <thingClass>SRA.Building_TurretGunHasSpeed</thingClass>
		<modExtensions>
	      <li Class="SRA.ModExt_HasSpeedTurret"><!-- SRA炮塔转速 -->
		    <speed>1.9</speed>
	      </li>
  	    </modExtensions>
		
        <uiOrder>1800</uiOrder>
        <size>(3,3)</size>
        <drawerType>MapMeshAndRealTime</drawerType>
        
        <graphicData>
		  <texPath>Things/Building/Security/KT100MMCANNON_Base</texPath>
		  <graphicClass>Graphic_Single</graphicClass>
		  <drawSize>(6,6)</drawSize>
	    </graphicData>

        <castEdgeShadows>False</castEdgeShadows>
        <minifiedDef>MinifiedThing</minifiedDef>
        <uiIconPath>Things/Building/Security/KT_LARGEAUTOCANNON_Ico</uiIconPath> <!-- 图标路径 -->

        <altitudeLayer>Building</altitudeLayer>
        <stealable>false</stealable> <!-- 不可盗窃 -->
        <rotatable>true</rotatable> <!-- 不可旋转 -->
        
        <thingCategories>
            <li>BuildingsSecurity</li> <!-- 建筑类别：安全 -->
        </thingCategories>
        
        <statBases>
            <MaxHitPoints>4800</MaxHitPoints> <!-- 最大生命值 -->
            <Flammability>0</Flammability> <!-- 可燃性 -->
            <WorkToBuild>1800</WorkToBuild> <!-- 建造所需工作时间 -->
            <Mass>120</Mass> <!-- 质量 -->
            <Beauty>-10</Beauty> <!-- 美观度 -->
            <ShootingAccuracyTurret>1</ShootingAccuracyTurret> <!-- 射击精度 -->
        </statBases>

        <tickerType>Normal</tickerType> <!-- 每次更新的计时器类型 -->
        
        <comps>
          <li Class="CompProperties_Forbiddable"/>
		  <li Class="SRA.CompProperties_ForceTargetable" /><!-- 善良手操 -->
            <li Class="CompProperties_Power">
              <compClass>CompPowerTrader</compClass>
              <basePowerConsumption>1000</basePowerConsumption>
            </li>
            <li Class="CompProperties_Flickable"/>
            <li Class="CompProperties_Breakdownable"/>
            <li Class="CompProperties_Refuelable"> <!-- 应该是可以补给 -->
              <fuelLabel>Shots until barrel change</fuelLabel>
              <fuelGizmoLabel>Barrel durability</fuelGizmoLabel>
              <outOfFuelMessage>Needs new barrel</outOfFuelMessage>
              <fuelFilter><thingDefs><li>Steel</li></thingDefs></fuelFilter>
              <fuelCapacity>2500</fuelCapacity>
              <fuelMultiplier>8</fuelMultiplier>
              <initialFuelPercent>1</initialFuelPercent>
              <autoRefuelPercent>0.5</autoRefuelPercent>
              <showFuelGizmo>true</showFuelGizmo>
              <minimumFueledThreshold>1</minimumFueledThreshold>
              <factorByDifficulty>false</factorByDifficulty>
              <consumeFuelOnlyWhenUsed>true</consumeFuelOnlyWhenUsed>
              <fuelIconPath>KT_UI/UI_OUTAMMO</fuelIconPath>
            </li>
        </comps>
        
        <passability>PassThroughOnly</passability> <!-- 只能穿透 -->
        <pathCost>50</pathCost> <!-- 建筑路径成本 -->
        <fillPercent>0.5</fillPercent> <!-- 填充度 -->
        <hasTooltip>true</hasTooltip> <!-- 是否显示工具提示 -->
        
        
        <costList>
            <Steel>500</Steel>
	        <Plasteel>80</Plasteel>
            <ComponentIndustrial>5</ComponentIndustrial>
	        <ComponentSpacer>1</ComponentSpacer>
        </costList>
        
        <generateCommonality>0</generateCommonality>
        <tradeability>None</tradeability>

        <constructionSkillPrerequisite>5</constructionSkillPrerequisite> <!-- 建造技能需求 -->
        <terrainAffordanceNeeded>Light</terrainAffordanceNeeded> <!-- 需要轻型地形 -->
        <designationCategory>KT_designation_group</designationCategory> <!-- 指定分类：安全 -->

        <building>
            <ai_combatDangerous>true</ai_combatDangerous> <!-- AI认为它具有危险性 -->
            <turretGunDef>Gun_KT_LARGEAUTOCANNON</turretGunDef> <!-- 定义使用的枪械 -->
            <deconstructible>true</deconstructible>
            <paintable>true</paintable> <!-- 是否可以涂漆：可以 -->
            <turretTopDrawSize>6.5</turretTopDrawSize>
            <turretTopOffset>(0, 0)</turretTopOffset>
            <turretBurstCooldownTime>0.6</turretBurstCooldownTime> <!-- 炮塔射击冷却时间 -->
            <combatPower>250</combatPower>
        </building>
 		
        <researchPrerequisites>
            <li>KT_Base_t1_turret</li>
        </researchPrerequisites>
		       
        <placeWorkers>
            <li>PlaceWorker_TurretTop</li> <!-- 放置工作：炮塔顶部 -->
        </placeWorkers>
        
    </ThingDef>

    <!-- 定义子弹：Pocket 20MMAC Bullet -->
    <ThingDef ParentName="BaseBullet">
        <defName>Bullet_KT_LARGEAUTOCANNON</defName> <!-- 子弹名称 -->
        <label>25MM bullet</label> <!-- 子弹标签 -->
        <graphicData>
            <texPath>Things/Projectile/Bullet_100MM</texPath> <!-- 子弹贴图路径 -->
            <graphicClass>Graphic_Single</graphicClass> <!-- 使用单一图形 -->
			<drawSize>(1.5)</drawSize>
        </graphicData>
        <projectile>
            <damageDef>Bullet</damageDef> <!-- 子弹伤害类型 -->
            <damageAmountBase>26</damageAmountBase> <!-- 基础伤害量 -->
			<stoppingPower>1.2</stoppingPower>
            <speed>350</speed> <!-- 子弹速度 -->
			<armorPenetrationBase>1.0</armorPenetrationBase>
        </projectile>
    </ThingDef>

    <!-- 定义武器：Pocket 20MMAC Gun -->
    <ThingDef ParentName="BaseWeaponTurret">
        <defName>Gun_KT_LARGEAUTOCANNON</defName> <!-- 武器名称 -->
        <label>"Python" 25mm Twin Autocannon</label> <!-- 武器标签 -->
        <description>This turret is equipped with 25mm armor-piercing rounds, designed to shred lightly and moderately armored targets that attempt to close in.</description> <!-- 武器描述 -->
        <graphicData>
            <texPath>Things/Building/Security/KT_LARGEAUTOCANNON</texPath> <!-- 武器贴图路径 -->
            <graphicClass>Graphic_Single</graphicClass> <!-- 使用单一图形 -->
            <shaderType>CutoutComplex</shaderType>
        </graphicData>
        <soundInteract>Interact_Rifle</soundInteract> <!-- 使用时音效 -->
        <tradeability>None</tradeability> <!-- 不能交易 -->
        <destroyOnDrop>true</destroyOnDrop> <!-- 掉落时销毁 -->
        <generateCommonality>0</generateCommonality>
        <statBases>
            <AccuracyTouch>0.90</AccuracyTouch> <!-- 近距离精度 -->
            <AccuracyShort>1</AccuracyShort> <!-- 短程精度 -->
            <AccuracyMedium>0.85</AccuracyMedium> <!-- 中程精度 -->
            <AccuracyLong>0.80</AccuracyLong> <!-- 长程精度 -->
            <RangedWeapon_Cooldown>0.6</RangedWeapon_Cooldown> <!-- 冷却时间 -->
            <Mass>30</Mass> <!-- 质量 -->
            <Flammability>0</Flammability> <!-- 不可燃 -->
            <DeteriorationRate>0</DeteriorationRate> <!-- 不会腐烂 -->
        </statBases>
		<weaponTags>
	  	  <li>KT_weapon</li>
    	</weaponTags>
        <verbs>
            <li>
                <verbClass>SRA.Verb_ShootWithOffset</verbClass> <!-- 射击行为 -->
                <hasStandardCommand>true</hasStandardCommand> <!-- 标准命令 -->
                <defaultProjectile>Bullet_KT_LARGEAUTOCANNON</defaultProjectile> <!-- 默认子弹 -->
                <warmupTime>0.2</warmupTime> <!-- 预热时间 -->
				<requireLineOfSight>true</requireLineOfSight><!-- 能不能曲射 -->
                <range>80</range> <!-- 射程 -->
				<minRange>4</minRange>
                <burstShotCount>30</burstShotCount> <!-- 每次射击子弹数量 -->
                <ticksBetweenBurstShots>2</ticksBetweenBurstShots>
                <soundCast>KT_AUTOCANNON_VI</soundCast> <!-- 射击音效 -->
                <soundCastTail>GunTail_Light</soundCastTail> <!-- 尾音效 -->
                <muzzleFlashScale>15</muzzleFlashScale> <!-- 火光规模 -->
                <consumeFuelPerShot>1</consumeFuelPerShot> <!-- 每发子弹消耗的燃料 -->
            </li>
        </verbs>
		<modExtensions>
          <li Class="MuzzleFlash.MuzzleFlashProps" MayRequire="IssacZhuang.MuzzleFlash">
            <def>MF_StandardMuzzleFalsh</def>
            <drawSize>(1.5)</drawSize>
            <offsets>
			  <li>(3.05,0.8)</li>
			  <li>(3.05,-0.8)</li>
            </offsets>
            <isAlternately>true</isAlternately>
          </li>
		  <li Class="SRA.ModExtension_ShootWithOffset">
             <offsets>
			  <li>(-0.8,-3.8)</li>
			  <li>(0.8,-3.8)</li>
             </offsets>
          </li>
        </modExtensions>
    </ThingDef>
</Defs>
