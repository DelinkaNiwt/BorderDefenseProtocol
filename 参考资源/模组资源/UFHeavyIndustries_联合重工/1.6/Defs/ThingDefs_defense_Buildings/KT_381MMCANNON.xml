<Defs>
	<ThingDef ParentName="KT_AutocannonTurret">
    <defName>KT381MMCANNON</defName>
    <label>KT381MMCANNON</label>
	<thingClass>SRA.Building_TurretGunHasSpeed</thingClass>
	<modExtensions>
	   <li Class="SRA.ModExt_HasSpeedTurret"><!-- SRA炮塔转速 -->
		 <speed>0.8</speed>
	   </li>
  	</modExtensions>
	
    <description>381MM cannon</description>
    <uiIconPath>Things/Building/Security/KT381MMCANNON_Ico</uiIconPath>
	<uiOrder>2000</uiOrder> <!-- UI栏顺序 -->
	<graphicData>
		<texPath>Things/Building/Security/KT381MMCANNON_Base</texPath>
		<graphicClass>Graphic_Single</graphicClass>
		<drawSize>(17,17)</drawSize>
	</graphicData>
	<size>(7,7)</size>
    <statBases>
	  <MaxHitPoints>7200</MaxHitPoints>
	  <Flammability>0</Flammability>
      <ShootingAccuracyTurret>1</ShootingAccuracyTurret>
	  <WorkToBuild>3000</WorkToBuild>
    </statBases>
	<drawerType>MapMeshAndRealTime</drawerType>
	<tickerType>Normal</tickerType>
	<killedLeavings>
      <ChunkSlagSteel>3</ChunkSlagSteel>
    </killedLeavings>
    <costList>
      <KT_steel>400</KT_steel>
      <ComponentIndustrial>40</ComponentIndustrial>
	  <ComponentSpacer>20</ComponentSpacer>
    </costList>
    <comps>
	  <li Class="SRA.CompProperties_ForceTargetable" /><!-- 善良手操 -->
      <li Class="CompProperties_Forbiddable"/>
      <li Class="CompProperties_Power">
        <compClass>CompPowerTrader</compClass>
        <basePowerConsumption>8000</basePowerConsumption>
      </li>
      <li Class="CompProperties_Flickable"/>
      <li Class="CompProperties_Breakdownable"/>
      <li Class="CompProperties_Refuelable"> <!-- 应该是可以补给 -->
        <fuelLabel>Shots until barrel change</fuelLabel>
        <fuelGizmoLabel>Barrel durability</fuelGizmoLabel>
        <outOfFuelMessage>Needs new barrel</outOfFuelMessage>
        <fuelFilter><thingDefs><li>ComponentSpacer</li></thingDefs></fuelFilter>
        <fuelCapacity>30</fuelCapacity>
        <fuelMultiplier>2</fuelMultiplier>
        <initialFuelPercent>1</initialFuelPercent>
        <autoRefuelPercent>0.5</autoRefuelPercent>
        <showFuelGizmo>true</showFuelGizmo>
        <minimumFueledThreshold>1</minimumFueledThreshold>
        <factorByDifficulty>false</factorByDifficulty>
        <consumeFuelOnlyWhenUsed>true</consumeFuelOnlyWhenUsed>
        <fuelIconPath>KT_UI/UI_OUTAMMO</fuelIconPath>
      </li>
    </comps>

    <building>
      <turretGunDef>Gun_KT381MMCANNON</turretGunDef>
	  <ai_combatDangerous>true</ai_combatDangerous> <!-- AI认为它具有危险性 -->
	  <turretTopDrawSize>15</turretTopDrawSize>
	   <turretTopOffset>(0, 0)</turretTopOffset>
      <turretBurstCooldownTime>15</turretBurstCooldownTime>
    </building>
    <researchPrerequisites>
      <li>KT_Base_t3_Artillery_turret</li>
    </researchPrerequisites>
	<designationCategory>KT_designation_group</designationCategory> <!-- 指定分类：联合 -->

  </ThingDef>
  
  <ThingDef ParentName="BaseWeaponTurret">
    <defName>Gun_KT381MMCANNON</defName>
    <label>Gun_KT381MMCANNON</label>
    <description>381MM cannon</description>
    <graphicData>
      <texPath>Things/Building/Security/KT381MMCANNON</texPath>
      <graphicClass>Graphic_Single</graphicClass>
      <drawSize>(25,25)</drawSize>
    </graphicData>
    <statBases>
      <AccuracyTouch>0.70</AccuracyTouch>
      <AccuracyShort>0.65</AccuracyShort>
      <AccuracyMedium>0.50</AccuracyMedium>
      <AccuracyLong>0.35</AccuracyLong>
      <RangedWeapon_Cooldown>15</RangedWeapon_Cooldown>
      <DeteriorationRate>0</DeteriorationRate>
      <Mass>80</Mass>
      <Flammability>0</Flammability>
    </statBases>
	<verbs>
      <li>
        <verbClass>SRA.Verb_ShootWithOffset</verbClass> <!-- 射击行为 -->
        <hasStandardCommand>true</hasStandardCommand> <!-- 标准命令 -->
        <defaultProjectile>Bullet_KT381MMCANNON</defaultProjectile> <!-- 默认子弹 -->
        <warmupTime>3</warmupTime> <!-- 预热时间 -->
		<requireLineOfSight>false</requireLineOfSight><!-- 只能直线射击 -->
		<minRange>45</minRange>
        <range>500</range> <!-- 射程 -->
        <burstShotCount>3</burstShotCount> <!-- 每次射击子弹数量 -->
		<ticksBetweenBurstShots>20</ticksBetweenBurstShots>
        <soundCast>KT_Largecannon_II</soundCast> <!-- 射击音效 -->
        <soundCastTail>GunTail_Heavy</soundCastTail> <!-- 尾音效 -->
        <muzzleFlashScale>80</muzzleFlashScale> <!-- 火光规模 -->
        <consumeFuelPerShot>1</consumeFuelPerShot> <!-- 每发子弹消耗的燃料 -->
		<forcedMissRadius>0.5</forcedMissRadius>
		<targetParams>
			<canTargetLocations>true</canTargetLocations>
		</targetParams>
      </li>
    </verbs>
	<weaponTags>
	  <li>KT_weapon</li>
    </weaponTags>
	<modExtensions>
      <li Class="MuzzleFlash.MuzzleFlashProps" MayRequire="IssacZhuang.MuzzleFlash">
         <def>MF_StandardMuzzleFalsh</def>
         <drawSize>(5)</drawSize>
         <offsets>
           <li>(7.4,0.8)</li>
		   <li>(7.4,0)</li>
		   <li>(7.4,-0.8)</li>
         </offsets>
         <isAlternately>true</isAlternately>
     </li>
	 <li Class="SRA.ModExtension_ShootWithOffset">
         <offsets>
           <li>(-0.8,-8.2)</li><!-- 第一个参数是东西（负数为东）。第二个参数为南北（负数为朝北） -->
		   <li>(0.8,-8.2)</li>
		   <li>(0,-8.2)</li>
         </offsets>
     </li>		 
   </modExtensions>
  </ThingDef>
  
  <ThingDef>
        <defName>Bullet_KT381MMCANNON</defName>
        <label>KT381MMCANNON</label>
        <thingClass>Projectile_Explosive</thingClass>
        <category>Projectile</category>
        <tickerType>Normal</tickerType>
        <altitudeLayer>Projectile</altitudeLayer>
        <graphicData>
            <texPath>Things/Projectile/Bullet_381MM</texPath> <!-- 子弹贴图路径 -->
            <graphicClass>Graphic_Single</graphicClass> <!-- 使用单一图形 -->
			<shaderType>MoteGlow</shaderType>
      		<drawSize>(4)</drawSize>
        </graphicData>
        <projectile>
            <damageDef>Bomb</damageDef>
			<flyOverhead>true</flyOverhead>
            <explosionRadius>5</explosionRadius>
            <speed>180</speed>
			<stoppingPower>3</stoppingPower>
            <damageAmountBase>500</damageAmountBase>
            <arcHeightFactor>0</arcHeightFactor>
            <soundExplode>Explosion_Rocket</soundExplode>
			<armorPenetrationBase>1.5</armorPenetrationBase>
        </projectile>
  </ThingDef>	

</Defs>