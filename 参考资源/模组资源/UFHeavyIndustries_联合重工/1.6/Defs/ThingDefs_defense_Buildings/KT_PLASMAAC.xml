<Defs>
	<ThingDef ParentName="KT_AutocannonTurret">
    <defName>KTPLASMAAC</defName>
    <label>KTPLASMAAC</label>
	<thingClass>SRA.Building_TurretGunHasSpeed</thingClass>
	<modExtensions>
	   <li Class="SRA.ModExt_HasSpeedTurret"><!-- SRA炮塔转速 -->
		 <speed>1.6</speed>
	   </li>
  	</modExtensions>
    <description>KTPLASMAAC</description>
	<uiOrder>1800</uiOrder> <!-- UI栏顺序 -->
    <uiIconPath>Things/Building/Security/KTPLASMAAC_Ico</uiIconPath>
	<graphicData>
		<texPath>Things/Building/Security/KT100MMCANNON_Base</texPath>
		<graphicClass>Graphic_Single</graphicClass>
		<drawSize>(6,6)</drawSize>
	</graphicData>
	<size>(3,3)</size>
    <statBases>
	  <MaxHitPoints>3000</MaxHitPoints>
	  <Flammability>0</Flammability>
      <ShootingAccuracyTurret>1</ShootingAccuracyTurret>
	  <WorkToBuild>1500</WorkToBuild>
    </statBases>
	<drawerType>MapMeshAndRealTime</drawerType>
	<tickerType>Normal</tickerType>
	<killedLeavings>
      <ChunkSlagSteel>3</ChunkSlagSteel>
    </killedLeavings>
    <costList>
      <Steel>1000</Steel>
	  <Plasteel>400</Plasteel>
      <ComponentIndustrial>15</ComponentIndustrial>
	  <ComponentSpacer>10</ComponentSpacer>
    </costList>
	
	<damageMultipliers>
	  <li>
        <damageDef>EMP</damageDef>
        <multiplier>0</multiplier>
      </li>
	  <li>
        <damageDef>Stun</damageDef>
        <multiplier>0</multiplier>
      </li>
    </damageMultipliers>
	
    <comps>
	  <li Class="SRA.CompProperties_ForceTargetable" /><!-- 善良手操 -->
      <li Class="CompProperties_Forbiddable"/>
      <li Class="CompProperties_Power">
        <compClass>CompPowerTrader</compClass>
        <basePowerConsumption>1800</basePowerConsumption>
      </li>
      <li Class="CompProperties_Flickable"/>
      <li Class="CompProperties_Breakdownable"/>
    </comps>

    <building>
      <turretGunDef>Gun_KTPLASMAAC</turretGunDef>
	  <ai_combatDangerous>true</ai_combatDangerous> <!-- AI认为它具有危险性 -->
	  <turretTopDrawSize>7.5</turretTopDrawSize>
	  <turretTopOffset>(0.05, 0)</turretTopOffset>
      <turretBurstCooldownTime>1.8</turretBurstCooldownTime>
    </building>
    <researchPrerequisites>
      <li>KT_Base_t2_energy_turret</li>
    </researchPrerequisites>
	<designationCategory>KT_designation_group</designationCategory> <!-- 指定分类：联合 -->

  </ThingDef>
  
  <ThingDef ParentName="BaseWeaponTurret">
    <defName>Gun_KTPLASMAAC</defName>
    <label>Gun_KTPLASMAAC</label>
    <description>Gun_KTPLASMAAC</description>
    <graphicData>
      <texPath>Things/Building/Security/KTPLASMAAC</texPath>
      <graphicClass>Graphic_Single</graphicClass>
      <drawSize>(3.8,3.8)</drawSize>
    </graphicData>
    <statBases>
      <AccuracyTouch>0.55</AccuracyTouch>
      <AccuracyShort>0.45</AccuracyShort>
      <AccuracyMedium>0.45</AccuracyMedium>
      <AccuracyLong>0.30</AccuracyLong>
      <RangedWeapon_Cooldown>1.8</RangedWeapon_Cooldown>
      <DeteriorationRate>0</DeteriorationRate>
      <Mass>50</Mass>
      <Flammability>0</Flammability>
    </statBases>
	<verbs>
      <li>
        <verbClass>SRA.Verb_ShootWithOffset</verbClass> <!-- 射击行为 -->
        <hasStandardCommand>true</hasStandardCommand> <!-- 标准命令 -->
        <defaultProjectile>Bullet_KTPLASMAAC</defaultProjectile> <!-- 默认子弹 -->
        <warmupTime>1</warmupTime> <!-- 预热时间 -->
		<requireLineOfSight>true</requireLineOfSight><!-- 只能直线射击 -->
		<minRange>10</minRange>
        <range>90</range> <!-- 射程 -->
        <burstShotCount>4</burstShotCount> <!-- 每次射击子弹数量 -->
        <soundCast>KTPLASMACANNONRound</soundCast> <!-- 射击音效 -->
        <soundCastTail>GunTail_Light</soundCastTail> <!-- 尾音效 -->
        <muzzleFlashScale>20</muzzleFlashScale> <!-- 火光规模 -->
        <consumeFuelPerShot>1</consumeFuelPerShot> <!-- 每发子弹消耗的燃料 -->
		<targetParams>
			<canTargetLocations>true</canTargetLocations>
		</targetParams>
      </li>
    </verbs>
	<weaponTags>
	  	<li>KT_weapon</li>
   	</weaponTags>
	<modExtensions>
      <li Class="MuzzleFlash.MuzzleFlashProps" MayRequire="IssacZhuang.MuzzleFlash">
         <def>MF_ChargedMuzzleFalsh</def>
         <drawSize>(3)</drawSize>
         <offsets>
           <li>(1,-0.1)</li>
		   <li>(1,0.1)</li>
         </offsets>
         <isAlternately>true</isAlternately>
     </li>
	 <li Class="SRA.ModExtension_ShootWithOffset">
         <offsets>
           <li>(0.1,-1.5)</li>
		   <li>(-0.1,-1.5)</li><!-- 第一个参数是东西（负数为东）。第二个参数为南北（负数为朝北） -->
         </offsets>
     </li>		 
   </modExtensions>
  </ThingDef>
  
  <ThingDef>
        <defName>Bullet_KTPLASMAAC</defName>
        <label>Bullet_KTPLASMAAC</label>
        <thingClass>SRA.Projectile_MultiExplosive</thingClass>
        <category>Projectile</category>
        <tickerType>Normal</tickerType>
        <altitudeLayer>Projectile</altitudeLayer>
        <graphicData>
            <texPath>Things/Projectile/Bullet_kt_plasma</texPath> <!-- 子弹贴图路径 -->
            <graphicClass>Graphic_Single</graphicClass> <!-- 使用单一图形 -->
			<shaderType>MoteGlow</shaderType>
      		<drawSize>(1.2)</drawSize>
        </graphicData>
        <projectile>
            <damageDef>KTBLUEBomb</damageDef>
            <explosionRadius>1</explosionRadius>
			<stoppingPower>1</stoppingPower>
            <speed>140</speed>
            <damageAmountBase>35</damageAmountBase>
            <arcHeightFactor>0</arcHeightFactor>
            <soundExplode>Explosion_Rocket</soundExplode>
			<flyOverhead>false</flyOverhead>
			<armorPenetrationBase>0.7</armorPenetrationBase>
        </projectile>
		
		<modExtensions>
		 <li Class="SRA.TailBulletDef">
       		   <tailFleckDef>KT_Fleck_blue_particle_Tail_II</tailFleckDef>
      	 	   <fleckMakeFleckTickMax>10</fleckMakeFleckTickMax><!-- 疑似无效 -->
			   <fleckDelayTicks>5</fleckDelayTicks><!-- 出膛后多久出现轨迹 -->
			   <fleckMakeFleckNum>1</fleckMakeFleckNum>
     	 </li>
         <li Class="SRA.MultiExplosiveExtension">
          <multiexplosions>
          <li>
            <radius>1</radius>
            <damageDef>KTBLUEBomb</damageDef>
            <damageAmount>35</damageAmount>
            <armorPenetration>0.7</armorPenetration>
            <explosionSound>Explosion_Rocket</explosionSound>
            <explosionDamageFalloff>true</explosionDamageFalloff><!-- 默认true -->
            <onlyAntiHostile>false</onlyAntiHostile> <!-- 智能弹药：这个爆炸只伤害敌对目标，默认false -->
            <!-- 现阶段就支持这么多参数 -->
          </li>
		  <li>
			<radius>1.5</radius>
			<damageDef>EMP</damageDef>
			<damageAmount>60</damageAmount>
			<armorPenetration>8</armorPenetration>
			<explosionSound>Explosion_EMP</explosionSound>
			<explosionDamageFalloff>true</explosionDamageFalloff>
			<onlyAntiHostile>true</onlyAntiHostile>
		  </li>
        </multiexplosions>
        <bulletLaunches>
          <li>
            <projectileDef>KT_Bullet_shield_overloader</projectileDef>
            <bulletCount>2</bulletCount>
            <angleRange>120</angleRange>
            <distanceRange>
              <min>1</min>
              <max>1</max>
            </distanceRange>
          </li>
        </bulletLaunches>
      </li>
    </modExtensions>
  </ThingDef>	

</Defs>