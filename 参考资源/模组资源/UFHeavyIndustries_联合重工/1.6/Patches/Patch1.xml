<?xml version="1.0" encoding="utf-8"?>
<Patch>
    <Operation Class="PatchOperationFindMod">
        <mods>
          <li>Kiiro Race</li>
        </mods>
		<match Class="PatchOperationSequence">
		  <success>Always</success>
		  <operations>
		  <li Class="PatchOperationAdd">
			<xpath>Defs/AlienRace.ThingDef_AlienRace[defName="Kiiro_Race"]/alienRace/raceRestriction/apparelList</xpath>
			<value>
			  <li>KT_Kiiro</li>
			</value>
		  </li>
		  <li Class="PatchOperationAdd">
			<xpath>Defs/AlienRace.ThingDef_AlienRace[defName="Kiiro_Race"]/alienRace/raceRestriction/whiteApparelList</xpath>
			<value>
			  <li>TurbojetBackpack</li>
			  <li>KT_Backpack</li>
			</value>
		  </li>
		  </operations>
		</match>
	</Operation>
	
