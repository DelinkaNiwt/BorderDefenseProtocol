<?xml version="1.0" encoding="utf-8"?>
<Defs>

  <!--
    战斗体专用伤口 HediffDef
    与原版完全对应，仅修改:
    - painPerSeverity=0 / averagePainPerSeverityPermanent=0 (无疼痛)
    - partIgnoreMissingHP=true (伤口不影响部位效率)
    - 移除 HediffCompProperties_Infecter (战斗体不感染)
    - 移除 HediffCompProperties_GetsPermanent (战斗伤口不永久化)

    由 Patch_HealthUtility_GetHediffDefFromDamage 在战斗体激活时自动替换
  -->

  <!-- 基类: 战斗体伤口 -->
  <HediffDef Name="BDP_InjuryBase" Abstract="True">
    <hediffClass>Hediff_Injury</hediffClass>
    <tendable>false</tendable>
    <displayWound>true</displayWound>
    <labelNounPretty>{1}的{0}</labelNounPretty>
    <isBad>true</isBad>
    <stages>
      <li>
        <partIgnoreMissingHP>true</partIgnoreMissingHP>
      </li>
    </stages>
  </HediffDef>

  <!-- 枪伤 (原版: Gunshot) -->
  <HediffDef ParentName="BDP_InjuryBase">
    <defName>BDP_Gunshot</defName>
    <label>枪伤</label>
    <labelNoun>枪伤</labelNoun>
    <description>枪伤。（战斗体）</description>
    <injuryProps>
      <painPerSeverity>0</painPerSeverity>
      <averagePainPerSeverityPermanent>0</averagePainPerSeverityPermanent>
      <bleedRate>0.06</bleedRate>
      <canMerge>false</canMerge>
      <destroyedLabel>被射断</destroyedLabel>
      <destroyedOutLabel>被射出</destroyedOutLabel>
    </injuryProps>
  </HediffDef>

