<?xml version="1.0" encoding="utf-8"?>
<Defs>

  <!-- ══════════════════════════════════════════════════════
       BDP_ChipBase — 芯片基础模板（抽象）
       所有芯片都应该继承这个基础模板
       ══════════════════════════════════════════════════════ -->
  <ThingDef Name="BDP_ChipBase" Abstract="True">
    <category>Item</category>
    <thingClass>ThingWithComps</thingClass>
    <selectable>true</selectable>
    <alwaysHaulable>true</alwaysHaulable>
    <altitudeLayer>Item</altitudeLayer>
    <drawGUIOverlay>true</drawGUIOverlay>
    <pathCost>14</pathCost>
    <rotatable>false</rotatable>
    <stackLimit>5</stackLimit>

    <graphicData>
      <graphicClass>Graphic_Single</graphicClass>
    </graphicData>

    <statBases>
      <Mass>0.1</Mass>
      <MaxHitPoints>70</MaxHitPoints>
      <Flammability>0.6</Flammability>
      <DeteriorationRate>2.0</DeteriorationRate>
      <Beauty>-2</Beauty>
    </statBases>

    <comps>
      <li Class="CompProperties_Forbiddable" />
    </comps>

    <thingCategories>
      <li>ItemsMisc</li>
    </thingCategories>

    <soundInteract>Metal_Drop</soundInteract>
    <soundDrop>Standard_Drop</soundDrop>
  </ThingDef>

  <!-- ══════════════════════════════════════════════════════
       #10 BDP_Chip_Grasshopper — 蚱蜢芯片
       约束：左右手槽位
       作用：Trion弹射跳板，高速弹向目标位置
       ══════════════════════════════════════════════════════ -->
  <ThingDef ParentName="BDP_ChipBase">
    <defName>BDP_Chip_Grasshopper</defName>
    <label>蚱蜢</label>
    <description>机动型芯片。在使用者脚下凝聚出Trion弹射跳板，以爆发性的速度将其弹向面对方向。这种爆炸性的推进力能够实现战场上的快速重新定位，但着陆时的急剧减速需要精确的控制。</description>

    <graphicData>
      <texPath>Things/Item/Chip/SonicDash</texPath>
    </graphicData>

    <statBases>
      <MarketValue>800</MarketValue>
    </statBases>

    <comps>
      <li Class="BDP.Trigger.CompProperties_TriggerChip">
        <modes>
          <li>
            <label>蚱蜢</label>
            <description>机动型芯片，提供爆发性弹射能力</description>
            <effectClasses>
              <li>BDP.Trigger.AbilityChipEffect</li>
            </effectClasses>
          </li>
        </modes>
        <primaryCategory>Ability</primaryCategory> <!-- 主类别：能力类 -->
        <activationCost>0</activationCost> <!-- 无激活成本 -->
        <allocationCost>15</allocationCost> <!-- 占用15 Trion -->
        <usageCost>20</usageCost> <!-- 每次使用消耗20 Trion -->
        <drainPerDay>0</drainPerDay> <!-- 无持续消耗 -->
        <activationWarmup>0</activationWarmup> <!-- 无预热 -->
        <slotRestriction>HandsOnly</slotRestriction> <!-- 只能插左右手槽位 -->
        <categories>
          <li>Mobility</li>
          <li>Utility</li>
        </categories>
      </li>
    </comps>

    <modExtensions>
      <li Class="BDP.Trigger.AbilityChipConfig">
        <abilityDef>BDP_Ability_Grasshopper</abilityDef>
      </li>
    </modExtensions>
  </ThingDef>

  <!-- ══════════════════════════════════════════════════════
       #9 BDP_Chip_EmergencyEscape — 紧急脱离芯片（特殊槽位）
       约束：只能插特殊槽位
       作用：战斗体被动破裂时触发传送
       ══════════════════════════════════════════════════════ -->
  <ThingDef ParentName="BDP_ChipBase">
    <defName>BDP_Chip_EmergencyEscape</defName>
    <label>紧急脱离</label>
    <description>特殊系统芯片。装载后，战斗体被动破裂时自动传送到紧急脱离信标位置。只能插入特殊槽位。</description>
    <graphicData>
      <texPath>Things/Trigger/BDP_Chip_Test</texPath>
    </graphicData>
    <statBases>
      <MarketValue>300</MarketValue>
    </statBases>
    <comps>
      <li Class="BDP.Trigger.CompProperties_TriggerChip">
        <modes>
          <li>
            <label>紧急脱离</label>
            <description>战斗体破裂时自动传送</description>
            <effectClasses>
              <li>BDP.Trigger.PassiveChipEffect</li>
            </effectClasses>
          </li>
        </modes>
        <primaryCategory>Passive</primaryCategory> <!-- 主类别：被动类 -->
        <slotRestriction>SpecialOnly</slotRestriction>
        <activationCost>0</activationCost>
        <allocationCost>200</allocationCost>
        <activationWarmup>0</activationWarmup>
        <deactivationDelay>0</deactivationDelay>
        <categories>
          <li>System</li>
          <li>Passive</li>
          <li>Utility</li>
          <li>HighCost</li>
        </categories>
      </li>
    </comps>
  </ThingDef>

  <!-- ══════════════════════════════════════════════════════
       BDP_Chip_Asteroid — 小行星芯片（远程武器，齐射攻击）
       模块：拖尾（BeamTrailConfig）
       类别：Cube（方块类）
       攻击模式：齐射（Volley）
       ══════════════════════════════════════════════════════ -->
  <ThingDef ParentName="BDP_ChipBase">
    <defName>BDP_Chip_Asteroid</defName>
    <label>小行星</label>
    <description>发射普通弹进行齐射攻击的远程芯片。5发连射，中等射程，具有一定护甲穿透能力。适合对抗中装甲目标。</description>
    <graphicData>
      <texPath>Things/Trigger/Cube/cube</texPath>
    </graphicData>
    <statBases>
      <MarketValue>1000</MarketValue>
    </statBases>
    <comps>
      <li Class="BDP.Trigger.CompProperties_TriggerChip">
        <modes>
          <li>
            <label>小行星</label>
            <description>5发齐射，中等射程</description>
            <effectClasses>
              <li>BDP.Trigger.VerbChipEffect</li>
            </effectClasses>
          </li>
        </modes>
        <primaryCategory>RangedWeapon</primaryCategory> <!-- 主类别：远程武器类 -->
        <slotRestriction>HandsOnly</slotRestriction>
        <activationCost>12</activationCost>
        <allocationCost>38</allocationCost>
        <usageCost>2</usageCost> <!-- 每次射击消耗2 Trion -->
        <drainPerDay>0</drainPerDay>
        <minOutputPower>6</minOutputPower>
        <activationWarmup>30</activationWarmup>
        <deactivationDelay>15</deactivationDelay>
        <categories>
          <li>Weapon</li>
          <li>Ranged</li>
          <li>Medium</li>
          <li>Physical</li>
          <li>Rifle</li>
          <li>Burst</li>
          <li>Cube</li>
        </categories>
      </li>
      <li Class="BDP.FireMode.CompProperties_FireMode"/>
    </comps>
    <modExtensions>
      <li Class="BDP.Trigger.VerbChipConfig">
        <primaryVerbProps>
          <verbClass>BDP.Trigger.Verb_BDPSingle</verbClass>
          <hasStandardCommand>true</hasStandardCommand>
          <defaultProjectile>BDP_Bullet_Normal</defaultProjectile>
          <warmupTime>1.0</warmupTime>
          <range>40</range>
          <burstShotCount>5</burstShotCount>
          <ticksBetweenBurstShots>12</ticksBetweenBurstShots>
          <soundCast>BDP_Shot_Asteroid</soundCast>
          <soundCastTail>GunTail_Medium</soundCastTail>
          <muzzleFlashScale>9</muzzleFlashScale>
          <defaultCooldownTime>2.0</defaultCooldownTime>
          <accuracyTouch>0.55</accuracyTouch>
          <accuracyShort>0.64</accuracyShort>
          <accuracyMedium>0.55</accuracyMedium>
          <accuracyLong>0.45</accuracyLong>
        </primaryVerbProps>
        <primaryFiringPattern>Simultaneous</primaryFiringPattern>
        <ranged>
          <!-- 散布半径 = drawSize / 2 = 0.55 / 2，子弹起点不超出方块边界 -->
          <volleySpreadRadius>0.275</volleySpreadRadius>
        </ranged>
      </li>

      <!-- 武器绘制配置 -->
      <li Class="BDP.Trigger.WeaponDraw.WeaponDrawChipConfig">
        <!-- 枪口发射配置：子弹从方块贴图中心射出 -->
        <isRangedWeapon>true</isRangedWeapon>
        <muzzleOffset>(0, 0, 0)</muzzleOffset>

        <!-- 武器贴图 -->
        <graphicData>
          <texPath>Things/Trigger/Cube/cube</texPath>
          <graphicClass>Graphic_Single</graphicClass>
          <shaderType>Cutout</shaderType>
          <drawSize>0.55</drawSize>
        </graphicData>

        <!-- 发光层贴图 -->
        <glowGraphicData>
          <texPath>Things/Trigger/Cube/cube_glow</texPath>
          <graphicClass>Graphic_Single</graphicClass>
          <shaderType>MoteGlow</shaderType>
          <color>(0.8, 0.85, 0.85)</color>  <!-- 接近白色的浅青色发光，85%强度 -->
          <drawSize>0.55</drawSize>
        </glowGraphicData>

        <!-- South/North参数 -->
        <defaultOffset>(-0.35, 0, 0.08)</defaultOffset>
        <defaultAngle>105</defaultAngle>
        <defaultAltitudeOffset>0.05</defaultAltitudeOffset>
        <southZAdjust>-0.03</southZAdjust>
        <northZAdjust>0.03</northZAdjust>

        <!-- East/West参数 -->
        <sideBaseX>0.10</sideBaseX>
        <sideDeltaX>0.04</sideDeltaX>
        <leftHandAngleOffset>0</leftHandAngleOffset>
      </li>

    </modExtensions>
  </ThingDef>

  <!-- ══════════════════════════════════════════════════════
       BDP_Chip_Viper — 毒蛇芯片（远程武器，引导齐射攻击）
       模块：拖尾（BeamTrailConfig）+ 引导（BDPGuidedConfig）
       类别：Cube（方块类）
       攻击模式：引导齐射（Guided Volley）
       ══════════════════════════════════════════════════════ -->
  <ThingDef ParentName="BDP_ChipBase">
    <defName>BDP_Chip_Viper</defName>
    <label>毒蛇</label>
    <description>发射引导弹进行齐射攻击的远程芯片。支持路径引导瞄准，5发连射，中等射程。引导弹伤害较低但能精确命中目标，适合对抗轻装甲目标。每发消耗5 Trion。</description>
    <graphicData>
      <texPath>Things/Trigger/Cube/cube</texPath>
    </graphicData>
    <statBases>
      <MarketValue>1000</MarketValue>
    </statBases>
    <comps>
      <li Class="BDP.Trigger.CompProperties_TriggerChip">
        <modes>
          <li>
            <label>毒蛇</label>
            <description>5发引导齐射，精确命中</description>
            <effectClasses>
              <li>BDP.Trigger.VerbChipEffect</li>
            </effectClasses>
          </li>
        </modes>
        <primaryCategory>RangedWeapon</primaryCategory> <!-- 主类别：远程武器类 -->
        <slotRestriction>HandsOnly</slotRestriction>
        <activationCost>12</activationCost>
        <allocationCost>38</allocationCost>
        <usageCost>5</usageCost> <!-- 每次射击消耗5 Trion -->
        <drainPerDay>0</drainPerDay>
        <minOutputPower>6</minOutputPower>
        <activationWarmup>30</activationWarmup>
        <deactivationDelay>15</deactivationDelay>
        <categories>
          <li>Weapon</li>
          <li>Ranged</li>
          <li>Medium</li>
          <li>Physical</li>
          <li>Rifle</li>
          <li>Burst</li>
          <li>Cube</li>
        </categories>
      </li>
      <li Class="BDP.FireMode.CompProperties_FireMode"/>
    </comps>
    <modExtensions>
      <li Class="BDP.Trigger.VerbChipConfig">
        <primaryVerbProps>
          <verbClass>BDP.Trigger.Verb_BDPSingle</verbClass>
          <hasStandardCommand>true</hasStandardCommand>
          <defaultProjectile>BDP_Bullet_Guided</defaultProjectile>
          <warmupTime>1.0</warmupTime>
          <range>40</range>
          <burstShotCount>5</burstShotCount>
          <ticksBetweenBurstShots>12</ticksBetweenBurstShots>
          <soundCast>Shot_AssaultRifle</soundCast>
          <soundCastTail>GunTail_Medium</soundCastTail>
          <muzzleFlashScale>9</muzzleFlashScale>
          <defaultCooldownTime>2.0</defaultCooldownTime>
        </primaryVerbProps>
        <primaryFiringPattern>Simultaneous</primaryFiringPattern>
        <ranged>
          <volleySpreadRadius>0.3</volleySpreadRadius>
          <guided>
            <maxAnchors>5</maxAnchors>
            <anchorSpread>0.3</anchorSpread>
          </guided>
        </ranged>
      </li>

      <!-- 武器绘制配置 -->
      <li Class="BDP.Trigger.WeaponDraw.WeaponDrawChipConfig">
        <!-- 武器贴图 -->
        <graphicData>
          <texPath>Things/Trigger/Cube/cube</texPath>
          <graphicClass>Graphic_Single</graphicClass>
          <shaderType>Cutout</shaderType>
          <drawSize>0.55</drawSize>
        </graphicData>

        <!-- 发光层贴图 -->
        <glowGraphicData>
          <texPath>Things/Trigger/Cube/cube_glow</texPath>
          <graphicClass>Graphic_Single</graphicClass>
          <shaderType>MoteGlow</shaderType>
          <color>(0.8, 0.85, 0.85)</color>  <!-- 接近白色的浅青色发光，85%强度 -->
          <drawSize>0.55</drawSize>
        </glowGraphicData>

        <!-- South/North参数 -->
        <defaultOffset>(-0.35, 0, 0.08)</defaultOffset>
        <defaultAngle>105</defaultAngle>
        <defaultAltitudeOffset>0.05</defaultAltitudeOffset>
        <southZAdjust>-0.03</southZAdjust>
        <northZAdjust>0.03</northZAdjust>

        <!-- East/West参数 -->
        <sideBaseX>0.10</sideBaseX>
        <sideDeltaX>0.04</sideDeltaX>
        <leftHandAngleOffset>0</leftHandAngleOffset>
      </li>

    </modExtensions>
  </ThingDef>

  <!-- ══════════════════════════════════════════════════════
       BDP_Chip_Shield — 能量盾芯片
       约束：特殊槽位
       作用：激活时添加正面180°护盾，抵挡前方攻击（70%成功率）
       Severity机制：两个芯片同时激活时，防护范围扩展为360°，成功率提升至95%
       ══════════════════════════════════════════════════════ -->
  <ThingDef ParentName="BDP_ChipBase">
    <defName>BDP_Chip_Shield</defName>
    <label>能量盾</label>
    <description>防御型芯片。激活后在使用者周围生成正面180度能量护盾，可以抵挡来自前方的远程攻击（70%成功率）。每次抵挡会消耗Trion能量，当Trion不足时护盾失效。只能插入特殊槽位。

【组合效果】同时激活两个能量盾芯片时，防护范围扩展为360°全方位，成功率提升至95%。</description>

    <graphicData>
      <texPath>Things/Trigger/BDP_Chip_Test</texPath>
    </graphicData>

    <statBases>
      <MarketValue>1200</MarketValue>
    </statBases>

    <comps>
      <li Class="BDP.Trigger.CompProperties_TriggerChip">
        <modes>
          <li>
            <label>护盾</label>
            <description>正面180°护盾，70%成功率</description>
            <effectClasses>
              <li>BDP.Trigger.StackableHediffChipEffect</li>
            </effectClasses>
          </li>
        </modes>
        <primaryCategory>Defense</primaryCategory> <!-- 主类别：防御类 -->

        <!-- Trion成本配置 -->
        <activationCost>20</activationCost>      <!-- 激活消耗20 Trion -->
        <allocationCost>50</allocationCost>      <!-- 占用50 Trion -->
        <drainPerDay>0</drainPerDay>             <!-- 无持续消耗（护盾抵挡时才消耗） -->

        <!-- 时间配置 -->
        <activationWarmup>60</activationWarmup>  <!-- 1秒预热 -->
        <deactivationDelay>30</deactivationDelay> <!-- 0.5秒关闭延迟 -->

        <!-- 槽位限制：只能插特殊槽位 -->
        <slotRestriction>SpecialOnly</slotRestriction>

        <!-- 芯片类别 -->
        <categories>
          <li>Defense</li>
          <li>Shield</li>
          <li>HighCost</li>
        </categories>
      </li>
    </comps>

    <!-- Hediff配置：指定要添加的护盾hediff -->
    <modExtensions>
      <li Class="BDP.Trigger.HediffChipConfig">
        <hediffDef>BDP_Shield</hediffDef>
      </li>
    </modExtensions>
  </ThingDef>

  <!-- ══════════════════════════════════════════════════════
       BDP_Chip_ShieldFront — 前方护盾芯片
       约束：特殊槽位
       作用：激活时添加前方120°护盾，抵挡前方攻击（100%成功率）
       ══════════════════════════════════════════════════════ -->
  <ThingDef ParentName="BDP_ChipBase">
    <defName>BDP_Chip_ShieldFront</defName>
    <label>前方护盾</label>
    <description>防御型芯片。激活后在使用者前方生成定向能量护盾，可以抵挡来自前方120度（左60°右60°）的远程攻击（100%成功率）。防护范围有限但抵挡可靠。每次抵挡会消耗Trion能量，当Trion不足时护盾失效。只能插入特殊槽位。</description>

    <graphicData>
      <texPath>Things/Trigger/BDP_Chip_Test</texPath>
    </graphicData>

    <statBases>
      <MarketValue>1000</MarketValue>
    </statBases>

    <comps>
      <li Class="BDP.Trigger.CompProperties_TriggerChip">
        <modes>
          <li>
            <label>前方护盾</label>
            <description>前方120°护盾，100%成功率</description>
            <effectClasses>
              <li>BDP.Trigger.StackableHediffChipEffect</li>
            </effectClasses>
          </li>
        </modes>
        <primaryCategory>Defense</primaryCategory> <!-- 主类别：防御类 -->

        <!-- Trion成本配置 -->
        <activationCost>15</activationCost>      <!-- 激活消耗15 Trion -->
        <allocationCost>40</allocationCost>      <!-- 占用40 Trion -->
        <drainPerDay>0</drainPerDay>             <!-- 无持续消耗（护盾抵挡时才消耗） -->

        <!-- 时间配置 -->
        <activationWarmup>60</activationWarmup>  <!-- 1秒预热 -->
        <deactivationDelay>30</deactivationDelay> <!-- 0.5秒关闭延迟 -->

        <!-- 槽位限制：只能插特殊槽位 -->
        <slotRestriction>SpecialOnly</slotRestriction>

        <!-- 芯片类别 -->
        <categories>
          <li>Defense</li>
          <li>Shield</li>
          <li>Medium</li>
        </categories>
      </li>
    </comps>

    <!-- Hediff配置：指定要添加的护盾hediff -->
    <modExtensions>
      <li Class="BDP.Trigger.HediffChipConfig">
        <hediffDef>BDP_Shield</hediffDef>
      </li>
    </modExtensions>
  </ThingDef>

  <!-- ══════════════════════════════════════════════════════
       BDP_Chip_Meteora — 流星芯片（远程武器，齐射攻击）
       模块：拖尾（BeamTrailConfig）+ 爆炸（BDPExplosionConfig）
       类别：Cube（方块类）+ Explosive（爆炸类）
       攻击模式：齐射（Simultaneous）
       子弹：炸裂弹（BDP_Bullet_Explosive）
       ══════════════════════════════════════════════════════ -->
  <ThingDef ParentName="BDP_ChipBase">
    <defName>BDP_Chip_Meteora</defName>
    <label>流星</label>
    <description>发射炸裂弹进行齐射攻击的远程芯片。3发连射，中等射程，子弹命中后产生范围爆炸（半径3格）。适合对抗密集目标和轻装甲单位。</description>
    <graphicData>
      <texPath>Things/Trigger/Cube/cube</texPath>
    </graphicData>
    <statBases>
      <MarketValue>1000</MarketValue>
    </statBases>
    <comps>
      <li Class="BDP.Trigger.CompProperties_TriggerChip">
        <modes>
          <li>
            <label>流星</label>
            <description>3发炸裂弹齐射，范围爆炸</description>
            <effectClasses>
              <li>BDP.Trigger.VerbChipEffect</li>
            </effectClasses>
          </li>
        </modes>
        <primaryCategory>RangedWeapon</primaryCategory>
        <slotRestriction>HandsOnly</slotRestriction>
        <activationCost>12</activationCost>
        <allocationCost>38</allocationCost>
        <usageCost>2</usageCost>
        <drainPerDay>0</drainPerDay>
        <minOutputPower>6</minOutputPower>
        <activationWarmup>30</activationWarmup>
        <deactivationDelay>15</deactivationDelay>
        <categories>
          <li>Weapon</li>
          <li>Ranged</li>
          <li>Medium</li>
          <li>Physical</li>
          <li>Rifle</li>
          <li>Burst</li>
          <li>Cube</li>
          <li>Explosive</li>
        </categories>
      </li>
      <li Class="BDP.FireMode.CompProperties_FireMode"/>
    </comps>
    <modExtensions>
      <li Class="BDP.Trigger.VerbChipConfig">
        <primaryVerbProps>
          <verbClass>BDP.Trigger.Verb_BDPSingle</verbClass>
          <hasStandardCommand>true</hasStandardCommand>
          <defaultProjectile>BDP_Bullet_Explosive</defaultProjectile>
          <warmupTime>1.0</warmupTime>
          <range>40</range>
          <burstShotCount>3</burstShotCount>
          <ticksBetweenBurstShots>12</ticksBetweenBurstShots>
          <soundCast>Shot_AssaultRifle</soundCast>
          <soundCastTail>GunTail_Medium</soundCastTail>
          <muzzleFlashScale>9</muzzleFlashScale>
          <defaultCooldownTime>2.0</defaultCooldownTime>
          <accuracyTouch>0.55</accuracyTouch>
          <accuracyShort>0.64</accuracyShort>
          <accuracyMedium>0.55</accuracyMedium>
          <accuracyLong>0.45</accuracyLong>
        </primaryVerbProps>
        <primaryFiringPattern>Simultaneous</primaryFiringPattern>
        <ranged>
          <volleySpreadRadius>0.3</volleySpreadRadius>
        </ranged>
      </li>

      <!-- 武器绘制配置 -->
      <li Class="BDP.Trigger.WeaponDraw.WeaponDrawChipConfig">
        <!-- 武器贴图 -->
        <graphicData>
          <texPath>Things/Trigger/Cube/cube</texPath>
          <graphicClass>Graphic_Single</graphicClass>
          <shaderType>Cutout</shaderType>
          <drawSize>0.55</drawSize>
        </graphicData>

        <!-- 发光层贴图 -->
        <glowGraphicData>
          <texPath>Things/Trigger/Cube/cube_glow</texPath>
          <graphicClass>Graphic_Single</graphicClass>
          <shaderType>MoteGlow</shaderType>
          <color>(0.8, 0.85, 0.85)</color>  <!-- 接近白色的浅青色发光，85%强度 -->
          <drawSize>0.55</drawSize>
        </glowGraphicData>

        <!-- South/North参数 -->
        <defaultOffset>(-0.35, 0, 0.08)</defaultOffset>
        <defaultAngle>105</defaultAngle>
        <defaultAltitudeOffset>0.05</defaultAltitudeOffset>
        <southZAdjust>-0.03</southZAdjust>
        <northZAdjust>0.03</northZAdjust>

        <!-- East/West参数 -->
        <sideBaseX>0.10</sideBaseX>
        <sideDeltaX>0.04</sideDeltaX>
        <leftHandAngleOffset>0</leftHandAngleOffset>
      </li>

    </modExtensions>
  </ThingDef>

  <!-- ══════════════════════════════════════════════════════
       BDP_Chip_Raygust — 光魂芯片
       约束：左右手槽位
       形态1（默认）：巨盾模式 - 前方大盾 + 推进器能力
       形态2：重刃模式 - 钝击近战武器 + 推进器能力
       激活期间：移速 -25%
       ══════════════════════════════════════════════════════ -->
  <ThingDef ParentName="BDP_ChipBase">
    <defName>BDP_Chip_Raygust</defName>
    <label>光魂</label>
    <description>重型多形态芯片。默认展开前方大盾（巨盾模式），可切换为重型近战武器（重刃模式）。两种形态均内置推进器，可进行爆发性位移。激活期间移动速度降低25%。</description>

    <graphicData>
      <texPath>Things/Trigger/BDP_Chip_Test</texPath>
    </graphicData>

    <statBases>
      <MarketValue>1500</MarketValue>
    </statBases>

    <comps>
      <li Class="BDP.Trigger.CompProperties_TriggerChip">
        <modes>
          <!-- 形态0：巨盾模式（默认） -->
          <li>
            <label>巨盾模式</label>
            <description>展开前方大盾，抵挡来袭攻击</description>
            <effectClasses>
              <li>BDP.Trigger.ModeBasedHediffChipEffect</li>
              <li>BDP.Trigger.AbilityChipEffect</li>
            </effectClasses>
          </li>
          <!-- 形态1：重刃模式 -->
          <li>
            <label>重刃模式</label>
            <description>收起护盾，切换为重型近战武器</description>
            <effectClasses>
              <li>BDP.Trigger.ModeBasedHediffChipEffect</li>
              <li>BDP.Trigger.VerbChipEffect</li>
              <li>BDP.Trigger.AbilityChipEffect</li>
            </effectClasses>
            <switchCost>15</switchCost>
          </li>
        </modes>

        <primaryCategory>Defense</primaryCategory>
        <slotRestriction>HandsOnly</slotRestriction>

        <activationCost>25</activationCost>
        <allocationCost>65</allocationCost>
        <drainPerDay>0</drainPerDay>
        <activationWarmup>60</activationWarmup>   <!-- 1秒预热 -->
        <deactivationDelay>30</deactivationDelay> <!-- 0.5秒关闭延迟 -->

        <categories>
          <li>Defense</li>
          <li>Shield</li>
          <li>Melee</li>
          <li>Heavy</li>
        </categories>
      </li>
    </comps>

    <modExtensions>
      <!-- 巨盾模式：护盾Hediff（Severity=1） -->
      <li Class="BDP.Trigger.HediffChipConfig">
        <hediffDef>BDP_Chip_Raygust_Hediff</hediffDef>
      </li>

      <!-- 两种形态共用：推进器能力 -->
      <li Class="BDP.Trigger.AbilityChipConfig">
        <abilityDef>BDP_Ability_Raygust_Thruster</abilityDef>
      </li>

      <!-- 重刃模式：钝击近战武器 -->
      <li Class="BDP.Trigger.VerbChipConfig">
        <primaryVerbProps>
          <verbClass>BDP.Trigger.Verb_BDPMelee</verbClass>
          <hasStandardCommand>true</hasStandardCommand>
          <meleeDamageBaseAmount>20</meleeDamageBaseAmount>
          <meleeDamageDef>Blunt</meleeDamageDef>
          <range>1.5</range>
          <burstShotCount>2</burstShotCount>
        </primaryVerbProps>
        <melee>
          <tools>
            <li>
              <label>重刃</label>
              <capacities>
                <li>Blunt</li>
              </capacities>
              <power>20</power>
              <cooldownTime>2.5</cooldownTime>
              <armorPenetration>0.1</armorPenetration>
            </li>
          </tools>
        </melee>
      </li>
    </modExtensions>
  </ThingDef>

  <!-- ══════════════════════════════════════════════════════
       BDP_Chip_Kogetsu — 弧月芯片（近战武器，利器）
       约束：左右手槽位
       作用：展开弧形能量刃，单次斩击，伤害20
       ══════════════════════════════════════════════════════ -->
  <ThingDef ParentName="BDP_ChipBase">
    <defName>BDP_Chip_Kogetsu</defName>
    <label>弧月</label>
    <description>近战型芯片。激活后从手柄中展开弧形能量刃（Kogetsu），以锋利的斩击攻击目标。刀刃由Trion能量凝聚而成，能够切割大多数材质。</description>

    <graphicData>
      <texPath>Things/Trigger/Chip/kogetsu_handle</texPath>
      <graphicClass>Graphic_Single</graphicClass>
      <drawSize>0.85</drawSize>
    </graphicData>

    <statBases>
      <MarketValue>1200</MarketValue>
    </statBases>

    <comps>
      <li Class="BDP.Trigger.CompProperties_TriggerChip">
        <modes>
          <li>
            <label>弧月</label>
            <description>展开能量刃，单次斩击</description>
            <effectClasses>
              <li>BDP.Trigger.VerbChipEffect</li>
            </effectClasses>
          </li>
        </modes>
        <primaryCategory>MeleeWeapon</primaryCategory> <!-- 主类别：近战武器类 -->
        <slotRestriction>HandsOnly</slotRestriction>    <!-- 只能插左右手槽位 -->
        <activationCost>10</activationCost>             <!-- 激活消耗10 Trion -->
        <allocationCost>30</allocationCost>             <!-- 占用30 Trion -->
        <usageCost>5</usageCost>                        <!-- 每次攻击消耗5 Trion -->
        <drainPerDay>0</drainPerDay>
        <activationWarmup>30</activationWarmup>         <!-- 0.5秒预热（展开刀刃） -->
        <deactivationDelay>15</deactivationDelay>
        <categories>
          <li>Weapon</li>
          <li>Melee</li>
          <li>Sharp</li>
          <li>Medium</li>
        </categories>
      </li>
    </comps>

    <modExtensions>
      <li Class="BDP.Trigger.VerbChipConfig">
        <primaryVerbProps>
          <verbClass>BDP.Trigger.Verb_BDPMelee</verbClass>
          <hasStandardCommand>true</hasStandardCommand>
          <meleeDamageBaseAmount>20</meleeDamageBaseAmount>
          <meleeDamageDef>Cut</meleeDamageDef>  <!-- 利器：切割伤害 -->
          <range>1.5</range>
          <burstShotCount>1</burstShotCount>    <!-- 单次斩击 -->
        </primaryVerbProps>
        <melee>
          <tools>
            <li>
              <label>弧月刃</label>
              <capacities>
                <li>Cut</li>
              </capacities>
              <power>20</power>
              <cooldownTime>2.0</cooldownTime>
              <armorPenetration>0.15</armorPenetration>
            </li>
          </tools>
        </melee>
      </li>

      <!-- 激活时在小人身上绘制弧月武器贴图 + 发光层 -->
      <li Class="BDP.Trigger.WeaponDraw.WeaponDrawChipConfig">
        <graphicData>
          <texPath>Things/Trigger/Chip/kogetsu_handle</texPath>
          <graphicClass>Graphic_Single</graphicClass>
          <shaderType>Cutout</shaderType>
          <drawSize>1.2</drawSize>
        </graphicData>
        <glowGraphicData>
          <texPath>Things/Trigger/Chip/kogetsu_blade</texPath>
          <graphicClass>Graphic_Single</graphicClass>
          <shaderType>MoteGlow</shaderType>
          <color>(1.0, 1.0, 0.95)</color>  <!-- 接近纯白的黄白色发光 -->
          <drawSize>1.2</drawSize>
        </glowGraphicData>

        <!-- South/North 参数：右手South为基准 -->
        <!-- X=-0.25：右手在屏幕左侧，左手自动镜像到右侧 -->
        <!-- Z=0.1：武器略靠后（北侧） -->
        <defaultOffset>(-0.20, 0, 0.1)</defaultOffset>
        <defaultAngle>-50</defaultAngle>  <!-- 补偿贴图本身的45°斜角；右手额外偏5°（远离方向） -->
        <!-- AltInc=0.0366，需大于此值才能改变渲染层级；0.05 ≈ 1.4×AltInc -->
        <defaultAltitudeOffset>0.05</defaultAltitudeOffset>
        <!-- South略往下，North略往上，体现视角透视感 -->
        <southZAdjust>-0.05</southZAdjust>
        <northZAdjust>0.05</northZAdjust>

        <!-- East/West 参数：侧身时两手靠拢，靠前景/背景区分 -->
        <sideBaseX>0.08</sideBaseX>   <!-- 两手共同X基准（朝东时偏右） -->
        <sideDeltaX>0.03</sideDeltaX> <!-- 前后手X微分 -->
        <leftHandAngleOffset>15</leftHandAngleOffset> <!-- 左手相对右手的额外偏转（度） -->
      </li>
    </modExtensions>
  </ThingDef>

  <!-- ══════════════════════════════════════════════════════
       BDP_Chip_RifleAsteroid — 步枪:小行星（远程武器，逐发射击）
       类别：Rifle（步枪类）
       攻击模式：逐发连射（Sequential Burst）
       散布：0（精准射击）
       子弹：普通弹（BDP_Bullet_Normal）
       ══════════════════════════════════════════════════════ -->
  <ThingDef ParentName="BDP_ChipBase">
    <defName>BDP_Chip_RifleAsteroid</defName>
    <label>步枪:小行星</label>
    <description>步枪型远程芯片。以突击步枪形态展开，逐发精准射击，6发连射，无散布。使用普通弹，适合中远距离精确打击。</description>
    <graphicData>
      <texPath>Things/Item/Equipment/WeaponRanged/AssaultRifle</texPath>
    </graphicData>
    <statBases>
      <MarketValue>1000</MarketValue>
    </statBases>
    <comps>
      <li Class="BDP.Trigger.CompProperties_TriggerChip">
        <modes>
          <li>
            <label>步枪:小行星</label>
            <description>6发逐发连射，精准射击</description>
            <effectClasses>
              <li>BDP.Trigger.VerbChipEffect</li>
            </effectClasses>
          </li>
        </modes>
        <primaryCategory>RangedWeapon</primaryCategory>
        <slotRestriction>HandsOnly</slotRestriction>
        <activationCost>12</activationCost>
        <allocationCost>38</allocationCost>
        <usageCost>2</usageCost>
        <drainPerDay>0</drainPerDay>
        <minOutputPower>6</minOutputPower>
        <activationWarmup>30</activationWarmup>
        <deactivationDelay>15</deactivationDelay>
        <categories>
          <li>Weapon</li>
          <li>Ranged</li>
          <li>Medium</li>
          <li>Physical</li>
          <li>Rifle</li>
          <li>Burst</li>
        </categories>
      </li>
      <li Class="BDP.FireMode.CompProperties_FireMode"/>
    </comps>
    <modExtensions>
      <li Class="BDP.Trigger.VerbChipConfig">
        <primaryVerbProps>
          <verbClass>BDP.Trigger.Verb_BDPSingle</verbClass>
          <hasStandardCommand>true</hasStandardCommand>
          <defaultProjectile>BDP_Bullet_Normal</defaultProjectile>
          <warmupTime>1.0</warmupTime>
          <range>40</range>
          <burstShotCount>6</burstShotCount>
          <ticksBetweenBurstShots>10</ticksBetweenBurstShots>
          <soundCast>Shot_AssaultRifle</soundCast>
          <soundCastTail>GunTail_Medium</soundCastTail>
          <muzzleFlashScale>9</muzzleFlashScale>
          <defaultCooldownTime>2.5</defaultCooldownTime>
          <accuracyTouch>0.50</accuracyTouch>
          <accuracyShort>0.65</accuracyShort>
          <accuracyMedium>0.60</accuracyMedium>
          <accuracyLong>0.50</accuracyLong>
        </primaryVerbProps>
        <!-- 逐发射击：不设 primaryFiringPattern，默认顺序连射 -->
        <!-- 散布0：不设 ranged/volleySpreadRadius -->
      </li>

      <!-- 武器绘制配置：突击步枪贴图 + 双武器绘制 + 枪口位置 -->
      <li Class="BDP.Trigger.WeaponDraw.WeaponDrawChipConfig">
        <!-- 枪口发射配置 -->
        <isRangedWeapon>true</isRangedWeapon>
        <muzzleOffset>(0, 0, 0.35)</muzzleOffset>

        <!-- 武器贴图 -->
        <graphicData>
          <texPath>Things/Item/Equipment/WeaponRanged/AssaultRifle</texPath>
          <graphicClass>Graphic_Single</graphicClass>
          <shaderType>Cutout</shaderType>
          <drawSize>1.0</drawSize>
        </graphicData>

        <!-- South/North参数 -->
        <defaultOffset>(-0.20, 0, 0.1)</defaultOffset>
        <defaultAngle>0</defaultAngle>
        <defaultAltitudeOffset>0.05</defaultAltitudeOffset>
        <southZAdjust>-0.03</southZAdjust>
        <northZAdjust>0.03</northZAdjust>

        <!-- East/West参数 -->
        <sideBaseX>0.15</sideBaseX>
        <sideDeltaX>0.05</sideDeltaX>
        <leftHandAngleOffset>0</leftHandAngleOffset>
      </li>

    </modExtensions>
  </ThingDef>

</Defs>
