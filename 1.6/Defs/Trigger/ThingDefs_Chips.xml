<?xml version="1.0" encoding="utf-8"?>
<Defs>

  <!-- ══════════════════════════════════════════════════════
       BDP_ChipBase — 芯片基础模板（抽象）
       所有芯片都应该继承这个基础模板
       ══════════════════════════════════════════════════════ -->
  <ThingDef Name="BDP_ChipBase" Abstract="True">
    <category>Item</category>
    <thingClass>ThingWithComps</thingClass>
    <selectable>true</selectable>
    <alwaysHaulable>true</alwaysHaulable>
    <altitudeLayer>Item</altitudeLayer>
    <drawGUIOverlay>true</drawGUIOverlay>
    <pathCost>14</pathCost>
    <rotatable>false</rotatable>
    <stackLimit>5</stackLimit>

    <graphicData>
      <graphicClass>Graphic_Single</graphicClass>
    </graphicData>

    <statBases>
      <Mass>0.1</Mass>
      <MaxHitPoints>70</MaxHitPoints>
      <Flammability>0.6</Flammability>
      <DeteriorationRate>2.0</DeteriorationRate>
      <Beauty>-2</Beauty>
    </statBases>

    <comps>
      <li Class="CompProperties_Forbiddable" />
    </comps>

    <thingCategories>
      <li>ItemsMisc</li>
    </thingCategories>

    <soundInteract>Metal_Drop</soundInteract>
    <soundDrop>Standard_Drop</soundDrop>
  </ThingDef>

  <!-- ══════════════════════════════════════════════════════
       #9 BDP_Chip_EmergencyEscape — 紧急脱离芯片（特殊槽位）
       约束：只能插特殊槽位
       作用：战斗体被动破裂时触发传送
       ══════════════════════════════════════════════════════ -->
  <ThingDef ParentName="BDP_ChipBase">
    <defName>BDP_Chip_EmergencyEscape</defName>
    <label>紧急脱离芯片</label>
    <description>特殊系统芯片。装载后，战斗体被动破裂时自动传送到紧急脱离信标位置。只能插入特殊槽位。</description>
    <graphicData>
      <texPath>Things/Trigger/BDP_Chip_Test</texPath>
    </graphicData>
    <statBases>
      <MarketValue>300</MarketValue>
    </statBases>
    <comps>
      <li Class="BDP.Trigger.CompProperties_TriggerChip">
        <chipEffectClass>BDP.Combat.PassiveChipEffect</chipEffectClass>
        <slotRestriction>SpecialOnly</slotRestriction>
        <activationCost>0</activationCost>
        <allocationCost>200</allocationCost>
        <activationWarmup>0</activationWarmup>
        <deactivationDelay>0</deactivationDelay>
        <categories>
          <li>System</li>
          <li>Passive</li>
          <li>Utility</li>
          <li>HighCost</li>
        </categories>
      </li>
    </comps>
  </ThingDef>

  <!-- ══════════════════════════════════════════════════════
       BDP_Chip_Asteroid — 小行星芯片（远程武器，齐射攻击）
       模块：拖尾（BeamTrailConfig）
       类别：Cube（方块类）
       攻击模式：齐射（Volley）
       ══════════════════════════════════════════════════════ -->
  <ThingDef ParentName="BDP_ChipBase">
    <defName>BDP_Chip_Asteroid</defName>
    <label>小行星</label>
    <description>发射普通弹进行齐射攻击的远程芯片。5发连射，中等射程，具有一定护甲穿透能力。适合对抗中装甲目标。</description>
    <graphicData>
      <texPath>Things/Trigger/BDP_Chip_Test</texPath>
    </graphicData>
    <statBases>
      <MarketValue>1000</MarketValue>
    </statBases>
    <comps>
      <li Class="BDP.Trigger.CompProperties_TriggerChip">
        <chipEffectClass>BDP.Trigger.VerbChipEffect</chipEffectClass>
        <slotRestriction>HandsOnly</slotRestriction>
        <activationCost>12</activationCost>
        <allocationCost>38</allocationCost>
        <drainPerDay>0</drainPerDay>
        <minOutputPower>6</minOutputPower>
        <activationWarmup>30</activationWarmup>
        <deactivationDelay>15</deactivationDelay>
        <categories>
          <li>Weapon</li>
          <li>Ranged</li>
          <li>Medium</li>
          <li>Physical</li>
          <li>Rifle</li>
          <li>Burst</li>
          <li>Cube</li>
        </categories>
      </li>
      <li Class="BDP.FireMode.CompProperties_FireMode"/>
    </comps>
    <modExtensions>
      <li Class="BDP.Trigger.VerbChipConfig">
        <primaryVerbProps>
          <verbClass>BDP.Trigger.Verb_BDPVolley</verbClass>
          <hasStandardCommand>true</hasStandardCommand>
          <defaultProjectile>BDP_Bullet_Normal</defaultProjectile>
          <warmupTime>1.0</warmupTime>
          <range>40</range>
          <burstShotCount>5</burstShotCount>
          <ticksBetweenBurstShots>12</ticksBetweenBurstShots>
          <soundCast>Shot_AssaultRifle</soundCast>
          <soundCastTail>GunTail_Medium</soundCastTail>
          <muzzleFlashScale>9</muzzleFlashScale>
          <defaultCooldownTime>2.0</defaultCooldownTime>
          <accuracyTouch>0.55</accuracyTouch>
          <accuracyShort>0.64</accuracyShort>
          <accuracyMedium>0.55</accuracyMedium>
          <accuracyLong>0.45</accuracyLong>
        </primaryVerbProps>
        <cost>
          <trionPerShot>2</trionPerShot>
        </cost>
        <ranged>
          <volleySpreadRadius>0.3</volleySpreadRadius>
        </ranged>
      </li>
    </modExtensions>
  </ThingDef>

  <!-- ══════════════════════════════════════════════════════
       BDP_Chip_Viper — 毒蛇芯片（远程武器，引导齐射攻击）
       模块：拖尾（BeamTrailConfig）+ 引导（BDPGuidedConfig）
       类别：Cube（方块类）
       攻击模式：引导齐射（Guided Volley）
       ══════════════════════════════════════════════════════ -->
  <ThingDef ParentName="BDP_ChipBase">
    <defName>BDP_Chip_Viper</defName>
    <label>毒蛇</label>
    <description>发射引导弹进行齐射攻击的远程芯片。支持路径引导瞄准，5发连射，中等射程。引导弹伤害较低但能精确命中目标，适合对抗轻装甲目标。每发消耗5 Trion。</description>
    <graphicData>
      <texPath>Things/Trigger/BDP_Chip_Test</texPath>
    </graphicData>
    <statBases>
      <MarketValue>1000</MarketValue>
    </statBases>
    <comps>
      <li Class="BDP.Trigger.CompProperties_TriggerChip">
        <chipEffectClass>BDP.Trigger.VerbChipEffect</chipEffectClass>
        <slotRestriction>HandsOnly</slotRestriction>
        <activationCost>12</activationCost>
        <allocationCost>38</allocationCost>
        <drainPerDay>0</drainPerDay>
        <minOutputPower>6</minOutputPower>
        <activationWarmup>30</activationWarmup>
        <deactivationDelay>15</deactivationDelay>
        <categories>
          <li>Weapon</li>
          <li>Ranged</li>
          <li>Medium</li>
          <li>Physical</li>
          <li>Rifle</li>
          <li>Burst</li>
          <li>Cube</li>
        </categories>
      </li>
      <li Class="BDP.FireMode.CompProperties_FireMode"/>
    </comps>
    <modExtensions>
      <li Class="BDP.Trigger.VerbChipConfig">
        <primaryVerbProps>
          <verbClass>BDP.Trigger.Verb_BDPVolley</verbClass>
          <hasStandardCommand>true</hasStandardCommand>
          <defaultProjectile>BDP_Bullet_Guided</defaultProjectile>
          <warmupTime>1.0</warmupTime>
          <range>40</range>
          <burstShotCount>5</burstShotCount>
          <ticksBetweenBurstShots>12</ticksBetweenBurstShots>
          <soundCast>Shot_AssaultRifle</soundCast>
          <soundCastTail>GunTail_Medium</soundCastTail>
          <muzzleFlashScale>9</muzzleFlashScale>
          <defaultCooldownTime>2.0</defaultCooldownTime>
          <accuracyTouch>0.55</accuracyTouch>
          <accuracyShort>0.64</accuracyShort>
          <accuracyMedium>0.55</accuracyMedium>
          <accuracyLong>0.45</accuracyLong>
        </primaryVerbProps>
        <cost>
          <trionPerShot>5</trionPerShot>
        </cost>
        <ranged>
          <volleySpreadRadius>0.3</volleySpreadRadius>
          <guided>
            <maxAnchors>5</maxAnchors>
            <anchorSpread>0.3</anchorSpread>
          </guided>
        </ranged>
      </li>
    </modExtensions>
  </ThingDef>

</Defs>