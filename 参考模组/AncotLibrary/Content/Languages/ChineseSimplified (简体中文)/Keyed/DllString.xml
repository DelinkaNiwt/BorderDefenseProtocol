  <!-- EN: recover {0} -->
  <Ancot.MechCarrierRecover>回收{0}</Ancot.MechCarrierRecover>
  <!-- EN: Recall all {1} that have been released, convert them back to {4} for storage. The amount of {4} recovered is related to the percentage of remaining health of {1}. When the health of the recovered {1} is full, {5} release cost can be recovered.\n\nRecover {1} will put the release capability into a long period of cooling. -->
