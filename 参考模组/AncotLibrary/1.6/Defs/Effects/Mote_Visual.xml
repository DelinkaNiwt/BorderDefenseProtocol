<?xml version="1.0" encoding="utf-8" ?>
<Defs>

  <EffecterDef>
    <defName>Ancot_SmokeReleasing_Fast</defName>
    <children>
      <li>
        <subEffecterClass>SubEffecter_Sustainer</subEffecterClass>
        <soundDef>GasReleasing</soundDef>
      </li>
      <li>
        <subEffecterClass>SubEffecter_SprayerChance</subEffecterClass>
        <positionRadius>0.3</positionRadius>
        <fleckDef>Fleck_SmokeSmall</fleckDef>
        <chancePerTick>0.5</chancePerTick>
        <scale>0.5~1</scale>
        <spawnLocType>OnSource</spawnLocType>
      </li>
    </children>
  </EffecterDef>
  <FleckDef ParentName="FleckBase_Thrown">
    <defName>Fleck_SmokeSmall</defName>
    <altitudeLayer>MoteOverhead</altitudeLayer>
    <fadeInTime>0.3</fadeInTime>
    <solidTime>0</solidTime>
    <fadeOutTime>0.3</fadeOutTime>
    <growthRate>0.8</growthRate>
    <acceleration>(0, 0, 2)</acceleration>
    <graphicData>
      <texPath>Things/Gas/GasCloudThickA</texPath>
      <shaderType>TransparentPostLight</shaderType>
      <color>(255, 255, 255, 64)</color>
    </graphicData>
  </FleckDef>

  <FleckDef ParentName="FleckBase_Thrown">
    <defName>Ancot_Fleck_CrossHair</defName>
    <altitudeLayer>MoteOverhead</altitudeLayer>
    <fadeInTime>0.01</fadeInTime>
    <solidTime>0.05</solidTime>
    <fadeOutTime>0.2</fadeOutTime>
    <acceleration>(0, 0, 2)</acceleration>
    <graphicData>
      <texPath>AncotLibrary/Mote/CrossHair</texPath>
      <shaderType>MoteGlow</shaderType>
    </graphicData>
  </FleckDef>

  <ThingDef ParentName="MoteBase">
    <defName>Ancot_Mote_SmokeCircle</defName>
    <graphicData>
      <texPath>AncotLibrary/Mote/SmokeCircle</texPath>
      <shaderType>TransparentPostLight</shaderType>
    </graphicData>
    <altitudeLayer>Projectile</altitudeLayer>
    <mote>
      <fadeInTime>0.02</fadeInTime>
      <solidTime>0.2</solidTime>
      <fadeOutTime>0.1</fadeOutTime>
      <growthRate>3.8</growthRate>
      <rotateTowardsMoveDirection>true</rotateTowardsMoveDirection>
    </mote>
  </ThingDef>

</Defs>