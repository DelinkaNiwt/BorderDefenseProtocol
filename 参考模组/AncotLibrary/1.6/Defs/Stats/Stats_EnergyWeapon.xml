<?xml version="1.0" encoding="utf-8" ?>
<Defs>

  <StatDef Name="Ancot_EnergyWeapon" Abstract="true">
    <category>Ancot_EnergyWeapon</category>
    <showIfUndefined>false</showIfUndefined>
  </StatDef>

  <StatDef ParentName="Ancot_EnergyWeapon">
    <defName>Ancot_WeaponMaxCharge</defName>
    <label>max charge</label>
    <description>The max charge of this weapon.</description>
    <displayPriorityInCategory>1000</displayPriorityInCategory>
    <defaultBaseValue>100</defaultBaseValue>
    <minValue>1</minValue>
    <toStringStyle>Integer</toStringStyle>
    <parts>
      <li Class="AncotLibrary.StatPart_EnergyWeaponEquipped">
        <pawnStat>Ancot_WeaponMaxChargeFactor</pawnStat>
        <correctionStat>Ancot_EnergyWeaponCorrectionFactor</correctionStat>
      </li>
      <li Class="StatPart_Quality">
        <factorAwful>0.8</factorAwful>
        <factorPoor>0.9</factorPoor>
        <factorNormal>1</factorNormal>
        <factorGood>1.1</factorGood>
        <factorExcellent>1.2</factorExcellent>
        <factorMasterwork>1.35</factorMasterwork>
        <factorLegendary>1.5</factorLegendary>
      </li>
    </parts>
  </StatDef>

  <StatDef ParentName="Ancot_EnergyWeapon">
    <defName>Ancot_WeaponChargeTick</defName>
    <label>charge interval</label>
    <workerClass>AncotLibrary.StatWorker_TickToSecond</workerClass>
    <description>Time required by each auto recharge of this weapon.</description>
    <displayPriorityInCategory>990</displayPriorityInCategory>
    <defaultBaseValue>100</defaultBaseValue>
    <minValue>1</minValue>
    <toStringStyle>FloatTwo</toStringStyle>
    <formatString>{0} s</formatString>
    <parts>
      <li Class="AncotLibrary.StatPart_EnergyWeaponEquipped">
        <pawnStat>Ancot_WeaponChargeTickFactor</pawnStat>
        <correctionStat>Ancot_EnergyWeaponCorrectionFactor</correctionStat>
      </li>
      <li Class="StatPart_Quality">
        <factorAwful>1.2</factorAwful>
        <factorPoor>1.1</factorPoor>
        <factorNormal>1</factorNormal>
        <factorGood>0.95</factorGood>
        <factorExcellent>0.9</factorExcellent>
        <factorMasterwork>0.85</factorMasterwork>
        <factorLegendary>0.8</factorLegendary>
      </li>
    </parts>
  </StatDef>

  <StatDef ParentName="Ancot_EnergyWeapon">
    <defName>Ancot_EnergyWeaponResetTime</defName>
    <label>reset time</label>
    <workerClass>AncotLibrary.StatWorker_TickToSecond</workerClass>
    <description>The time required to recover energy when the weapon is fully depleted.</description>
    <displayPriorityInCategory>980</displayPriorityInCategory>
    <defaultBaseValue>100</defaultBaseValue>
    <minValue>1</minValue>
    <toStringStyle>FloatTwo</toStringStyle>
    <formatString>{0} s</formatString>
    <parts>
      <li Class="StatPart_Quality">
        <factorAwful>1.0</factorAwful>
        <factorPoor>1.0</factorPoor>
        <factorNormal>1.0</factorNormal>
        <factorGood>1.0</factorGood>
        <factorExcellent>1.0</factorExcellent>
        <factorMasterwork>0.9</factorMasterwork>
        <factorLegendary>0.8</factorLegendary>
      </li>
    </parts>
  </StatDef>

  <!-- 修正系数 -->
  <StatDef ParentName="Ancot_EnergyWeapon">
    <defName>Ancot_EnergyWeaponCorrectionFactor</defName>
    <label>correction factor</label>
    <description>The multiplier that modifies this energy weapon's attributes based on external conditions.</description>
    <minValue>0</minValue>
    <maxValue>1</maxValue>
    <defaultBaseValue>1.0</defaultBaseValue>
    <toStringStyle>PercentZero</toStringStyle>
    <displayPriorityInCategory>900</displayPriorityInCategory>
    <parts>
      <li Class="StatPart_Quality">
        <factorAwful>0.8</factorAwful>
        <factorPoor>0.9</factorPoor>
        <factorNormal>1</factorNormal>
        <factorGood>1</factorGood>
        <factorExcellent>1.1</factorExcellent>
        <factorMasterwork>1.15</factorMasterwork>
        <factorLegendary>1.25</factorLegendary>
      </li>
    </parts>
  </StatDef>



</Defs>