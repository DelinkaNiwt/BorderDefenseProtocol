<?xml version="1.0" encoding="utf-8"?>
<Defs>

  <ThingDef ParentName="BuildingBase">
    <defName>Milira_HarrierFighter</defName>
    <label>milira harrier fighter</label>
    <description>A small fighter that uses force-field propulsion for flight and can perform vertical takeoffs and landings. Consumes a small amount of solar fuel to initiate liftoff, after which it can fly solely on its built-in fuel cell.\n\nEquipped with two particle autocannons, consuming 0.05 solar fuel per shot.</description>
    <thingClass>AncotLibrary.Building_Aerocraft</thingClass>
    <preventDroppingThingsOn>true</preventDroppingThingsOn>
    <altitudeLayer>Building</altitudeLayer>
    <pathCost>0</pathCost>
    <blockWind>true</blockWind>
    <drawOffscreen>true</drawOffscreen>
    <seeThroughFog>true</seeThroughFog>
    <passability>Standable</passability>
    <fillPercent>0.5</fillPercent>
    <size>(3,3)</size>
    <drawHighlight>true</drawHighlight>
    <highlightColor>(0.56, 0.62, 0.9)</highlightColor>
    <uiIconScale>1</uiIconScale>
    <drawDamagedOverlay>false</drawDamagedOverlay>
    <graphicData>
      <graphicClass>Graphic_Multi</graphicClass>
      <texPath>Milira/Building/Shuttle/Harrier</texPath>
      <shaderType>CutoutComplex</shaderType>
      <drawSize>(4,4)</drawSize>
      <drawOffset>(0, 0, 0)</drawOffset>
      <shadowData>
        <volume>(0.8, 0.8, 2.2)</volume>
        <offset>(-0.1, 0, 0)</offset>
      </shadowData>
      <damageData>
        <rect>(0, 0, 0, 0)</rect>
      </damageData>
    </graphicData>
    <statBases>
      <MaxHitPoints>400</MaxHitPoints>
      <Flammability>0.2</Flammability>
      <WorkToBuild>36000</WorkToBuild>
      <Comfort>0.65</Comfort>
      <Ancot_Aerocraft_MaxSpeed>12</Ancot_Aerocraft_MaxSpeed>
      <Ancot_Aerocraft_MinTurnRadius>3</Ancot_Aerocraft_MinTurnRadius>
      <Ancot_Aerocraft_ArmorRating>0.8</Ancot_Aerocraft_ArmorRating>
    </statBases>
    <tickerType>Normal</tickerType>
    <designationCategory>Odyssey</designationCategory>
    <constructionSkillPrerequisite>8</constructionSkillPrerequisite>
    <costList>
      <Milira_SplendidSteel>280</Milira_SplendidSteel>
      <Milira_SunPlateSteel>60</Milira_SunPlateSteel>
      <ComponentIndustrial>35</ComponentIndustrial>
      <Milira_StarshipBattery>1</Milira_StarshipBattery>
    </costList>
    <canOverlapZones>true</canOverlapZones>
    <killedLeavings>
      <Milira_SplendidSteel>60</Milira_SplendidSteel>
      <Milira_ChunkSlag_SunPlateSteel>3</Milira_ChunkSlag_SunPlateSteel>
      <ComponentIndustrial>8</ComponentIndustrial>
    </killedLeavings>
    <rotatable>true</rotatable>
    <hasInteractionCell>true</hasInteractionCell>
    <interactionCellOffset>(0, 0, -2)</interactionCellOffset>
    <defaultPlacingRot>East</defaultPlacingRot>
    <selectable>true</selectable>
    <terrainAffordanceNeeded>Light</terrainAffordanceNeeded>
    <soundImpactDefault>BulletImpact_Metal</soundImpactDefault>
    <preventSkyfallersLandingOn>true</preventSkyfallersLandingOn>
    <drawerType>RealtimeOnly</drawerType>
    <repairEffect>ConstructMetal</repairEffect>
    <forceDebugSpawnable>true</forceDebugSpawnable>
    <building>
      <combatPower>400</combatPower>
      <expandHomeArea>false</expandHomeArea>
      <destroySound>BuildingDestroyed_Metal_Big</destroySound>
      <paintable>true</paintable>
      <isInert>true</isInert>
      <isEdifice>false</isEdifice>
      <forcedCostLeavings>
        <li MayRequire="Ludeon.RimWorld.Odyssey">Milira_StarshipBattery</li>
      </forcedCostLeavings>
    </building>
    <inspectorTabs>
      <li>AncotLibrary.ITab_ContentsAerocraft</li>
    </inspectorTabs>
    <researchPrerequisites>
      <li>Milira_ForceFieldAerocraft</li>
      <li>Milira_ParticleAcceleratorIII</li>
    </researchPrerequisites>
    <comps>
      <li Class="CompProperties_Shuttle">
        <compClass>AncotLibrary.CompShuttleAerocraft</compClass>
        <shipDef>Milira_HarrierFighter</shipDef>
      </li>
      <li Class="CompProperties_Launchable">
        <compClass>AncotLibrary.CompLaunchableAerocraft</compClass>
        <fuelPerTile>0.01</fuelPerTile>
        <minFuelCost>10</minFuelCost>
        <skyfallerLeaving>Milira_HarrierFighterLeaving</skyfallerLeaving>
        <worldObjectDef>Milira_HarrierFighter</worldObjectDef>
        <cooldownTicks>1500</cooldownTicks>
        <fixedLaunchDistanceMax>165</fixedLaunchDistanceMax>
        <cooldownEndedMessage>{0} is ready to launch again.</cooldownEndedMessage>
      </li>
      <li Class="CompProperties_Transporter">
        <compClass>AncotLibrary.CompTransporterAerocraft</compClass>
        <massCapacity>240</massCapacity>
        <max1PerGroup>true</max1PerGroup>
        <canChangeAssignedThingsAfterStarting>true</canChangeAssignedThingsAfterStarting>
        <pawnLoadedSound>Shuttle_PawnLoaded</pawnLoadedSound>
        <pawnExitSound>Shuttle_PawnExit</pawnExitSound>
        <showMassInInspectString>true</showMassInInspectString>
      </li>
      <li Class="CompProperties_Refuelable">
        <compClass>AncotLibrary.CompRefuelableAerocraft</compClass>
        <fuelCapacity>100</fuelCapacity>
        <targetFuelLevelConfigurable>true</targetFuelLevelConfigurable>
        <initialConfigurableTargetFuelLevel>100</initialConfigurableTargetFuelLevel>
        <fuelFilter>
          <thingDefs>
            <li>Milira_SunLightFuel</li>
          </thingDefs>
        </fuelFilter>
        <fuelLabel>SolarFuel</fuelLabel>
        <fuelGizmoLabel>SolarFuel</fuelGizmoLabel>
        <consumeFuelOnlyWhenUsed>true</consumeFuelOnlyWhenUsed>
        <autoRefuelPercent>1</autoRefuelPercent>
        <showFuelGizmo>true</showFuelGizmo>
        <drawOutOfFuelOverlay>false</drawOutOfFuelOverlay>
        <showAllowAutoRefuelToggle>true</showAllowAutoRefuelToggle>
        <canEjectFuel>true</canEjectFuel>
      </li>
      <li Class="CompProperties_AmbientSound">
        <sound>ShuttleIdle_Ambience</sound>
      </li>
      <li Class="AncotLibrary.CompProperties_Aerocraft">
        <inflightGraphicData>
          <graphicClass>Graphic_Single</graphicClass>
          <texPath>Milira/Building/Shuttle/HarrierLaunched_north</texPath>
          <shaderType>CutoutComplex</shaderType>
          <drawSize>(4,4)</drawSize>
        </inflightGraphicData>
        <takeOffIconPath>Milira/Building/Shuttle/HarrierTakeOff</takeOffIconPath>
        <landingIconPath>Milira/Building/Shuttle/HarrierLanding</landingIconPath>
        <takeOffFuelCost>10</takeOffFuelCost>
        <!-- <weaponSlotCellOffsets>
          <li>(-1, 0, 0)</li>
          <li>(1, 0, 0)</li>
        </weaponSlotCellOffsets> -->
        <fleckIntervalTicks>6</fleckIntervalTicks>
        <takeOffEffect>Milian_HarrierFighterTakeOff</takeOffEffect>
        <flightFlecks>
          <li>
            <fleckDef>Milira_AirPuffGlow</fleckDef>
            <offset>(1.0,-0.1,-0.6)</offset>
            <fleckColor>(0.4,0.8,1.0,0.6)</fleckColor>
          </li>
          <li>
            <fleckDef>Milira_AirPuffGlow</fleckDef>
            <offset>(-1.0,-0.1,-0.6)</offset>
            <fleckColor>(0.4,0.8,1.0,0.6)</fleckColor>
          </li>
        </flightFlecks>
      </li>
      <li Class="AncotLibrary.CompProperties_TurretGun_Building">
        <turretDef>MiliraTurret_HarrierFighter_MiniGun</turretDef>
        <turretDrawScale>3</turretDrawScale>
        <consumeChargeAmountPerShot>0.05</consumeChargeAmountPerShot>
        <statLabelPostfix>1</statLabelPostfix>
        <turretDrawOffset>(0.6, -0.3)</turretDrawOffset>
      </li>
      <li Class="AncotLibrary.CompProperties_TurretGun_Building">
        <turretDef>MiliraTurret_HarrierFighter_MiniGun</turretDef>
        <consumeChargeAmountPerShot>0.05</consumeChargeAmountPerShot>
        <turretDrawScale>3</turretDrawScale>
        <turretDrawOffset>(-0.6, -0.3)</turretDrawOffset>
        <statLabelPostfix>2</statLabelPostfix>
        <saveKeysPrefix>B</saveKeysPrefix>
      </li>
      <li Class="CompProperties_Explosive">
        <wickTicks>60</wickTicks>
        <damageAmountBase>60</damageAmountBase>
        <armorPenetrationBase>0.6</armorPenetrationBase>
        <explosiveRadius>3.9</explosiveRadius>
        <explosiveDamageType>Bomb</explosiveDamageType>
        <drawWick>false</drawWick>
        <startWickHitPointsPercent>0.01</startWickHitPointsPercent>
      </li>
    </comps>
    <placeWorkers>
      <li>PlaceWorker_NotUnderRoof</li>
    </placeWorkers>
    <uiIconScale>0.8</uiIconScale>
    <uiOrder>2600</uiOrder>
  </ThingDef>

  <TransportShipDef>
    <defName>Milira_HarrierFighter</defName>
    <label>milira harrier fighter</label>
    <shipThing>Milira_HarrierFighter</shipThing>
    <arrivingSkyfaller>Milira_HarrierFighterIncoming</arrivingSkyfaller>
    <leavingSkyfaller>Milira_HarrierFighterLeaving</leavingSkyfaller>
    <worldObject>Milira_HarrierFighter</worldObject>
    <playerShuttle>true</playerShuttle>
  </TransportShipDef>

  <WorldObjectDef ParentName="ShuttleWorldObjectBase">
    <defName>Milira_HarrierFighter</defName>
    <label>milira harrier fighter</label>
    <description>A small fighter that uses force-field propulsion for flight and can perform vertical takeoffs and landings. Consumes a small amount of solar fuel to initiate liftoff, after which it can fly solely on its built-in fuel cell.</description>
    <expandingIconTexture>Milira/Building/Shuttle/Harrier_north</expandingIconTexture>
    <expandingIconDrawSize>1</expandingIconDrawSize>
    <expandingIconColor>(255,255,255)</expandingIconColor>
    <rotateGraphicWhenTraveling>true</rotateGraphicWhenTraveling>
    <modExtensions>
      <li Class="AncotLibrary.WorldObjectShuttle_Extension">
        <traveledPctStepPerTickFactor>3.0</traveledPctStepPerTickFactor>
      </li>
    </modExtensions>
  </WorldObjectDef>


