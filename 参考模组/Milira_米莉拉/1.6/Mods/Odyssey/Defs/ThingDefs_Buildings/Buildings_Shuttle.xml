  <!-- 鹞式战机机炮 -->
  <ThingDef ParentName="Milira_CombatDroneTurretBase">
    <defName>MiliraTurret_HarrierFighter_MiniGun</defName>
    <label>particle minigun</label>
    <description>a particle minigun installed on harrier fighter.</description>
    <graphicData>
      <texPath>Milira/Building/Shuttle/HarrierFighterMiniGun</texPath>
      <graphicClass>Graphic_Single</graphicClass>
    </graphicData>
    <statBases>
      <Mass>8.2</Mass>
      <AccuracyTouch>0.78</AccuracyTouch>
      <AccuracyShort>0.65</AccuracyShort>
      <AccuracyMedium>0.54</AccuracyMedium>
      <AccuracyLong>0.42</AccuracyLong>
      <RangedWeapon_Cooldown>4</RangedWeapon_Cooldown>
    </statBases>
    <verbs>
      <li>
        <verbClass>AncotLibrary.Verb_TurretShoot</verbClass>
        <defaultProjectile>MiliraBullet_HarrierFighterMiniGun</defaultProjectile>
        <requireLineOfSight>false</requireLineOfSight>
        <range>33.9</range>
        <soundCast>Milira_Shot_ParticlePulse</soundCast>
        <soundCastTail>GunTail_Heavy</soundCastTail>
        <muzzleFlashScale>3</muzzleFlashScale>
        <defaultCooldownTime>4</defaultCooldownTime>
        <burstShotCount>12</burstShotCount>
        <ticksBetweenBurstShots>6</ticksBetweenBurstShots>
      </li>
    </verbs>
  </ThingDef>
  <ThingDef ParentName="MiliraBullet_ParticleBase">
    <defName>MiliraBullet_HarrierFighterMiniGun</defName>
    <label>particle beam</label>
    <thingClass>AncotLibrary.Projectile_Aerocraft</thingClass>
    <projectile>
      <flyOverhead>true</flyOverhead>
      <damageDef>Bullet</damageDef>
      <damageAmountBase>18</damageAmountBase>
      <armorPenetrationBase>0.2</armorPenetrationBase>
      <stoppingPower>0.8</stoppingPower>
      <speed>125</speed>
    </projectile>
    <graphicData>
      <texPath>Milira/ProjectileNew/Bullet_Particle</texPath>
      <graphicClass>Graphic_Single</graphicClass>
      <shaderType>MoteGlow</shaderType>
      <drawSize>1.5</drawSize>
    </graphicData>
    <modExtensions>
      <li Class = "AncotLibrary.Projectile_Aerocraft_Extension"/>
    </modExtensions>
  </ThingDef>

</Defs>