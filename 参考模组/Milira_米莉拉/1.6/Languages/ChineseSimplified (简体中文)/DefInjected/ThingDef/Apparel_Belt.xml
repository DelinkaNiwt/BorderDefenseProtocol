  <!-- EN: grenade -->
  <Milira_Apparel_PlasmaShockGrenade.comps.CompApparelReloadable.chargeNoun>手雷</Milira_Apparel_PlasmaShockGrenade.comps.CompApparelReloadable.chargeNoun>
