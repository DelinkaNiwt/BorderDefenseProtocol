<?xml version="1.0" encoding="UTF-8"?>
<!--
  ProjectTrion Framework - LoadFolders.xml

  此文件控制RimWorld在加载模组时选择哪些文件夹。

  框架目录结构说明：
  - Content/        - 所有版本间共享的资源（本地化文本等）
  - 1.6/            - RimWorld 1.6 版本特定的内容
  - 1.6/Defs/       - 游戏定义文件（仅包含框架接口和配置）
  - 1.6/Assemblies/ - 编译的C# dll（框架代码）

  加载顺序很重要：
  - Content/ 中的资源（共享）应该首先加载
  - 版本特定内容应该随后加载
  - DLC条件加载应放在最后
-->

<loadFolders>

  <!-- RimWorld 1.6 版本配置 -->
  <v1.6>
    <!-- 步骤1：加载共享资源（本地化等） -->
    <li>Content</li>

    <!-- 步骤2：加载1.6版本特定内容（Defs、Assemblies） -->
    <li>1.6</li>

    <!--
      步骤3：条件加载DLC特定内容（如果需要）
      此框架暂不依赖特定DLC，但可以在此扩展

      常见DLC ID：
      - Ludeon.RimWorld.Royalty     （贵族 - Royalty）
      - Ludeon.RimWorld.Biotech     （生物技术 - Biotech）
      - Ludeon.RimWorld.Ideology    （意识形态 - Ideology）
      - Ludeon.RimWorld.Anomaly     （异常 - Anomaly）
      - Ludeon.RimWorld.Odyssey     （奥德赛 - Odyssey）
    -->
    <!-- 示例（如果框架需要支持特定DLC，取消注释）:
    <li IfModActive="Ludeon.RimWorld.Royalty">1.6/Mods/Royalty</li>
    -->

  </v1.6>

  <!--
    如需支持其他版本，在此添加相应配置
    但框架目前仅针对 v1.6.4633 设计

  <v1.5>
    <li>Content</li>
    <li>1.5</li>
  </v1.5>

  <v1.4>
    <li>Content</li>
    <li>1.4</li>
  </v1.4>
  -->

</loadFolders>
