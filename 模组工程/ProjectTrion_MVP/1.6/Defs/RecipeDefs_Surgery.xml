<?xml version="1.0" encoding="utf-8"?>
<Defs>

  <!-- ======================== 植入Trion腺体手术 ======================== -->
  <RecipeDef>
    <defName>Surgery_ImplantTrionGland</defName>
    <label>植入Trion腺体</label>
    <description>在Pawn的身体内植入Trion腺体，使其获得Trion能量管理系统。\n\n手术成功后，自动附加CompTrion组件，Pawn可以装备和使用Trion组件。</description>
    <workerClass>Recipe_Surgery</workerClass>
    <jobString>进行Trion腺体植入手术</jobString>
    <workAmount>2000</workAmount>
    <skillRequirements>
      <Medicine>5</Medicine>
    </skillRequirements>
    <recipeUsers>
      <li>VitalsMonitor</li>
    </recipeUsers>
    <ingredients>
      <li>
        <filter>
          <thingDefs>
            <li>TrionComponent_ArcBlade</li>
          </thingDefs>
        </filter>
        <count>1</count>
      </li>
    </ingredients>
    <fixedIngredientFilter>
      <thingDefs>
        <li>TrionComponent_ArcBlade</li>
      </thingDefs>
    </fixedIngredientFilter>
    <surgerySuccessChanceFactor>0.95</surgerySuccessChanceFactor>
    <anesthetize>true</anesthetize>
    <addsHediff>Hediff_TrionGland</addsHediff>
    <appliedOnFixedBodyPartGroups>
      <li>Torso</li>
    </appliedOnFixedBodyPartGroups>

  </RecipeDef>

</Defs>
