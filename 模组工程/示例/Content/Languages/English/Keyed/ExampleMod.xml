<?xml version="1.0" encoding="UTF-8"?>
<!--
  示例：本地化文件 (English)

  此文件包含游戏内显示的所有英文文本。
  遵循"键值"模式：defName -> 游戏显示的label。

  优点：
  - 易于集中管理所有文本
  - 便于翻译（创建其他语言版本）
  - 避免在Defs中直接写入硬编码的文本

  路径约定：
  Languages/[语言]/Keyed/[模组名].xml

  其他语言示例：
  - Languages/ChineseSimplified/Keyed/ExampleMod.xml
  - Languages/French/Keyed/ExampleMod.xml
-->

<LanguageData>

  <!-- 物品标签 -->
  <Example_Component_Basic_label>basic component</Example_Component_Basic_label>
  <Example_Component_Basic_description>A simple component used in basic recipes. This is the most fundamental item in the example mod.</Example_Component_Basic_description>

  <!-- 建筑标签 -->
  <Example_Building_SimpleWorkbench_label>simple workbench</Example_Building_SimpleWorkbench_label>
  <Example_Building_SimpleWorkbench_description>A basic workbench where colonists can craft items. This demonstrates a functional building with work interaction.</Example_Building_SimpleWorkbench_description>

  <!-- 武器标签 -->
  <Example_Weapon_SimpleMelee_label>simple blade</Example_Weapon_SimpleMelee_label>
  <Example_Weapon_SimpleMelee_description>A basic melee weapon. Perfect for close combat situations.</Example_Weapon_SimpleMelee_description>

  <Example_Weapon_SimpleGun_label>simple rifle</Example_Weapon_SimpleGun_label>
  <Example_Weapon_SimpleGun_description>A basic firearm for ranged combat.</Example_Weapon_SimpleGun_description>

  <!-- 弹药标签 -->
  <Example_Projectile_SimpleBullet_label>simple bullet</Example_Projectile_SimpleBullet_label>
  <Example_Projectile_SimpleBullet_description>Ammunition for simple rifles.</Example_Projectile_SimpleBullet_description>

  <!-- 提示：
       添加更多文本条目时，使用以下命名约定：
       [DefName]_label     - 物品/系统的显示名称
       [DefName]_description - 物品/系统的说明文本
       [DefName]_[属性]    - 其他特定属性的文本
  -->

</LanguageData>
