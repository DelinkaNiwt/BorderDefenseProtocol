<!--
  LoadFolders.xml 配置模板

  本文件控制RimWorld在加载模组时选择哪些文件夹。
  支持：
  - 按游戏版本加载不同内容
  - 按DLC/模组激活状态条件加载
  - 跨版本共享资源

  使用说明：
  1. 复制此文件到你的模组的根目录
  2. 根据你的模组结构修改版本和路径
  3. 如果仅支持单个版本（如1.6），可以简化配置

  详细说明参考：模组规范文档 > 01_模组目录结构标准规范.md
-->

<!--
  ========================================
  【最简单】单版本模组（仅支持1.6）
  ========================================
-->

<!--
<loadFolders>
  <v1.6>
    <li>1.6</li>
  </v1.6>
</loadFolders>
-->

<!--
  ========================================
  【标准】多版本 + 共享资源
  ========================================

  加载顺序说明：
  1. 先加载Content/（基础共享资源）
  2. 再加载版本特定目录（版本覆盖共享的）
  3. 最后加载DLC特定内容（DLC覆盖版本的）
-->

<!--
<loadFolders>
  <v1.5>
    <li>Content</li>
    <li>1.5</li>
    <li IfModActive="Ludeon.RimWorld.Royalty">1.5/Mods/Royalty</li>
    <li IfModActive="Ludeon.RimWorld.Biotech">1.5/Mods/Biotech</li>
  </v1.5>
  <v1.6>
    <li>Content</li>
    <li>1.6</li>
    <li IfModActive="Ludeon.RimWorld.Royalty">1.6/Mods/Royalty</li>
    <li IfModActive="Ludeon.RimWorld.Biotech">1.6/Mods/Biotech</li>
    <li IfModActive="Ludeon.RimWorld.Odyssey">1.6/Mods/Odyssey</li>
  </v1.6>
</loadFolders>
-->

<!--
  ========================================
  【完整】多版本 + 完整DLC支持
  ========================================
-->

<!--
<loadFolders>
  <v1.4>
