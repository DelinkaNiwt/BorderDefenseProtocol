<?xml version="1.0" encoding="UTF-8"?>
<!-- 完整模板的LoadFolders配置

     完整模板展示了多版本支持的最佳实践：
     - 1.4/、1.5/、1.6/ 分别对应不同版本
     - Content/ 包含跨版本共享的资源
     - Mods/ 目录包含DLC特定内容

     版本间差异处理：
     - 如果某个定义在1.5版本中改变，在1.5/Defs中创建新版本
     - 1.4/只包含1.4特定的内容
     - 共用的部分放在Content/中

     DLC支持：
     - 从1.5开始支持Royalty和Biotech
     - 1.6新增支持Ideology、Anomaly、Odyssey
     - 使用IfModActive条件加载相关内容
-->

<loadFolders>

  <v1.4>
    <!-- 1.4版本：只加载1.4特定内容和共享资源 -->
    <li>Content</li>
    <li>1.4</li>
  </v1.4>

  <v1.5>
    <!-- 1.5版本：包含DLC支持 -->
    <li>Content</li>
    <li>1.5</li>
    <!-- 1.5新增DLC支持 -->
    <li IfModActive="Ludeon.RimWorld.Royalty">1.5/Mods/Royalty</li>
    <li IfModActive="Ludeon.RimWorld.Biotech">1.5/Mods/Biotech</li>
  </v1.5>

  <v1.6>
    <!-- 1.6版本：完整的DLC支持 -->
    <li>Content</li>
    <li>1.6</li>
    <!-- 原有DLC -->
    <li IfModActive="Ludeon.RimWorld.Royalty">1.6/Mods/Royalty</li>
    <li IfModActive="Ludeon.RimWorld.Biotech">1.6/Mods/Biotech</li>
    <li IfModActive="Ludeon.RimWorld.Ideology">1.6/Mods/Ideology</li>
    <!-- 1.6新增DLC -->
    <li IfModActive="Ludeon.RimWorld.Anomaly">1.6/Mods/Anomaly</li>
    <li IfModActive="Ludeon.RimWorld.Odyssey">1.6/Mods/Odyssey</li>
  </v1.6>

</loadFolders>
