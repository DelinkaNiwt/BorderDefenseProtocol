<?xml version="1.0" encoding="utf-8"?>
<ModMetaData>
  <!-- 模组的唯一标识符（推荐使用Steam ID或自定义ID） -->
  <name>My Awesome Tool Mod</name>

  <!-- 简短描述（Steam显示） -->
  <author>Your Name</author>

  <!-- 模组描述 -->
  <description>A simple utility mod that adds useful features to RimWorld. This is a lightweight template for small tools and patches.</description>

  <!-- 模组版本 -->
  <modVersion>1.0.0</modVersion>

  <!-- 支持的RimWorld版本（当前为1.6） -->
  <supportedVersions>
    <li>1.6</li>
  </supportedVersions>

  <!-- 模组依赖（如有） -->
  <dependencies>
    <!-- <li>Ludeon.RimWorld.Biotech</li> -->
  </dependencies>

  <!-- 不兼容的模组 -->
  <incompatibleWith>
    <!-- <li>Some.Conflicting.Mod</li> -->
  </incompatibleWith>

  <!-- Steam工坊ID（发布后自动生成） -->
  <packageId>your.custom.modid</packageId>

  <!-- 加载顺序（可选，默认按字母顺序） -->
  <loadBefore>
    <!-- <li>Ludeon.RimWorld</li> -->
  </loadBefore>

  <loadAfter>
    <!-- <li>Some.OtherMod</li> -->
  </loadAfter>
</ModMetaData>
