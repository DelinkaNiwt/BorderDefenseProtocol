<?xml version="1.0" encoding="utf-8"?>
<!-- 轻量模板 - ThingDefs示例

     ThingDef定义游戏中的"物品"（Thing），包括：
     - 武器
     - 建筑
     - 物品
     - 植物
     - 动物
     等等

     此文件是示例，删除示例内容并添加你自己的定义。
-->

<Defs>

  <!-- ============ 示例：简单的工具物品 ============ -->
  <ThingDef>
    <defName>YourModPrefix_SimpleTool</defName>
    <label>simple tool</label>
    <description>A basic tool for demonstration purposes.</description>

    <!-- 物品类型 -->
    <thingClass>ThingWithComps</thingClass>

    <!-- 分类 -->
    <category>Item</category>
    <selectable>true</selectable>

    <!-- 重量和体积 -->
    <stackLimit>1</stackLimit>
    <mass>0.5</mass>

    <!-- 纹理 -->
    <graphicData>
      <texPath>Things/Item/Tool</texPath>
      <graphicClass>Graphic_Single</graphicClass>
      <drawSize>1</drawSize>
    </graphicData>

    <!-- 物品价值 -->
    <statBases>
      <MarketValue>50</MarketValue>
    </statBases>
  </ThingDef>

  <!-- ============ 示例：简单的建筑 ============ -->
  <ThingDef>
    <defName>YourModPrefix_SimpleBuilding</defName>
    <label>simple building</label>
    <description>A basic building for demonstration.</description>

    <!-- 建筑类型 -->
    <thingClass>Building</thingClass>
    <category>Building</category>
    <selectable>true</selectable>
    <drawerType>MapMeshAndRealTime</drawerType>

    <!-- 建筑属性 -->
    <size>(2,2)</size>
    <passability>PassThroughOnly</passability>
    <rotatable>false</rotatable>

    <!-- 纹理 -->
    <graphicData>
      <texPath>Things/Building/Simple</texPath>
      <graphicClass>Graphic_Multi</graphicClass>
      <drawSize>(2,2)</drawSize>
    </graphicData>

    <!-- 建筑基础属性 -->
    <statBases>
      <MaxHitPoints>100</MaxHitPoints>
      <Flammability>0.3</Flammability>
      <Beauty>0</Beauty>
      <MarketValue>200</MarketValue>
    </statBases>

    <!-- 建筑成本 -->
    <costList>
      <Steel>20</Steel>
      <Wood>30</Wood>
    </costList>

    <!-- 建筑位置 -->
    <placeWorkers>
      <li>PlaceWorker_ShowFacingGizmo</li>
    </placeWorkers>

    <!-- 声音 -->
    <soundImpactDefault>BulletImpact_Ground</soundImpactDefault>
  </ThingDef>

  <!-- 删除上述示例并添加你自己的定义 -->

</Defs>
