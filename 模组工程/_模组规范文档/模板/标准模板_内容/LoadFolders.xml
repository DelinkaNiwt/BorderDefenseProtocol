<?xml version="1.0" encoding="UTF-8"?>
<!-- 标准模板的LoadFolders配置

     结构说明：
     - 1.5/ 和 1.6/ 包含版本特定的内容
     - Content/ 包含在两个版本间共享的资源（如图片、语言文件等）
     - Mods/ 目录包含DLC特定的内容，通过IfModActive条件加载

     加载顺序：
     1. 先加载共享的Content/
     2. 再加载版本特定的内容（1.5/或1.6/）
     3. 最后加载DLC特定的内容（如果DLC激活）

     这个顺序确保DLC内容能够正确覆盖基础内容。
-->

<loadFolders>

  <v1.5>
    <!-- 加载共享内容 -->
    <li>Content</li>
    <!-- 加载1.5版本特定内容 -->
    <li>1.5</li>
    <!-- 条件加载：仅当Royalty DLC激活时 -->
    <li IfModActive="Ludeon.RimWorld.Royalty">1.5/Mods/Royalty</li>
    <!-- 可以继续添加更多DLC条件 -->
    <!-- <li IfModActive="Ludeon.RimWorld.Biotech">1.5/Mods/Biotech</li> -->
  </v1.5>

  <v1.6>
    <li>Content</li>
    <li>1.6</li>
    <li IfModActive="Ludeon.RimWorld.Royalty">1.6/Mods/Royalty</li>
    <li IfModActive="Ludeon.RimWorld.Biotech">1.6/Mods/Biotech</li>
    <!-- 1.6新增的DLC -->
    <li IfModActive="Ludeon.RimWorld.Odyssey">1.6/Mods/Odyssey</li>
  </v1.6>

</loadFolders>
