<?xml version="1.0" encoding="utf-8"?>
<Defs>
  <!-- ========================================
       护盾系统 - Hediff定义
       ======================================== -->

  <!-- 能量盾 - 基础版本（正面180°防护，支持Severity叠加） -->
  <HediffDef>
    <defName>BDP_Shield</defName>
    <label>能量盾</label>
    <description>一个能量护盾，可以抵挡来自正面180度的远程攻击。抵挡成功率70%。每次抵挡会消耗Trion能量。

【Severity机制】激活两个能量盾芯片时，防护范围扩展为360°全方位，成功率提升至95%。</description>
    <hediffClass>BDP.Trigger.Shield.Hediff_BDPShield</hediffClass>
    <defaultLabelColor>(0.6, 0.8, 1.0)</defaultLabelColor>
    <isBad>false</isBad>

    <!-- Severity配置 -->
    <initialSeverity>1</initialSeverity>
    <minSeverity>0</minSeverity>
    <maxSeverity>2</maxSeverity>

    <comps>
      <li Class="BDP.Trigger.Shield.HediffCompProperties_BDPShield">
        <!-- 基础配置（Severity=1）：正面180°防护 -->
        <enableAngleCheck>true</enableAngleCheck>
        <blockAngleRange>180</blockAngleRange>
        <blockAngleOffset>0</blockAngleOffset>

        <!-- 成功率：70% -->
        <blockChance>0.7</blockChance>

        <!-- Trion消耗：受到20点伤害，消耗14 Trion (20 × 0.7) -->
        <trionCostMultiplier>0.7</trionCostMultiplier>

        <!-- 叠加配置（Severity>=2）：全方位360°防护 -->
        <stackedLabel>全方位能量盾</stackedLabel>
        <stackedEnableAngleCheck>false</stackedEnableAngleCheck>
        <stackedBlockAngleRange>360</stackedBlockAngleRange>
        <stackedBlockChance>0.95</stackedBlockChance>

        <!-- 特效配置 -->
        <blockEffectDef>Interceptor_BlockedProjectilePsychic</blockEffectDef>
        <effectScale>0.25</effectScale>
        <shieldRadius>0.8</shieldRadius>

        <!-- 可视化配置 -->
        <showShieldBubble>true</showShieldBubble>
        <shieldColor>(100, 150, 255, 50)</shieldColor>
      </li>
    </comps>
  </HediffDef>

  <!-- 前方护盾 - 定向防护（仅前方120度） -->
  <HediffDef>
    <defName>BDP_ShieldFront</defName>
    <label>前方护盾</label>
    <description>一个能量护盾，只能抵挡来自前方120度（左60°右60°）的远程攻击。抵挡成功率90%，但防护范围有限。每次抵挡会消耗Trion能量。</description>
    <hediffClass>BDP.Trigger.Shield.Hediff_BDPShield</hediffClass>
    <defaultLabelColor>(0.6, 0.8, 1.0)</defaultLabelColor>
    <isBad>false</isBad>
    <comps>
      <li Class="BDP.Trigger.Shield.HediffCompProperties_BDPShield">
        <!-- 方向判定：仅前方120度 -->
        <enableAngleCheck>true</enableAngleCheck>
        <blockAngleRange>120</blockAngleRange>
        <blockAngleOffset>0</blockAngleOffset>

        <!-- 成功率：90% -->
        <blockChance>0.9</blockChance>

        <!-- Trion消耗：与全方位护盾相同 -->
        <trionCostMultiplier>0.5</trionCostMultiplier>

        <!-- 特效配置 -->
        <blockEffectDef>Interceptor_BlockedProjectilePsychic</blockEffectDef>
        <effectScale>0.25</effectScale> <!-- 特效缩小到25% (原始的50%) -->
        <shieldRadius>0.6</shieldRadius> <!-- 护盾半径0.6格，紧贴小人身边 -->

        <!-- 可视化配置 -->
        <showShieldBubble>true</showShieldBubble>
        <shieldColor>(100, 200, 255, 60)</shieldColor> <!-- 更亮的蓝色，区分全方位护盾 -->
      </li>
    </comps>
  </HediffDef>

</Defs>

