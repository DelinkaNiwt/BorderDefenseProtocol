<?xml version="1.0" encoding="utf-8"?>
<Defs>

  <!-- ══════════════════════════════════════════════════════
       BDP_Bullet_Normal — 普通弹（小行星芯片使用）
       使用电荷步枪贴图 + 拖尾效果
       伤害9，护甲穿透0.28，速度105
       ══════════════════════════════════════════════════════ -->
  <ThingDef ParentName="BaseBullet">
    <defName>BDP_Bullet_Normal</defName>
    <label>普通弹</label>
    <graphicData>
      <texPath>Things/Projectile/Charge_Small</texPath>
      <graphicClass>Graphic_Single</graphicClass>
    </graphicData>
    <thingClass>BDP.Projectiles.Bullet_BDP</thingClass>
    <projectile>
      <damageDef>Bullet</damageDef>
      <damageAmountBase>9</damageAmountBase>
      <armorPenetrationBase>0.28</armorPenetrationBase>
      <speed>105</speed>
    </projectile>
    <modExtensions>
      <li Class="BDP.Projectiles.Config.BeamTrailConfig">
        <segmentDuration>30</segmentDuration>
        <trailWidth>0.13</trailWidth>
        <trailColor>(0.7, 0.85, 1.0, 1.0)</trailColor>
        <startOpacity>1.0</startOpacity>
        <decayTime>0.8</decayTime>
        <decaySharpness>10.0</decaySharpness>
      </li>
    </modExtensions>
  </ThingDef>

  <!-- ══════════════════════════════════════════════════════
       BDP_Bullet_Guided — 引导弹
       使用电荷步枪贴图 + 拖尾效果 + 引导模块
       伤害5，护甲穿透0.15（适合轻甲），速度70
       ══════════════════════════════════════════════════════ -->
  <ThingDef ParentName="BaseBullet">
    <defName>BDP_Bullet_Guided</defName>
    <label>引导弹</label>
    <graphicData>
      <texPath>Things/Projectile/Charge_Small</texPath>
      <graphicClass>Graphic_Single</graphicClass>
    </graphicData>
    <thingClass>BDP.Projectiles.Bullet_BDP</thingClass>
    <projectile>
      <damageDef>Bullet</damageDef>
      <damageAmountBase>5</damageAmountBase>
      <armorPenetrationBase>0.15</armorPenetrationBase>
      <speed>70</speed>
    </projectile>
    <modExtensions>
      <li Class="BDP.Projectiles.Config.BeamTrailConfig">
        <segmentDuration>30</segmentDuration>
        <trailWidth>0.13</trailWidth>
        <trailColor>(0.7, 0.85, 1.0, 1.0)</trailColor>
        <startOpacity>1.0</startOpacity>
        <decayTime>0.8</decayTime>
        <decaySharpness>10.0</decaySharpness>
      </li>
      <li Class="BDP.Projectiles.Config.BDPGuidedConfig" />
    </modExtensions>
  </ThingDef>

</Defs>
