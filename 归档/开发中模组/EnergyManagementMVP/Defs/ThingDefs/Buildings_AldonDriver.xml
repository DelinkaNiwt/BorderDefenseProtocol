<?xml version="1.0" encoding="utf-8"?>
<Defs>

  <!-- 驱动塔建筑定义 -->
  <ThingDef ParentName="BuildingBase">
    <defName>AldonDriverTower</defName>
    <label>Aldon驱动塔</label>
    <description>能量管理系统的核心建筑。激活后，允许所有授权殖民者恢复能量。

MVP版本功能：
- 全局信号控制
- 启用/停用能量恢复
- 无范围限制（全地图生效）

建造后需要手动激活。</description>
    <thingClass>Aldon.Energy.Building_AldonDriver</thingClass>

    <!-- 图形 -->
    <graphicData>
      <texPath>Things/Building/Power/PowerSwitch</texPath>
      <graphicClass>Graphic_Single</graphicClass>
      <drawSize>(2,2)</drawSize>
    </graphicData>

    <!-- 基础属性 -->
    <altitudeLayer>Building</altitudeLayer>
    <passability>PassThroughOnly</passability>
    <blockWind>true</blockWind>
    <castEdgeShadows>true</castEdgeShadows>
    <fillPercent>0.40</fillPercent>

    <!-- 碰撞体积 -->
    <size>(2,2)</size>

    <!-- 生命值 -->
    <statBases>
      <MaxHitPoints>300</MaxHitPoints>
      <WorkToBuild>2000</WorkToBuild>
      <Flammability>1.0</Flammability>
      <Beauty>-5</Beauty>
    </statBases>

    <!-- 建造要求 -->
    <costList>
      <Steel>100</Steel>
      <ComponentIndustrial>5</ComponentIndustrial>
    </costList>

    <!-- 建造配置 -->
    <building>
      <ai_chillDestination>false</ai_chillDestination>
    </building>

    <!-- 研究要求 -->
    <researchPrerequisites>
      <li>Electricity</li>
    </researchPrerequisites>

    <!-- 建造技能 -->
    <constructionSkillPrerequisite>5</constructionSkillPrerequisite>

    <!-- 分类 -->
    <designationCategory>Misc</designationCategory>

    <!-- 放置规则 -->
    <canOverlapZones>false</canOverlapZones>
    <terrainAffordanceNeeded>Medium</terrainAffordanceNeeded>
  </ThingDef>

</Defs>
