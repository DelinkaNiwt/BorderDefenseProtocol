  <!-- EN: Milian config tab -->
  <Milira.MilianTabEnable_Label>米莉安配置界面</Milira.MilianTabEnable_Label>
  <!-- EN: choose the available way to open milian config tab. -->
  <Milira.MilianTabEnable_Desc>选择打开米莉安配置界面的可用方式。</Milira.MilianTabEnable_Desc>
